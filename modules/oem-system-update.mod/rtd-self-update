rtd::bootstrap_library() {
	if (( BASH_VERSINFO[0] < 4 || (BASH_VERSINFO[0] == 4 && BASH_VERSINFO[1] < 4) )); then
		echo "ERROR: RTD _rtd_library requires Bash 4.4 or newer. Current shell: Bash ${BASH_VERSION}." >&2
		return 1
	fi
	local library_name="${1:-_rtd_library}" minimum_version="" loaded_version path script_dir src_url tmp rc check
	local -a checks=()

	[[ $# -gt 0 && "${1:-}" != --* ]] && { library_name="$1"; shift; }
	[[ $# -gt 0 && "${1:-}" != --* ]] && { minimum_version="$1"; shift; }
	while [[ $# -gt 0 ]]; do
		case "$1" in
			--version|--check)
				[[ -n "${2:-}" ]] || { echo "Missing value for $1" >&2; return 1; }
				[[ "$1" == "--version" ]] && minimum_version="$2" || checks+=("$2")
				shift 2
			;;
			*)
				echo "Unknown rtd::bootstrap_library option: $1" >&2
				return 1
			;;
		esac
	done

	[[ "$library_name" == "_rtd_library" && ${#checks[@]} -eq 0 ]] && checks=(system::log_item library::apply_rtd_defaults)

	rtd::bootstrap_library::ok() {
		loaded_version="${RTD_VERSION:-${RTDFUNCTIONS:-}}"
		if [[ "$library_name" == "_rtd_library" && -n "$minimum_version" ]]; then
			[[ -n "$loaded_version" ]] || return 1
			[[ "$(printf '%s\n%s\n' "$minimum_version" "$loaded_version" | sort -V | tail -n 1)" == "$loaded_version" ]] || return 1
		fi
		for check in "${checks[@]}"; do declare -F "$check" >/dev/null 2>&1 || return 1; done
	}

	[[ "$library_name" == "_rtd_library" && -n "$loaded_version" ]] && rtd::bootstrap_library::ok && return 0

	script_dir="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"
	for path in \
		"${script_dir}/${library_name}" \
		"${script_dir}/../core/${library_name}" \
		"${script_dir}/../../core/${library_name}" \
		"/opt/${_TLA:-${_tla:-rtd}}/core/${library_name}" \
		"/opt/rtd/core/${library_name}" \
		"${HOME:-}/GIT/RTD-Setup/core/${library_name}" \
		"${HOME:-}/RTD-Setup/core/${library_name}"; do
		[[ -r "$path" ]] || continue
		# shellcheck source=/dev/null
		source "$path" ""
		rc=$?
		[[ $rc -eq 0 ]] && rtd::bootstrap_library::ok && return 0
	done

	src_url="https://github.com/${_GIT_PROFILE:-${GIT_Profile:-vonschutter}}/RTD-Setup/raw/main/core/${library_name}"
	tmp="$(mktemp "/tmp/${library_name}.XXXXXX" 2>/dev/null || echo "/tmp/${library_name}.$$")"
	rc=0
	if command -v curl >/dev/null 2>&1; then
		curl -fsSL "$src_url" -o "$tmp" || rc=$?
	elif command -v wget >/dev/null 2>&1; then
		wget -qO "$tmp" "$src_url" || rc=$?
	else
		rc=1
	fi
	[[ ${rc:-0} -eq 0 ]] || { rm -f "$tmp"; return "$rc"; }

	# shellcheck source=/dev/null
	source "$tmp" ""
	rc=$?
	rm -f "$tmp"
	[[ $rc -eq 0 ]] || return "$rc"
	rtd::bootstrap_library::ok && return 0

	echo "Loaded $library_name, but the requested version/functions are not available." >&2
	return 1
}

rtd::stage_powertools_update() {
	RTD_UPDATE_STAGE_DIR="$(mktemp -d "/tmp/${_tla,,}-update.XXXXXX")" || {
		write_error "Failed to create temporary directory for the RTD update."
		return 1
	}

	if git clone --depth=1 "${_git_src_url}" "${RTD_UPDATE_STAGE_DIR}/repository"; then
		write_information "Powertools successfully retrieved into ${RTD_UPDATE_STAGE_DIR}."
		return 0
	fi

	write_error "Failed to retrieve power tools correctly."
	rm -rf -- "${RTD_UPDATE_STAGE_DIR}"
	RTD_UPDATE_STAGE_DIR=
	return 1
}

rtd::cleanup_powertools_stage() {
	[[ -n "${RTD_UPDATE_STAGE_DIR:-}" ]] || return 0
	rm -rf -- "${RTD_UPDATE_STAGE_DIR}"
	RTD_UPDATE_STAGE_DIR=
}

rtd::register_updated_powertools() {
	if (( BASH_VERSINFO[0] < 4 || (BASH_VERSINFO[0] == 4 && BASH_VERSINFO[1] < 4) )); then
		write_error "RTD _rtd_library requires Bash 4.4 or newer. Current shell: Bash ${BASH_VERSION}."
		return 1
	fi
	# shellcheck source=/dev/null
	source "/opt/${_tla,,}/core/_rtd_library"
	oem::register_all_tools
	[[ -e "${_OEM_DIR}/log" || -L "${_OEM_DIR}/log" ]] || ln -s "${_log_dir}" "${_OEM_DIR}/log"
}

rtd::update_powertools_in_place() {
	local install_dir="/opt/${_tla,,}"
	local backup_dir
	local -a rsync_options=(-a --exclude='/.git/')
	backup_dir="${_bakup_dir}/${_tla,,}-$(date +%Y-%m-%d-%H-%M-%S-%s).bakup"

	write_information "Attempting to get the latest RTD tools..."
	hash git >> "${_logfile}" 2>&1 || software::check_native_package_dependency git
	hash rsync >> "${_logfile}" 2>&1 || software::check_native_package_dependency rsync
	rtd::stage_powertools_update || return 1

	if [[ -d "${install_dir}" ]]; then
		write_warning "Backing up old (${install_dir}) to ${backup_dir}..."
		if ! mkdir -p "${backup_dir}" || ! rsync -a "${install_dir}/" "${backup_dir}/"; then
			write_error "Failed to backup ${install_dir}; update cancelled."
			rtd::cleanup_powertools_stage
			return 1
		fi
	fi

	mkdir -p "${install_dir}" || {
		write_error "Failed to create ${install_dir}; update cancelled."
		rtd::cleanup_powertools_stage
		return 1
	}

	# Themes have their own update option and must not be overwritten by a base update.
	[[ -e "${_theme_dir}" ]] && rsync_options+=(--exclude='/themes/')
	write_information "Updating ${install_dir} in place; unmatched installed files will be retained."
	if ! rsync "${rsync_options[@]}" "${RTD_UPDATE_STAGE_DIR}/repository/" "${install_dir}/"; then
		write_error "Failed to synchronize updated RTD tools into ${install_dir}."
		rtd::cleanup_powertools_stage
		return 1
	fi

	rtd::cleanup_powertools_stage
	rtd::register_updated_powertools
}

rtd::reinitialize_powertools() {
	local install_dir="/opt/${_tla,,}"
	local backup_dir
	local theme_backup_dir=""
	backup_dir="${_bakup_dir}/${_tla,,}-$(date +%Y-%m-%d-%H-%M-%S-%s).bakup"

	write_information "Refreshing RTD tools with a clean replacement install..."
	hash git >> "${_logfile}" 2>&1 || software::check_native_package_dependency git
	rtd::stage_powertools_update || return 1

	if [[ -e "${_theme_dir}" ]]; then
		theme_backup_dir="${_bakup_dir}/themes-$(date +%Y-%m-%d-%H-%M-%S-%s).bakup"
		write_information "Moving themes out of the way..."
		if ! mv -- "${_theme_dir}" "${theme_backup_dir}"; then
			write_error "Failed to preserve themes from ${_theme_dir}; refresh cancelled."
			rtd::cleanup_powertools_stage
			return 1
		fi
	fi

	if [[ -d "${install_dir}" ]]; then
		if ! mv -- "${install_dir}" "${backup_dir}"; then
			write_error "Failed to move ${install_dir} out of the way; refresh cancelled."
			[[ -n "${theme_backup_dir}" ]] && mv -- "${theme_backup_dir}" "${_theme_dir}"
			rtd::cleanup_powertools_stage
			return 1
		fi
		write_warning "Backing up old (${install_dir}) to ${backup_dir}.zip..."
		if zip -r -5 -q "${backup_dir}.zip" "${backup_dir}"; then
			rm -rf -- "${backup_dir}"
		else
			write_error "Failed to archive the previous installation; it remains at ${backup_dir}."
		fi
	fi

	if ! mv -- "${RTD_UPDATE_STAGE_DIR}/repository" "${install_dir}"; then
		write_error "Failed to install the refreshed RTD tree."
		rtd::cleanup_powertools_stage
		return 1
	fi
	rm -rf -- "${install_dir}/.git"
	rtd::cleanup_powertools_stage

	if [[ -n "${theme_backup_dir}" && -e "${theme_backup_dir}" ]]; then
		write_information "Restoring themes from ${theme_backup_dir}..."
		rm -rf -- "${_theme_dir}"
		mv -- "${theme_backup_dir}" "${_theme_dir}"
	fi

	rtd::register_updated_powertools
}

rtd::stage_themes_update() {
	RTD_THEME_STAGE_DIR="$(mktemp -d "/tmp/${_tla,,}-themes-update.XXXXXX")" || {
		write_error "Failed to create temporary directory for the themes update."
		return 1
	}

	if git clone --depth=1 "${_git_theme_url}" "${RTD_THEME_STAGE_DIR}/repository"; then
		write_information "Themes successfully retrieved into ${RTD_THEME_STAGE_DIR}."
		return 0
	fi

	write_error "Failed to retrieve themes correctly."
	rm -rf -- "${RTD_THEME_STAGE_DIR}"
	RTD_THEME_STAGE_DIR=
	return 1
}

rtd::cleanup_themes_stage() {
	[[ -n "${RTD_THEME_STAGE_DIR:-}" ]] || return 0
	rm -rf -- "${RTD_THEME_STAGE_DIR}"
	RTD_THEME_STAGE_DIR=
}

rtd::update_themes_in_place() {
	local backup_dir
	backup_dir="${_bakup_dir}/themes-$(date +%Y-%m-%d-%H-%M-%S-%s).bakup"

	hash git >> "${_logfile}" 2>&1 || software::check_native_package_dependency git
	hash rsync >> "${_logfile}" 2>&1 || software::check_native_package_dependency rsync
	rtd::stage_themes_update || return 1

	if [[ -d "${_theme_dir}" ]]; then
		write_warning "Backing up old themes (${_theme_dir}) to ${backup_dir}..."
		if ! mkdir -p "${backup_dir}" || ! rsync -a "${_theme_dir}/" "${backup_dir}/"; then
			write_error "Failed to backup ${_theme_dir}; themes update cancelled."
			rtd::cleanup_themes_stage
			return 1
		fi
	fi

	mkdir -p "${_theme_dir}" || {
		write_error "Failed to create ${_theme_dir}; themes update cancelled."
		rtd::cleanup_themes_stage
		return 1
	}

	write_information "Updating themes in place; unmatched installed files will be retained."
	if ! rsync -a --exclude='/.git/' "${RTD_THEME_STAGE_DIR}/repository/" "${_theme_dir}/"; then
		write_error "Failed to synchronize updated themes into ${_theme_dir}."
		rtd::cleanup_themes_stage
		return 1
	fi

	rtd::cleanup_themes_stage
	write_information "Themes updated."
}

system::perform_powertools_update_linux ()
{
	local choices exit_status choice theme_update_default reinitialize_selected
	local -a cmd options
	theme_update_default=off
	[[ -e "${_theme_dir}" ]] && theme_update_default=on

	cmd=(dialog --backtitle "${PUBLICATION}" --title "${_tla^^} PowerTools Updater" --separate-output --checklist "Please select what to include in the update below:" 22 85 16)
	options=(1 "Update Base RTD Powertools (retain locally added files)" on
		2 "Update menu shortcuts" on
		3 "Update Themes (wallpapers, icons, themes, fonts etc.)" "${theme_update_default}"
		4 "Refresh/Reinitialize Base RTD Powertools (replace install)" off
	)

	choices=$("${cmd[@]}" "${options[@]}" 2>&1 >/dev/tty)
	exit_status=$?
	case $exit_status in
		1) clear && _pressed=Cancel && return ;;
		255) clear && _pressed=ESC && return ;;
	esac

	clear
	reinitialize_selected=false
	for choice in $choices; do
		[[ "${choice}" == "4" ]] && reinitialize_selected=true
	done

	for choice in $choices; do
		case $choice in
			1)
				[[ "${reinitialize_selected}" == true ]] || rtd::update_powertools_in_place || return 1
			;;
			2)
				write_information "Creating menu launchers..."
				oem::rtd_tools_make_launchers
			;;
			3)
				rtd::update_themes_in_place || return 1
			;;
			4)
				rtd::reinitialize_powertools || return 1
			;;
		esac
	done
}


task_setup_rtd_basics() {
	write_information "Task: Attempting to get the latest RTD tools..."
	if [[ "${OSTYPE:0:5}" == "linux" ]]; then
		write_information "Detected Linux OS..."
		system::perform_powertools_update_linux
	elif [[ "$OSTYPE" == "darwin"* ]]; then
		echo "Mac OSX is currently not supported..."
	elif [[ "$OSTYPE" == "cygwin" ]]; then
		echo "CYGWIN is currently unsupported..."
	elif [[ "$OSTYPE" == "msys" ]]; then
		echo "Lightweight shell is currently unsupported... "
	elif [[ "$OSTYPE" == "freebsd"* ]]; then
		echo "Free BSD is currently unsupported... "
	else
		echo "This system is Unknown to this script"
	fi
}




rtd_wait_for_internet_availability () {
	echo "Waiting for internet access..."
	echo "NOTE: Free access to the internet is required to continue."
	while ! ping -c 1 -W 1 8.8.8.8 &>/dev/null ; do
		echo Waiting...
		sleep 5
	done
}



do_update ()
{
	rtd_wait_for_internet_availability
	if task_setup_rtd_basics ; then
		if [[ ! --autoconfirm == ${autoconfirm} ]] ; then		
			if [[ "${_pressed}" == "Cancel" ]] ; then
				dialog --backtitle "${PUBLICATION}" --title "${_TLA} tools updater: CANCELED!" --msgbox "\nQuiting without updateign powertools. \n\n Press OK to confirm." 20 80 ; clear
			elif [[ "${_pressed}" == "ESC" ]] ; then
				echo "[ESC]"
			else
				dialog --backtitle "${PUBLICATION}" --title "${_TLA} tools updater: DONE!" --msgbox "\nUpdating the ${_TLA} tools done!. \n\n Press OK to confirm." 20 80 ; clear
			fi
		fi
		return 0
	else
		[[ --autoconfirm == ${autoconfirm} ]] || dialog --backtitle "${PUBLICATION}" --title "${_TLA} tools updater: ERROR!" --msgbox "\nUpdating the ${_TLA} FAILED!. \n\n Press OK to confirm." 20 80 ; clear
		return 1
	fi
}


