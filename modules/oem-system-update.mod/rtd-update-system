main ()
{
	case "${1:-}" in
		--help | -h)
			script::help
			exit 0
			;;
		config | --config)
			script::config_notice
			exit 0
			;;
		--show)
			script::show_banner
			rtd::bootstrap_library "_rtd_library" || {
				printf "%b\n" "${RED}Failed to load RTD Library.${ENDCOLOR}" >&2
				exit 1
			}
			software::show_updates_installed_today
			exit $?
			;;
		--update | --setup | --noui)
			;;
		--*)
			printf "%b\n" "${RED}Unknown option: $1${ENDCOLOR}"
			printf "%b\n" "Use ${YELLOW}--help${ENDCOLOR} to see supported options."
			exit 2
			;;
	esac

		# Load the RTD library before elevation so the shared helper is available.
		# Its --sudo path preserves only required desktop-session variables.
		rtd::bootstrap_library "_rtd_library" || pause::for_input 1 "$0: $* Failed to load RTD Library!"
		security::ensure_admin --sudo "$@" || pause::for_input 1 "$0: $* Failed to elevate privileges!"

	script::initialize_runtime || pause::for_input 1 "$0: $* Failed to initialize runtime!"
	script::show_banner

	# Check if the RTD library is loaded
	rtd::bootstrap_library "_rtd_library" || pause::for_input 1 "$0: $* Failed to load RTD Library!"

	case "${1:-}" in
		update | --update)
			log_item "The instruction update_me was given..."
			update_me
			;;
		setup | --setup)
			log_item "The instruction setup_me was given..."
			setup_me "${@:2}"
			;;
		--noui)
			write_status "Updating installed software text display only..."
			software::update_system_txt 
			;;
		*)
			if [[ -n "${1:-}" ]]; then
				echo "Request: $1"
			fi

			distro_type=$(system::distribution_type)
			case $distro_type in
				"debian" | "ubuntu" | "linuxmint" | "raspbian" | "pop" | "kali" | "kubuntu" | "elementary" | "zorin" | "mxlinux" | "Lubuntu" |  ubuntu*)
					write_warning "🌀 Found deb based distro, updating installed software..."
					write_warning "💻 Using txt only as deb cannot be forced not to ask any questions"
					software::update_system_txt
					;;
				*)
					write_status "🐧 Updating installed software..."
					software::update_all_ui 
					;;
			esac
			script::offer_remove_abandoned_flatpaks
			;;
	esac
}

