	script::show_banner
	script_name=$(basename "$0")

	printf "%b\n" "${GREEN} HELP ${ENDCOLOR}
${GREEN}--------------------------------------------------------${ENDCOLOR}

  This tool makes it simple to update software from all channels
  available on the system at once. It updates via the native package
  manager as well as newer formats like ${YELLOW}snap${ENDCOLOR} and ${YELLOW}flatpak${ENDCOLOR}.

${BLUE}${BOLD}Usage:${ENDCOLOR}
  ${script_name} [instruction|option] [target...]

${BLUE}${BOLD}Instructions:${ENDCOLOR}
  ${YELLOW}default${ENDCOLOR}  Update via all configured software channels.
  ${YELLOW}update${ENDCOLOR}   Update this updater script to the latest version.
  ${YELLOW}config${ENDCOLOR}   Configure the script. No configuration is currently available.
  ${YELLOW}setup${ENDCOLOR}    Ensure additional software channels are available.

${BLUE}${BOLD}Setup targets:${ENDCOLOR}
  ${YELLOW}flatpak${ENDCOLOR}  Install/configure Flatpak support.
  ${YELLOW}snap${ENDCOLOR}     Install/configure Snap support.
  ${YELLOW}both${ENDCOLOR}     Install/configure both Flatpak and Snap support.

${BLUE}${BOLD}Options:${ENDCOLOR}
  ${YELLOW}--help${ENDCOLOR}   Display this help text.
  ${YELLOW}-h${ENDCOLOR}       Display this help text.
  ${YELLOW}--config${ENDCOLOR} Same as config.
  ${YELLOW}--noui${ENDCOLOR}   Update the system without displaying the user interface.
  ${YELLOW}--setup${ENDCOLOR}  Same as setup. Optionally limit setup to flatpak, snap, or both.

${BLUE}${BOLD}Examples:${ENDCOLOR}
  Update all channels:          ${YELLOW}${script_name}${ENDCOLOR}
  Update this updater:          ${YELLOW}${script_name} update${ENDCOLOR}
  Configure the script:         ${YELLOW}${script_name} config${ENDCOLOR}
  Configure the script:         ${YELLOW}${script_name} --config${ENDCOLOR}
  Setup Flatpak and Snap:       ${YELLOW}${script_name} setup${ENDCOLOR}
  Setup only Flatpak:           ${YELLOW}${script_name} --setup flatpak${ENDCOLOR}
  Setup only Snap:              ${YELLOW}${script_name} --setup snap${ENDCOLOR}
  Setup Flatpak and Snap:       ${YELLOW}${script_name} --setup flatpak snap${ENDCOLOR}
  Setup comma targets:          ${YELLOW}${script_name} --setup flatpak,snap${ENDCOLOR}
  Update without UI:            ${YELLOW}${script_name} --noui${ENDCOLOR}
"
}


