rtd::bootstrap_library() {
	local library_name="${1:-_rtd_library}" minimum_version="" loaded_version path script_dir src_url tmp rc check
	local -a checks=()

	[[ $# -gt 0 && "${1:-}" != --* ]] && { library_name="$1"; shift; }
	[[ $# -gt 0 && "${1:-}" != --* ]] && { minimum_version="$1"; shift; }
	while [[ $# -gt 0 ]]; do
		case "$1" in
			--version|--check)
				[[ -n "${2:-}" ]] || { echo "Missing value for $1" >&2; return 1; }
				[[ "$1" == "--version" ]] && minimum_version="$2" || checks+=("$2")
				shift 2
			;;
			*)
				echo "Unknown rtd::bootstrap_library option: $1" >&2
				return 1
			;;
		esac
	done

	[[ "$library_name" == "_rtd_library" && ${#checks[@]} -eq 0 ]] && checks=(system::log_item library::apply_rtd_defaults)

	rtd::bootstrap_library::ok() {
		loaded_version="${RTD_VERSION:-${RTDFUNCTIONS:-}}"
		if [[ "$library_name" == "_rtd_library" && -n "$minimum_version" ]]; then
			[[ -n "$loaded_version" ]] || return 1
			[[ "$(printf '%s\n%s\n' "$minimum_version" "$loaded_version" | sort -V | tail -n 1)" == "$loaded_version" ]] || return 1
		fi
		for check in "${checks[@]}"; do declare -F "$check" >/dev/null 2>&1 || return 1; done
	}

	[[ "$library_name" == "_rtd_library" && -n "$loaded_version" ]] && rtd::bootstrap_library::ok && return 0

	script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
	for path in \
		"${script_dir}/${library_name}" \
		"${script_dir}/../core/${library_name}" \
		"${script_dir}/../../core/${library_name}" \
		"/opt/${_TLA:-${_tla:-rtd}}/core/${library_name}" \
		"/opt/rtd/core/${library_name}" \
		"${HOME:-}/GIT/RTD-Setup/core/${library_name}" \
		"${HOME:-}/RTD-Setup/core/${library_name}"; do
		[[ -r "$path" ]] || continue
		# shellcheck source=/dev/null
		source "$path" ""
		rc=$?
		[[ $rc -eq 0 ]] && rtd::bootstrap_library::ok && return 0
	done

	src_url="https://github.com/${_GIT_PROFILE:-${GIT_Profile:-vonschutter}}/RTD-Setup/raw/main/core/${library_name}"
	tmp="$(mktemp "/tmp/${library_name}.XXXXXX" 2>/dev/null || echo "/tmp/${library_name}.$$")"
	rc=0
	if command -v curl >/dev/null 2>&1; then
		curl -fsSL "$src_url" -o "$tmp" || rc=$?
	elif command -v wget >/dev/null 2>&1; then
		wget -qO "$tmp" "$src_url" || rc=$?
	else
		rc=1
	fi
	[[ ${rc:-0} -eq 0 ]] || { rm -f "$tmp"; return "$rc"; }

	# shellcheck source=/dev/null
	source "$tmp" ""
	rc=$?
	rm -f "$tmp"
	[[ $rc -eq 0 ]] || return "$rc"
	rtd::bootstrap_library::ok && return 0

	echo "Loaded $library_name, but the requested version/functions are not available." >&2
	return 1
}

log_item ()
{
	DATE=$(date '+%d/%m/%Y %H:%M:%S');
	echo "$DATE --- : $*" >> "${LOGFILE}"
}

script::offer_remove_abandoned_flatpaks ()
{
	local records=""
	local summary=""
	local scope=""
	local app_id=""
	local reason=""
	local answer=""
	local remove_status=0
	local selected_records=""
	local selected_tags=""
	local tag=""
	local install_label=""
	local app_count=0
	local -a checklist_rows=()
	local -A record_by_tag=()

	[[ -t 0 && -t 1 ]] || {
		system::log_item "Skipping abandoned Flatpak application cleanup offer: no interactive terminal."
		return 0
	}
	hash flatpak 2>/dev/null || return 0

	records=$(software::flatpak_list_eol_apps)
	[[ -n "$records" ]] || {
		system::log_item "No end-of-life Flatpak applications were found."
		return 0
	}

	while IFS=$'\t' read -r scope app_id reason; do
		[[ -n "$app_id" ]] || continue
		(( app_count++ ))
		tag="$app_count"
		[[ "$scope" == "--user" ]] && install_label="Current user" || install_label="All users"
		summary+="  ${app_id}"$'\n'
		summary+="      ${install_label}: ${reason}"$'\n'
		checklist_rows+=("$tag" "$app_id" "on" "${install_label}: ${reason}")
		record_by_tag["$tag"]="${scope}"$'\t'"${app_id}"$'\t'"${reason}"
		system::log_item "Found end-of-life Flatpak application: scope=${scope}; app=${app_id}; reason=${reason}"
	done <<<"$records"

	if hash dialog 2>/dev/null; then
		dialog \
			--backtitle "${PUBLICATION}" \
			--title "Unsupported Flatpak Apps" \
			--msgbox "Some installed Flatpak applications are no longer maintained.\n\nYou can review the affected applications on the next screen. Selected applications will be removed, followed by Flatpak runtimes that are no longer used." \
			13 88
		selected_tags=$(dialog \
			--stdout \
			--separate-output \
			--item-help \
			--backtitle "${PUBLICATION}" \
			--title "Unsupported Flatpak Apps" \
			--ok-label "Remove Selected" \
			--cancel-label "Keep Apps" \
			--checklist "Select abandoned applications to remove. Details for the highlighted application appear below." \
			20 100 10 \
			"${checklist_rows[@]}")
		answer=$?
		clear
		[[ $answer -eq 0 ]] || {
			system::log_item "User declined removal of end-of-life Flatpak applications."
			return 0
		}

		while IFS= read -r tag; do
			[[ -n "$tag" && -n "${record_by_tag[$tag]:-}" ]] || continue
			selected_records+="${record_by_tag[$tag]}"$'\n'
		done <<<"$selected_tags"
		records=${selected_records%$'\n'}
		[[ -n "$records" ]] || {
			system::log_item "User kept all end-of-life Flatpak applications."
			return 0
		}
	else
		printf '\nThe following Flatpak applications are no longer maintained:\n\n%s\n' "$summary"
		read -r -p "Remove these applications and clean up unused Flatpak runtimes? [y/N] " answer
		case "$answer" in
			y | Y | yes | YES | Yes)
				;;
			*)
				system::log_item "User declined removal of end-of-life Flatpak applications."
				return 0
				;;
		esac
	fi

	while IFS=$'\t' read -r scope app_id reason; do
		[[ -n "$app_id" ]] || continue
		write_status "Removing abandoned Flatpak application: ${app_id} (${scope})"
		system::log_item "Removing end-of-life Flatpak application: scope=${scope}; app=${app_id}"
		software::from_flathub.org "$app_id" --remove "$scope" 2>&1 | tee -a "$LOGFILE"
		remove_status=${PIPESTATUS[0]}
		if [[ $remove_status -eq 0 ]]; then
			system::log_item "Removed end-of-life Flatpak application: scope=${scope}; app=${app_id}"
		else
			write_warning "Failed to remove Flatpak application: ${app_id}"
			system::log_item "Failed to remove end-of-life Flatpak application: scope=${scope}; app=${app_id}; rc=${remove_status}"
		fi
	done <<<"$records"
}


update_me ()
{
	local script_path="${BASH_SOURCE[0]:-$0}"
	local resolved_path=""
	local script_dir=""
	local script_name=""
	local backup_path=""
	local tmp_path=""
	local src_url=""

	if [[ "$script_path" != */* ]]; then
		script_path=$(command -v -- "$script_path") || {
			write_error "Unable to resolve script path for update: $0"
			return 1
		}
	fi

	if command -v readlink >/dev/null 2>&1; then
		resolved_path=$(readlink -f -- "$script_path" 2>/dev/null || true)
		[[ -n "$resolved_path" ]] && script_path="$resolved_path"
	fi

	script_dir=$(cd -- "$(dirname -- "$script_path")" && pwd -P) || {
		write_error "Unable to resolve script directory for update: $script_path"
		return 1
	}
	script_name=$(basename -- "$script_path")
	script_path="${script_dir}/${script_name}"
	backup_path="${script_path}.bak"
	src_url="${RTD_UPDATE_SOURCE_BASE_URL}/${script_name}"

	if [[ ! -f "$script_path" ]]; then
		write_error "Unable to update because script path is not a regular file: $script_path"
		return 1
	fi

	if [[ ! -w "$script_path" || ! -w "$script_dir" ]]; then
		write_error "Unable to update because script or directory is not writable: $script_path"
		return 1
	fi

	tmp_path=$(mktemp "${script_dir}/.${script_name}.update.XXXXXX") || {
		write_error "Unable to create temporary update file in: $script_dir"
		return 1
	}

	write_status "Downloading updater from: ${src_url}"
	if command -v curl >/dev/null 2>&1; then
		curl -fsSL "$src_url" -o "$tmp_path" || {
			write_error "Failed to download updater with curl."
			rm -f -- "$tmp_path"
			return 1
		}
	elif command -v wget >/dev/null 2>&1; then
		wget --show-progress -O "$tmp_path" "$src_url" || {
			write_error "Failed to download updater with wget."
			rm -f -- "$tmp_path"
			return 1
		}
	else
		write_error "Unable to update because neither curl nor wget is available."
		rm -f -- "$tmp_path"
		return 1
	fi

	if [[ ! -s "$tmp_path" ]]; then
		write_error "Downloaded updater is empty: $src_url"
		rm -f -- "$tmp_path"
		return 1
	fi

	if ! bash -n "$tmp_path"; then
		write_error "Downloaded updater failed syntax validation. Keeping current script unchanged."
		rm -f -- "$tmp_path"
		return 1
	fi

	chmod --reference="$script_path" "$tmp_path" 2>/dev/null || chmod +x "$tmp_path"
	chown --reference="$script_path" "$tmp_path" 2>/dev/null || true

	if ! cp -p -- "$script_path" "$backup_path"; then
		write_error "Unable to create backup before update: $backup_path"
		rm -f -- "$tmp_path"
		return 1
	fi

	if ! mv -f -- "$tmp_path" "$script_path"; then
		write_error "Failed to install updated script. Restoring backup."
		cp -p -- "$backup_path" "$script_path" || write_error "Rollback failed: restore ${backup_path} manually."
		rm -f -- "$tmp_path"
		return 1
	fi

	write_status "Updater installed successfully. Backup saved to: $backup_path"
}



config_me ()
{
	if declare -F write_warning >/dev/null 2>&1; then
		write_warning "::There is nothing to configure at this time!::"
	else
		script::config_notice
	fi
}



setup_me ()
{
	local setup_flatpak=0
	local setup_snap=0
	local target
	local normalized_target

	if [[ $# -eq 0 ]]; then
		setup_flatpak=1
		setup_snap=1
	fi

	for target in "$@"; do
		target="${target,,}"
		target="${target//,/ }"

		for normalized_target in $target; do
			case "$normalized_target" in
			flatpak | --flatpak)
				setup_flatpak=1
				;;
			snap | snapd | --snap | --snapd)
				setup_snap=1
				;;
			all | both | --all | --both)
				setup_flatpak=1
				setup_snap=1
				;;
			*)
				write_error "Unknown setup target: ${normalized_target}"
				write_information "Valid setup targets are: flatpak, snap, or both."
				return 1
				;;
			esac
		done
	done

	if (( setup_flatpak )); then
		write_status "Ensuring Flatpak support is available..."
		software::ensure_flatpak_package_managment || return 1
	fi

	if (( setup_snap )); then
		write_status "Ensuring Snap support is available..."
		software::ensure_snap_package_managment || return 1
	fi
}


main "$@"
