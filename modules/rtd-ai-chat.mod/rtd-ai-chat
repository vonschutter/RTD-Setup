#!/bin/bash
#
#::                                       A D M I N   T O O L
#::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::
#:::::::::::::::::::::::::::::::::::::::// RTD AI Chat Launcher //::::::::::::::::::::::::::::::::::::// Linux //::::::::
#:: Author(s):    RTD
#:: Version:      1.00
#::
#:: Purpose:      Load the RTD library, ensure the required CLI dependencies are
#::               present, and launch the bundled OpenAI chat client.
#::
#:: Value:        Provides a simple RTD entry point for interactive AI use from
#::               the shell without requiring the user to manually locate or run
#::               the underlying helper script.
#::
#:: Usage:        Run with no arguments for interactive mode, or pass the same
#::               arguments supported by the bundled chat client.
#::
#:: Examples:
#::               rtd-ai-chat
#::               rtd-ai-chat --prompt "Summarize nftables logging"
#::
#::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::

rtd::bootstrap_library() {
	local library_name="${1:-_rtd_library}"
	local minimum_version="${2:-}"
	local loaded_version="${RTD_VERSION:-${RTDFUNCTIONS:-}}"
	local script_dir path src_url tmp

	if [[ "$library_name" == "_rtd_library" && -n "$loaded_version" ]]; then
		if { [[ -z "$minimum_version" ]] || [[ "$(printf '%s\n%s\n' "$minimum_version" "$loaded_version" | sort -V | tail -n 1)" == "$loaded_version" ]]; } &&
			declare -F system::log_item >/dev/null 2>&1 &&
			declare -F library::apply_rtd_defaults >/dev/null 2>&1; then
			return 0
		fi
	fi

	script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
	for path in \
		"${script_dir}/${library_name}" \
		"${script_dir}/../core/${library_name}" \
		"${script_dir}/../../core/${library_name}" \
		"/opt/${_TLA:-${_tla:-rtd}}/core/${library_name}" \
		"/opt/rtd/core/${library_name}" \
		"${HOME:-}/GIT/RTD-Setup/core/${library_name}" \
		"${HOME:-}/RTD-Setup/core/${library_name}"; do
		if [[ -r "$path" ]]; then
			# shellcheck source=/dev/null
			source "$path" ""
			return $?
		fi
	done

	src_url="https://github.com/${_GIT_PROFILE:-${GIT_Profile:-vonschutter}}/RTD-Setup/raw/main/core/${library_name}"
	tmp="$(mktemp "/tmp/${library_name}.XXXXXX" 2>/dev/null || echo "/tmp/${library_name}.$$")"
	if command -v curl >/dev/null 2>&1; then
		curl -fsSL "$src_url" -o "$tmp" || return 1
	elif command -v wget >/dev/null 2>&1; then
		wget -qO "$tmp" "$src_url" || return 1
	else
		return 1
	fi

	# shellcheck source=/dev/null
	source "$tmp" ""
	local rc=$?
	rm -f "$tmp"
	return $rc
}

if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
	cat <<EOF
Usage:
  $(basename "$0") [--help|-h] [chat-client-args...]

Description:
  Launch the bundled RTD AI chat helper after ensuring its CLI dependencies exist.
EOF
	exit 0
fi

rtd::bootstrap_library "_rtd_library" || {
	echo "Failed to load _rtd_library"
	exit 1
}

hash jq || software::check_native_package_dependency jq
hash curl || software::check_native_package_dependency curl



bash $(find /opt -name chatgpt.sh) "$@"
