RTD_AI_CHAT_CONFIG="${HOME:-}/.config/rtd/rtd-ai-chat.config"
RTD_AI_CHAT_DEFAULT_MODEL="gemma4:e2b"
RTD_AI_CHAT_MODEL=""
RTD_AI_CHAT_MODEL_SELECTED=0
RTD_AI_CHAT_PROMPT=""
RTD_AI_CHAT_PROMPT_SEEN=0
RTD_AI_CHAT_PROMPT_FROM_FILE=""
RTD_AI_CHAT_PROMPT_FROM_FILE_SEEN=0
RTD_AI_CHAT_STDIN_PROMPT=""
RTD_AI_CHAT_STDIN_PROMPT_SEEN=0
RTD_AI_CHAT_REMOTE_REASON=""
RTD_AI_CHAT_SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
declare -a RTD_AI_CHAT_FORWARD_ARGS=()



#::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::
#::::::::::::::                                          ::::::::::::::::::::::
