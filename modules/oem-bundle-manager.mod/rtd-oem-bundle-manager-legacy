system::open_url_in_browser ()
{
	local url="${1:-}" target_user="${2:-}" uid browser
	local -a run_as browser_candidates

	[[ -n "${url}" ]] || return 1

	browser_candidates=(
		"${BROWSER:-}"
		sensible-browser
		x-www-browser
		firefox
		firefox-esr
		brave-browser
		google-chrome-stable
		google-chrome
		chromium
		chromium-browser
		microsoft-edge
		opera
		vivaldi
	)

	if [[ -n "${target_user}" ]]; then
		uid="$(id -u "${target_user}" 2>/dev/null)" || return 1
		run_as=(
			sudo -H -u "${target_user}" env
			"DISPLAY=${DISPLAY:-}"
			"WAYLAND_DISPLAY=${WAYLAND_DISPLAY:-}"
			"XDG_RUNTIME_DIR=/run/user/${uid}"
			"DBUS_SESSION_BUS_ADDRESS=${DBUS_SESSION_BUS_ADDRESS:-unix:path=/run/user/${uid}/bus}"
		)
	else
		run_as=(env)
	fi

	for browser in "${browser_candidates[@]}"; do
		[[ -n "${browser}" ]] || continue
		command -v "${browser}" >/dev/null 2>&1 || continue
		"${run_as[@]}" "${browser}" "${url}" >/dev/null 2>&1 &
		return 0
	done

	if command -v gio >/dev/null 2>&1; then
		"${run_as[@]}" gio open "${url}" >/dev/null 2>&1 &
		return 0
	fi

	if command -v xdg-open >/dev/null 2>&1; then
		"${run_as[@]}" xdg-open "${url}" >/dev/null 2>&1 &
		return 0
	fi

	return 1
}



