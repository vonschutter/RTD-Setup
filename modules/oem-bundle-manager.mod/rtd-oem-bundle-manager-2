bm2::log() {
	if declare -F system::log_item >/dev/null 2>&1; then
		system::log_item "$*"
	else
		printf '%s\n' "$*" >>"${_LOGFILE}"
	fi
}

bm2::trim() {
	local value="${1:-}"
	value="${value#"${value%%[![:space:]]*}"}"
	value="${value%"${value##*[![:space:]]}"}"
	printf '%s' "$value"
}

bm2::ensure_yad() {
	if ! command -v yad >/dev/null 2>&1; then
		software::check_native_package_dependency yad >/dev/null 2>&1 || {
			echo "YAD is required for ${_SCRIPTNAME}." >&2
			return 1
		}
	fi
}

bm2::ensure_admin() {
	if [[ ${UID} -ne 0 ]]; then
		security::ensure_admin
	fi
	if [[ ${UID} -eq 0 ]]; then
		system::preserve_graphical_session_environment >/dev/null 2>&1 || true
	fi
}

bm2::completed_file() {
	mkdir -p "${completed_bundles_list%/*}"
	touch "${completed_bundles_list}"
	printf '%s' "${completed_bundles_list}"
}

bm2::category_for_bundle() {
	local bundle="${1:-}" category
	if [[ "$bundle" == *":_"* ]]; then
		category="${bundle%%:_*}"
	else
		category="${bundle%%_*}"
	fi
	category="${category//_/ }"
	printf '%s' "${category:-Other}"
}

bm2::display_name_for_bundle() {
	local bundle="${1:-}" display
	if [[ "$bundle" == *":_"* ]]; then
		display="${bundle#*:_}"
	else
		display="${bundle#*_}"
	fi
	display="${display//_/ }"
	printf '%s' "${display:-$bundle}"
}

bm2::source_summary_for_bundle() {
	local bundle="${1:-}" func source="Mixed"
	func="$(declare -f "${bundle_prefix:-recipe:_}${bundle}" 2>/dev/null || true)"
	[[ -n "$func" ]] || { printf '%s' "Unknown"; return 0; }

	local has_flatpak=0 has_snap=0 has_native=0 has_vendor=0
	grep -q 'software::from_flathub' <<<"$func" && has_flatpak=1
	grep -q 'software::from_snapcraft' <<<"$func" && has_snap=1
	grep -q 'software::add_native_package\|software::check_native_package_dependency' <<<"$func" && has_native=1
	grep -q 'vendor_download_and_install\|curl .*\.\(deb\|rpm\)\|wget .*\.\(deb\|rpm\)' <<<"$func" && has_vendor=1

	source=""
	((has_flatpak)) && source+="${source:+, }Flatpak"
	((has_snap)) && source+="${source:+, }Snap"
	((has_native)) && source+="${source:+, }Native"
	((has_vendor)) && source+="${source:+, }Vendor"
	printf '%s' "${source:-Mixed}"
}

bm2::count_zformat_records() {
	local mode="${1:?}" count=0 selected bundle description
	while IFS= read -r selected && IFS= read -r bundle && IFS= read -r description; do
		[[ -n "$(bm2::trim "$bundle")" ]] || continue
		((count++))
	done < <(software::list_bundles "$mode")
	printf '%s' "$count"
}

bm2::build_list_args() {
	local mode="${1:?}" status="${2:?}"
	local line selected bundle description clean_bundle display_bundle clean_description category source default_label
	local -a record=()
	while IFS= read -r line; do
		line="$(bm2::trim "$line")"
		[[ -n "$line" ]] || continue
		record+=("$line")
		((${#record[@]} == 3)) || continue

		selected="${record[0]}"
		bundle="${record[1]}"
		description="${record[2]}"
		record=()

		case "$(bm2::trim "$selected")" in
			true|TRUE|false|FALSE) ;;
			*) continue ;;
		esac

		clean_bundle="$(bm2::trim "$bundle")"
		[[ -n "$clean_bundle" ]] || continue
		display_bundle="$(bm2::display_name_for_bundle "$clean_bundle")"
		clean_description="$(bm2::trim "$description")"
		clean_description="${clean_description#: }"
		category="$(bm2::category_for_bundle "$clean_bundle")"
		source="$(bm2::source_summary_for_bundle "$clean_bundle")"
		case "$(bm2::trim "$selected")" in
			true|TRUE) default_label="Recommended" ;;
			*) default_label="" ;;
		esac
		printf '%s\n%s\n%s\n%s\n%s\n%s\n%s\n%s\n' \
			"$(bm2::trim "$selected")" "$category" "$display_bundle" "$clean_description" "$status" "$source" "$default_label" "$clean_bundle"
	done < <(software::list_bundles "$mode")
}

bm2::build_installed_list_args() {
	local line selected bundle description clean_bundle display_bundle clean_description category source
	local -a record=()
	while IFS= read -r line; do
		line="$(bm2::trim "$line")"
		[[ -n "$line" ]] || continue
		record+=("$line")
		((${#record[@]} == 3)) || continue

		selected="${record[0]}"
		bundle="${record[1]}"
		description="${record[2]}"
		record=()

		case "$(bm2::trim "$selected")" in
			true|TRUE|false|FALSE) ;;
			*) continue ;;
		esac

		clean_bundle="$(bm2::trim "$bundle")"
		[[ -n "$clean_bundle" ]] || continue
		display_bundle="$(bm2::display_name_for_bundle "$clean_bundle")"
		clean_description="$(bm2::trim "$description")"
		clean_description="${clean_description#: }"
		category="$(bm2::category_for_bundle "$clean_bundle")"
		source="$(bm2::source_summary_for_bundle "$clean_bundle")"
		printf '%s\n%s\n%s\n%s\n' \
			"$category" "$display_bundle" "$clean_description" "$source"
	done < <(software::list_bundles --zformat-removable)
}

bm2::show_about() {
	yad --info \
		--title="About ${_TITLE_MAIN}" \
		--width=620 --height=300 \
		--image="${_ui_side_bar}" \
		--text="<b>RTD Bundle Manager 2</b>\n\nThis is an experimental YAD-first interface for RTD software bundles.\n\nIt keeps the existing _rtd_library zformat output untouched and builds richer dashboard, list, and progress views locally."
}

bm2::dashboard() {
	local available_count installed_count default_count distro summary
	available_count="$(bm2::count_zformat_records --zformat-installable)"
	installed_count="$(bm2::count_zformat_records --zformat-removable)"
	default_count="$(software::list_bundles --zformat-installable | awk 'tolower($0)=="true" {c++} END{print c+0}')"
	distro="$(system::os_pretty_name 2>/dev/null || system::distribution_type 2>/dev/null || echo "Linux")"

	summary="<b>RTD Bundle Manager 2</b>\n\n"
	summary+="Install or remove curated application bundles by task.\n\n"
	summary+="<b>System:</b> ${distro}\n"
	summary+="<b>Available bundles:</b> ${available_count}\n"
	summary+="<b>Recommended bundles:</b> ${default_count}\n"
	summary+="<b>Installed bundles:</b> ${installed_count}\n\n"
	summary+="Phase 1 UI: dashboard, category/status columns, searchable bundle lists, and log-enabled progress."

	yad --form \
		--title="${_TITLE_MAIN}" \
		--image="${_ui_side_bar}" \
		--width=720 --height=420 \
		--text="${summary}" \
		--button="Install Bundles:10" \
		--button="Remove Bundles:20" \
		--button="Installed Bundles:30" \
		--button="About:40" \
		--button="Quit:1" \
		--buttons-layout=center
}

bm2::select_bundles() {
	local mode="${1:?}" title="${2:?}" text="${3:?}" status="${4:?}" selection exit_status
	local -a list_args
	mapfile -t list_args < <(bm2::build_list_args "$mode" "$status")

	if ((${#list_args[@]} == 0)); then
		yad --info --title="${title}" --width=520 --height=160 --text="No bundles are available for this action."
		return 1
	fi

	selection=$(yad --list --checklist \
		--title="${title}" \
		--text="${text}" \
		--width=1500 --height=760 \
		--search-column=3 \
		--expand-column=4 \
		--grid-lines=both \
		--wrap-cols=4 \
		--wrap-width=760 \
		--ellipsize=none \
		--tooltip-column=4 \
		--print-column=8 \
		--hide-column=8 \
		--separator=" " \
		--column="Select" \
		--column="Category" \
		--column="Bundle" \
		--column="Description" \
		--column="Status" \
		--column="Sources" \
		--column="Default" \
		--column="Bundle ID" \
		"${list_args[@]}" 2>/dev/null)
	exit_status=$?
	[[ $exit_status -eq 0 ]] || return 1
	[[ -n "${selection// /}" ]] || return 1
	printf '%s' "$selection"
}

bm2::show_installed() {
	local -a list_args
	mapfile -t list_args < <(bm2::build_installed_list_args)
	if ((${#list_args[@]} == 0)); then
		yad --info --title="Installed Bundles" --width=520 --height=160 --text="No installed bundles are recorded yet."
		return 0
	fi

	yad --list \
		--title="Installed Bundles" \
		--text="Bundles recorded in $(bm2::completed_file)" \
		--width=1400 --height=720 \
		--search-column=2 \
		--expand-column=3 \
		--grid-lines=both \
		--wrap-cols=3 \
		--wrap-width=720 \
		--ellipsize=none \
		--tooltip-column=3 \
		--column="Category" \
		--column="Bundle" \
		--column="Description" \
		--column="Sources" \
		"${list_args[@]}" >/dev/null 2>&1
}

bm2::progress_dialog() {
	local title="${1:?}" text="${2:?}"
	yad --progress \
		--title="${title}" \
		--text="${text}" \
		--percentage=0 \
		--width=920 --height=620 \
		--enable-log="Details" \
		--log-expanded \
		--log-height=360 \
		--auto-close \
		--no-cancel
}

bm2::install_bundles() {
	local selection completed_file snapshot_file total count current_bundle current_bundle_full_name result_file
	selection="$(bm2::select_bundles --zformat-installable "Install Bundles" "Select software bundles to install. Search by typing while the bundle list is focused." "Available")" || return 0

	completed_file="$(bm2::completed_file)"
	snapshot_file="$(mktemp 2>/dev/null || echo "${completed_file}.snapshot")"
	result_file="$(mktemp 2>/dev/null || echo "/tmp/rtd-bundle-manager-2-install.$$")"
	cp "${completed_file}" "${snapshot_file}" 2>/dev/null || : >"${snapshot_file}"

	# shellcheck disable=SC2206
	local -a selection_list=(${selection})
	total=${#selection_list[@]}
	count=0

	(
		for current_bundle in "${selection_list[@]}"; do
			[[ -n "${current_bundle}" ]] || continue
			((count++))
			current_bundle_full_name="${bundle_prefix:-recipe:_}${current_bundle}"
			echo "# Installing bundle ${count} of ${total}: ${current_bundle}"
			echo "Installing ${current_bundle}"
			bm2::log "Bundle Manager 2 installing ${current_bundle}"
			if "${current_bundle_full_name}" >>"${_LOGFILE}" 2>&1; then
				grep -Fxq "${current_bundle}" "${completed_file}" || printf '%s\n' "${current_bundle}" >>"${completed_file}"
				printf 'Installed\t%s\n' "${current_bundle}" >>"${result_file}"
				echo "Installed ${current_bundle}"
			else
				printf 'Failed\t%s\n' "${current_bundle}" >>"${result_file}"
				echo "Failed ${current_bundle}; see ${_LOGFILE}"
			fi
			echo $((100 * count / total))
		done
	) | bm2::progress_dialog "Installing Software Bundles" "Please wait while selected bundles are installed."

	bm2::summary "Install Summary" "${result_file}"
	rm -f "${snapshot_file}" "${result_file}"
}

bm2::remove_bundles() {
	local selection completed_file total count current_bundle current_bundle_full_name result_file
	selection="$(bm2::select_bundles --zformat-removable "Remove Bundles" "Select installed bundles to remove. Removal runs the same recipe with --remove." "Installed")" || return 0

	completed_file="$(bm2::completed_file)"
	result_file="$(mktemp 2>/dev/null || echo "/tmp/rtd-bundle-manager-2-remove.$$")"

	# shellcheck disable=SC2206
	local -a selection_list=(${selection})
	total=${#selection_list[@]}
	count=0

	(
		for current_bundle in "${selection_list[@]}"; do
			[[ -n "${current_bundle}" ]] || continue
			((count++))
			current_bundle_full_name="${bundle_prefix:-recipe:_}${current_bundle}"
			echo "# Removing bundle ${count} of ${total}: ${current_bundle}"
			echo "Removing ${current_bundle}"
			bm2::log "Bundle Manager 2 removing ${current_bundle}"
			if "${current_bundle_full_name}" --remove >>"${_LOGFILE}" 2>&1; then
				awk -v bundle="${current_bundle}" '$0 != bundle' "${completed_file}" >"${completed_file}.tmp" && mv "${completed_file}.tmp" "${completed_file}"
				printf 'Removed\t%s\n' "${current_bundle}" >>"${result_file}"
				echo "Removed ${current_bundle}"
			else
				printf 'Failed\t%s\n' "${current_bundle}" >>"${result_file}"
				echo "Failed ${current_bundle}; see ${_LOGFILE}"
			fi
			echo $((100 * count / total))
		done
	) | bm2::progress_dialog "Removing Software Bundles" "Please wait while selected bundles are removed."

	bm2::summary "Removal Summary" "${result_file}"
	rm -f "${result_file}"
}

bm2::summary() {
	local title="${1:?}" result_file="${2:?}"
	local -a rows
	if [[ ! -s "${result_file}" ]]; then
		yad --info --title="${title}" --width=520 --height=160 --text="No bundle results were recorded."
		return 0
	fi
	while IFS=$'\t' read -r status bundle; do
		rows+=("$status" "$bundle")
	done <"${result_file}"
	yad --list \
		--title="${title}" \
		--text="Completed action details. Full log: ${_LOGFILE}" \
		--width=760 --height=420 \
		--grid-lines=both \
		--column="Result" \
		--column="Bundle" \
		"${rows[@]}" >/dev/null 2>&1
}

bm2::help() {
	cat <<EOF
Usage:
  ${_SCRIPTNAME} [--install-menu|--remove-menu|--installed|--about|--help]

Description:
  Experimental YAD-first RTD bundle manager. It uses the current
  software::list_bundles --zformat-* output and does not change the library
  zformat contract used by the original bundle manager.
EOF
}


