bm2::main() {
	local action
	case "${1:-}" in
		--help|-h)
			bm2::help
			return
			;;
	esac

	rtd::bootstrap_library "_rtd_library" || {
		echo "Failed to load _rtd_library" >&2
		exit 1
	}
	bm2::ensure_yad || exit 1
	bm2::ensure_admin

	case "${1:-}" in
		--install-menu) bm2::install_bundles; return ;;
		--remove-menu) bm2::remove_bundles; return ;;
		--installed) bm2::show_installed; return ;;
		--about) bm2::show_about; return ;;
	esac

	while true; do
		bm2::dashboard
		action=$?
		case "$action" in
			10) bm2::install_bundles ;;
			20) bm2::remove_bundles ;;
			30) bm2::show_installed ;;
			40) bm2::show_about ;;
			1|252) break ;;
			*) break ;;
		esac
	done
}

bm2::main "$@"
