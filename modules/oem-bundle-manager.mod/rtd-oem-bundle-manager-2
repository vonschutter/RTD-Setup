: "${_SCRIPTNAME:=$(basename "$0")}"
: "${_TLA:=${_SCRIPTNAME:0:3}}"  ;  _TLA="${_TLA,,}"
: "${_GIT_PROFILE:=vonschutter}"
: "${_TITLE_MAIN:=RunTime Data - Software Bundle Manager}"
: "${_SCRIPT_PATH:=$(readlink -f "${BASH_SOURCE[0]}" 2>/dev/null || realpath "${BASH_SOURCE[0]}" 2>/dev/null || printf '%s' "${BASH_SOURCE[0]}")}"
: "${_SCRIPT_DIR:=$(cd "$(dirname "${_SCRIPT_PATH}")" && pwd)}"
: "${_CONFIG_DIR:=/etc/${_TLA:-"rtd"}}"
: "${completed_bundles_list:=${_CONFIG_DIR}/completed-bundles.info}"

# Decide where to put log files.
# Default: log in to the $_LOG_DIR location dated accordingly. If this is already set
# we use the requested location. These settings are calculated below but you may
# chose to over ride them by uncommenting the variables below:
#
# export _LOG_DIR=
# export _ERRLOGFILE=
# export _LOGFILE=
# export _TLA=

if [[ ${EUID} -eq 0 ]]; then
	: "${_LOG_DIR:=/var/log/${_TLA}}"
else
	: "${_LOG_DIR:=${HOME}/.config/${_TLA}/log}"
fi

if mkdir -p "${_LOG_DIR}" ; then
	: "${_LOGFILE:=${_LOG_DIR}/${_SCRIPTNAME}-$(date +%Y-%m-%d).log}"
	touch "${_LOGFILE}"
	chmod 644 "${_LOGFILE}" 2>/dev/null || true
else
	echo "Failed to create log directory at ${_LOG_DIR}. Check permissions or set _LOG_DIR to a writable location." >&2
fi

# Set UI image paths with fallbacks to ensure the script can run even if the expected images are missing.
# The images are not critical for functionality, so we check if they are readable and if not, we simply won't use them in the UI.
_ui_side_bar="${_SCRIPT_DIR}/image/sideimage.png"
_local_side_bar="/usr/share/icons/media-removable.svg"
[[ -r "${_ui_side_bar}" ]] || _ui_side_bar="${_local_side_bar}"
_ui_icon="${_SCRIPT_DIR}/image/software.ico"
_local_icon="/usr/share/icons/media-removable.svg"
[[ -r "${_ui_icon}" ]] || _ui_icon="${_local_icon}"




