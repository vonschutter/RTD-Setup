_LOG_DIR="${HOME}/.config/rtd/log"
_LOGFILE="${_LOG_DIR}/$(basename $0).log"
_HEIGHT="480" 
_WIDTH="830"

mkdir -p "${_LOG_DIR}"
touch "${_LOGFILE}"

#::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::
