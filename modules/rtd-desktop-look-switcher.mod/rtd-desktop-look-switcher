#:::::::::::::::::::::::::::::::// RTD Desktop Look Switcher Compatibility Launcher //::::::::::::::::// Linux //::::::
#:: Author(s):    RTD
#:: Version:      2.00
#::
#:: Purpose:      Open the integrated RTD GNOME Theme Manager desktop profiles.
#::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::

set -euo pipefail

SCRIPT_PATH="$(readlink -f "${BASH_SOURCE[0]}")"
SCRIPT_DIR="$(cd "$(dirname "$SCRIPT_PATH")" && pwd)"

find_theme_manager() {
	local candidate
	for candidate in \
		"${SCRIPT_DIR}/../theme-manager/rtd-theme-manager" \
		"/opt/rtd/scripts/rtd-theme-manager"; do
		[[ -x "$candidate" ]] && { printf '%s\n' "$candidate"; return 0; }
	done
	command -v rtd-theme-manager 2>/dev/null
}

show_help() {
	cat <<EOF
Usage:
  $(basename "$0") [--help|-h]

Description:
  RTD desktop profiles are now integrated into rtd-theme-manager.
  This compatibility launcher opens the RTD GNOME Theme Manager.
EOF
}

case "${1:-}" in
	--help|-h)
		show_help
		;;
	"")
		manager="$(find_theme_manager)" || {
			echo "Error: Could not find rtd-theme-manager." >&2
			exit 1
		}
		exec "$manager"
		;;
	*)
		echo "Error: Unknown option: $1" >&2
		exit 1
		;;
esac
