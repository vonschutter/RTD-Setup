trace() {
	system::log_item "rtd-ventoy-usb: $*"
}

require_value() {
	local option="$1"
	local value="${2:-}"

	if [[ -z "$value" ]]; then
		write_error "Option $option requires a value."
		return 1
	fi
	return 0
}

set_default_dest() {
	if [[ -n "$APP_DEST" ]]; then
		return 0
	fi

	if [[ ${EUID:-1} -eq 0 ]]; then
		APP_DEST="/var/lib/rtd/ventoy"
	else
		APP_DEST="${HOME:-${TMPDIR:-/tmp}}/.cache/${_TLA:-rtd}/ventoy"
	fi
}

require_dialog() {
	HAVE_DIALOG=0
	if [[ "${RTD_VENTOY_CONFIRMED:-0}" == "1" ]]; then
		trace "dialog available=0 (confirmation already handled by caller)"
		return 0
	fi
	if hash dialog 2>/dev/null && [[ -r /dev/tty ]] && [[ -n "${TERM:-}" && "${TERM:-}" != "dumb" ]]; then
		HAVE_DIALOG=1
	fi
	trace "dialog available=${HAVE_DIALOG}"
}

ui_notice() {
	local msg="$1"

	if [[ $HAVE_DIALOG -eq 1 ]]; then
		dialog --backtitle "${BRANDING:-RTD Power Tools}" --title "Ventoy USB Creator" --msgbox "$msg" 18 78
	else
		printf '%b\n\n' "$msg"
	fi
}

ui_confirm() {
	local msg="$1"
	local resp

	if [[ $HAVE_DIALOG -eq 1 ]]; then
		dialog --backtitle "${BRANDING:-RTD Power Tools}" --title "Confirm Ventoy USB Setup" --yesno "$msg" 22 78
		return $?
	fi

	printf '%b [y/N]: ' "$msg"
	read -r resp < /dev/tty
	[[ "$resp" =~ ^[Yy]$ ]]
}

normalize_device() {
	local device="$1"
	local parent

	[[ -b "$device" ]] || return 1
	parent="$(lsblk -dn -o PKNAME "$device" 2>/dev/null | head -n 1)"
	if [[ -n "$parent" ]]; then
		printf '/dev/%s' "$parent"
	else
		printf '%s' "$device"
	fi
}

device_summary() {
	local device="$1"
	local line size vendor model tran rm hotplug description

	[[ -n "$device" && -b "$device" ]] || return 1

	line="$(lsblk -P -d -o SIZE,VENDOR,MODEL,TRAN,RM,HOTPLUG "$device" 2>/dev/null | head -n 1)"
	[[ -n "$line" ]] || return 1

	size=""
	vendor=""
	model=""
	tran=""
	rm=""
	hotplug=""
	[[ "$line" =~ SIZE=\"([^\"]*)\" ]] && size="${BASH_REMATCH[1]}"
	[[ "$line" =~ VENDOR=\"([^\"]*)\" ]] && vendor="${BASH_REMATCH[1]}"
	[[ "$line" =~ MODEL=\"([^\"]*)\" ]] && model="${BASH_REMATCH[1]}"
	[[ "$line" =~ TRAN=\"([^\"]*)\" ]] && tran="${BASH_REMATCH[1]}"
	[[ "$line" =~ RM=\"([^\"]*)\" ]] && rm="${BASH_REMATCH[1]}"
	[[ "$line" =~ HOTPLUG=\"([^\"]*)\" ]] && hotplug="${BASH_REMATCH[1]}"

	description="${vendor:+$vendor }${model}"
	description="${description#"${description%%[![:space:]]*}"}"
	description="${description%"${description##*[![:space:]]}"}"
	[[ -n "$description" ]] || description="Unknown device"

	printf '%s\n' \
		"Target device: $device" \
		"Device info:   $description" \
		"Capacity:      ${size:-unknown}" \
		"Transport:     ${tran:-unknown} (rm=${rm:-?}, hotplug=${hotplug:-?})"
}

init_logging() {
	_LOGFILE="$(system::determine_logfile)" || return 1
	export _LOGFILE
	write_information "Logging to: ${_LOGFILE}"
	trace "script version=${SCRIPT_VERSION}"
	trace "cwd=$(pwd)"
	trace "user=${USER:-unknown} euid=${EUID:-unknown}"
}

parse_args() {
	while [[ $# -gt 0 ]]; do
		case "$1" in
		-h|--help)
			APP_SHOW_HELP=1
			shift
			;;
		-V|--script-version)
			APP_SHOW_VERSION=1
			shift
			;;
		--device)
			require_value "$1" "${2:-}" || return 1
			APP_DEVICE="$2"
			shift 2
			;;
		--version)
			require_value "$1" "${2:-}" || return 1
			APP_VERSION="$2"
			shift 2
			;;
		--dest)
			require_value "$1" "${2:-}" || return 1
			APP_DEST="$2"
			shift 2
			;;
		--update)
			APP_ACTION="update"
			shift
			;;
		--recreate)
			APP_ACTION="recreate"
			shift
			;;
		--sync-isos|--add-iso|--add-isos)
			APP_ACTION="sync-isos"
			shift
			;;
		--mbr)
			APP_PARTITION_STYLE="mbr"
			shift
			;;
		--gpt)
			APP_PARTITION_STYLE="gpt"
			shift
			;;
		--reserve-mib)
			require_value "$1" "${2:-}" || return 1
			[[ "$2" =~ ^[0-9]+$ ]] || {
				write_error "Option $1 requires a non-negative integer."
				return 1
			}
			APP_RESERVE_MIB="$2"
			shift 2
			;;
		--source)
			require_value "$1" "${2:-}" || return 1
			APP_SOURCES+=("$2")
			shift 2
			;;
		--overwrite)
			APP_OVERWRITE=1
			shift
			;;
		--gui)
			APP_GUI_MODE="force"
			shift
			;;
		--no-gui)
			APP_GUI_MODE="never"
			shift
			;;
		*)
			write_error "Unknown option: $1"
			return 1
			;;
		esac
	done

	set_default_dest
	trace "args action=${APP_ACTION:-prompt} device=${APP_DEVICE:-auto} version=${APP_VERSION} dest=${APP_DEST} style=${APP_PARTITION_STYLE} reserve_mib=${APP_RESERVE_MIB} overwrite=${APP_OVERWRITE} sources=${#APP_SOURCES[@]} gui=${APP_GUI_MODE}"
	return 0
}

graphical_ventoy_frontend() {
	local script_dir frontend
	script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
	for frontend in \
		"${script_dir}/ventoy-usb-gtk.py" \
		"/opt/rtd/modules/oem-ventoy.mod/ventoy-usb-gtk.py" \
		"/opt/RTD-Setup/modules/oem-ventoy.mod/ventoy-usb-gtk.py" \
		"${HOME:-}/GIT/RTD-Setup/modules/oem-ventoy.mod/ventoy-usb-gtk.py" \
		"${HOME:-}/RTD-Setup/modules/oem-ventoy.mod/ventoy-usb-gtk.py"; do
		[[ -r "$frontend" ]] && { printf '%s' "$frontend"; return 0; }
	done
	return 1
}

gtk_frontend_ready() {
	command -v python3 >/dev/null 2>&1 &&
		python3 -c 'import gi; gi.require_version("Gtk", "3.0"); gi.require_version("Gdk", "3.0"); from gi.repository import Gdk, GLib, Gtk, Pango' >/dev/null 2>&1
}

install_python_gtk_dependencies() {
	local distro

	distro="$(system::distribution_type 2>/dev/null || true)"
	case "$distro" in
		ubuntu|debian)
			software::check_native_package_dependency python3 python3-gi gir1.2-gtk-3.0
			;;
		fedora|redhat)
			software::check_native_package_dependency python3 python3-gobject gtk3
			;;
		suse)
			software::check_native_package_dependency python3 python3-gobject-Gdk typelib-1_0-Gtk-3_0
			;;
		*)
			write_warning "Automatic Python GTK setup is not available for distribution family: ${distro:-unknown}."
			return 1
			;;
	esac
}

should_launch_gui() {
	local frontend

	[[ "$APP_GUI_MODE" != "never" ]] || return 1
	frontend="$(graphical_ventoy_frontend 2>/dev/null || true)"
	if [[ -z "$frontend" ]]; then
		trace "GTK frontend not found for auto GUI routing."
		[[ "$APP_GUI_MODE" == "force" ]] && write_error "GTK frontend not found: ventoy-usb-gtk.py"
		return 1
	fi

	[[ -n "${DISPLAY:-}" || -n "${WAYLAND_DISPLAY:-}" ]] || {
		trace "No DISPLAY/WAYLAND_DISPLAY available for auto GUI routing."
		[[ "$APP_GUI_MODE" == "force" ]] && write_error "No graphical display session was detected."
		return 1
	}

	if dependency::desktop gnome || dependency::desktop kde; then
		[[ "$APP_GUI_MODE" == "force" || $INITIAL_ARG_COUNT -eq 0 ]]
		return $?
	fi

	trace "Desktop is not GNOME/KDE for auto GUI routing."
	[[ "$APP_GUI_MODE" == "force" ]] && write_error "Graphical frontend is only auto-routed for GNOME or KDE sessions."
	return 1
}

launch_gui() {
	local frontend
	frontend="$(graphical_ventoy_frontend)" || return 1
	if ! gtk_frontend_ready; then
		write_information "Installing Python GTK components required by the RTD Ventoy USB GUI."
		install_python_gtk_dependencies || return 1
		hash -r
	fi
	gtk_frontend_ready || {
		write_error "RTD Ventoy USB GUI requires python3, python3-gi, and GTK 3 bindings."
		return 1
	}
	exec python3 "$frontend" "$@"
}

ui_select_action() {
	local selection
	local -a choices
	local checked=0
	local item
	local resp

	[[ -n "$APP_ACTION" ]] && return 0

	if [[ $HAVE_DIALOG -eq 1 ]]; then
		exec 3>&1
		selection=$(dialog --backtitle "${BRANDING:-RTD Power Tools}" \
			--title "Ventoy Action" \
			--checklist "Select exactly one action:" 18 86 4 \
			"update" "Update Ventoy and refresh /ventoy files. Leave ISO files alone." off \
			"recreate" "Wipe the USB and recreate Ventoy, folders, and ISO copy layout." on \
			"sync-isos" "Add or refresh ISO files on an existing Ventoy USB. No wipe." off \
			2>&1 1>&3)
		resp=$?
		exec 3>&-
		[[ $resp -eq 0 ]] || return 1

		for item in $selection; do
			item="${item%\"}"
			item="${item#\"}"
			case "$item" in
			update|recreate|sync-isos)
				APP_ACTION="$item"
				((checked++))
				;;
			esac
		done

		if [[ $checked -ne 1 ]]; then
			write_error "Select exactly one action."
			return 1
		fi
		return 0
	fi

	printf '%s\n' "Choose Ventoy action:" >&2
	printf '%s\n' "  1) update   - refresh Ventoy and /ventoy files only" >&2
	printf '%s\n' "  2) recreate - wipe USB and rebuild Ventoy media" >&2
	printf '%s\n' "  3) sync-isos - add or refresh ISO files only" >&2
	printf '%s' "Selection [1/2/3]: " >&2
	read -r resp < /dev/tty || return 1
	case "$resp" in
	1) APP_ACTION="update" ;;
	2|"") APP_ACTION="recreate" ;;
	3) APP_ACTION="sync-isos" ;;
	*) write_error "Invalid action selection."; return 1 ;;
	esac
	return 0
}

resolve_target_device() {
	if [[ -n "$APP_DEVICE" ]]; then
		[[ -b "$APP_DEVICE" ]] || {
			write_error "Specified device not found: $APP_DEVICE"
			return 1
		}
	TARGET_DEVICE="$(normalize_device "$APP_DEVICE")" || return 1
	write_information "Using requested device: ${TARGET_DEVICE}"
	trace "requested device=${APP_DEVICE} normalized=${TARGET_DEVICE}"
	trace "$(device_summary "$TARGET_DEVICE" | tr '\n' ';')"
	return 0
	fi

	write_status "Selecting target USB device..."
	TARGET_DEVICE="$(oem::ventoy::select_usb_device)" || return 1
	TARGET_DEVICE="$(normalize_device "$TARGET_DEVICE")" || return 1
	write_information "Selected device: ${TARGET_DEVICE}"
	trace "selected device=${TARGET_DEVICE}"
	trace "$(device_summary "$TARGET_DEVICE" | tr '\n' ';')"
	return 0
}

build_setup_args() {
	local src

	SETUP_ARGS=(--device "$TARGET_DEVICE" --version "$APP_VERSION" --dest "$APP_DEST" "--${APP_PARTITION_STYLE}")
	[[ "$APP_ACTION" == "update" ]] && SETUP_ARGS+=(--update)
	[[ "$APP_ACTION" == "recreate" ]] && SETUP_ARGS+=(--recreate)
	[[ "$APP_ACTION" == "sync-isos" ]] && SETUP_ARGS+=(--sync-isos)
	[[ ${APP_RESERVE_MIB} -gt 0 ]] && SETUP_ARGS+=(--reserve-mib "$APP_RESERVE_MIB")
	[[ $APP_OVERWRITE -eq 1 ]] && SETUP_ARGS+=(--overwrite)
	for src in "${APP_SOURCES[@]}"; do
		SETUP_ARGS+=(--source "$src")
	done
	trace "setup args=$(printf '%q ' "${SETUP_ARGS[@]}")"
}

build_confirm_message() {
	local summary
	local overwrite_text="no"
	local reserve_text="none"
	local source_text=$'\n  - Use default ISO discovery paths'
	local style_text
	local action_text
	local download_text
	local src

	[[ $APP_OVERWRITE -eq 1 ]] && overwrite_text="yes"
	[[ ${APP_RESERVE_MIB} -gt 0 ]] && reserve_text="${APP_RESERVE_MIB} MiB"
	style_text="${APP_PARTITION_STYLE^^}"
	if [[ ${#APP_SOURCES[@]} -gt 0 ]]; then
		source_text=""
		for src in "${APP_SOURCES[@]}"; do
			source_text+=$'\n'"  - Scan ISO source: $src"
		done
	fi

	summary="$(device_summary "$TARGET_DEVICE" 2>/dev/null || printf 'Target device: %s' "$TARGET_DEVICE")"
	if [[ "$APP_ACTION" == "update" ]]; then
		download_text="  - Download Ventoy (${APP_VERSION}) to ${APP_DEST}\n"
		action_text="  - Update Ventoy in place on the selected device\n  - Leave existing ISO files and folders alone\n  - Refresh /ventoy files on the Ventoy data partition\n  - Refresh Ventoy legacy BIOS fallback boot files\n  - Do not recopy ISO files"
	elif [[ "$APP_ACTION" == "sync-isos" ]]; then
		download_text=""
		action_text="  - Leave the Ventoy installation and partition layout unchanged\n  - Mount the existing Ventoy data partition\n  - Create or refresh standard RTD folders:\n      /ventoy\n      /Images/OEM\n      /Images/Commercial\n      /Images/OSS\n      /Images/Tools\n      /Data${source_text}\n  - Copy discovered ISO files to the Ventoy drive\n  - Overwrite existing copied ISOs: ${overwrite_text}\n  - Refresh /ventoy configuration files"
	else
		download_text="  - Download Ventoy (${APP_VERSION}) to ${APP_DEST}\n"
		action_text="  - CLEAR the USB device and recreate the Ventoy partition layout\n  - Install Ventoy to the selected device using ${style_text}\n  - Preserve space at disk end: ${reserve_text}\n  - ERASE ALL DATA on the target device\n  - Keep the Ventoy data partition in Ventoy's native filesystem/layout\n  - Create standard RTD folders:\n      /ventoy\n      /Images/OEM\n      /Images/Commercial\n      /Images/OSS\n      /Images/Tools\n      /Data${source_text}\n  - Copy discovered ISO files to the Ventoy drive\n  - Overwrite existing copied ISOs: ${overwrite_text}"
	fi
	printf '%s' "Selected USB device:\n\n${summary}\n\nThis will:\n${download_text}${action_text}\n  - Write /ventoy/ventoy.json with TreeView mode enabled\n  - Set the Ventoy search root to /Images\n\nProceed?"
}

run_setup() {
	local preserve_env

	write_status "Starting Ventoy USB setup..."
	if [[ ${EUID:-1} -ne 0 ]]; then
		hash sudo 2>/dev/null || {
			write_error "sudo is required to install Ventoy to a USB device."
			return 1
		}
		trace "re-executing as root for privileged Ventoy setup"
		preserve_env="DISPLAY,DBUS_SESSION_BUS_ADDRESS,XAUTHORITY,XDG_RUNTIME_DIR,WAYLAND_DISPLAY"
		sudo --preserve-env="${preserve_env}" -H env RTD_VENTOY_CONFIRMED=1 SUDO_USER="${USER:-${SUDO_USER:-unknown}}" bash "$(readlink -f "$0")" "${SETUP_ARGS[@]}"
		return $?
	fi
	oem::ventoy::setup_usb "${SETUP_ARGS[@]}"
}

