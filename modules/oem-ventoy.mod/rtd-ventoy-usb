main() {
	local confirm_message
	local status

	rtd::bootstrap_library "_rtd_library" || {
		echo "Failed to load _rtd_library"
		exit 1
	}
	init_logging || exit 1
	trap 'trace "script exit status=$?"' EXIT
	parse_args "$@" || {
		usage
		return 1
	}

	if [[ $APP_SHOW_VERSION -eq 1 ]]; then
		echo "$SCRIPT_VERSION"
		return 0
	fi

	if [[ $APP_SHOW_HELP -eq 1 ]]; then
		usage
		return 0
	fi

	if should_launch_gui; then
		launch_gui "$@"
	fi
	if [[ "$APP_GUI_MODE" == "force" ]]; then
		return 1
	fi

	require_dialog
	resolve_target_device || return 1
	ui_select_action || return 1
	build_setup_args

	if [[ "${RTD_VENTOY_CONFIRMED:-0}" != "1" ]]; then
		confirm_message="$(build_confirm_message)"
		trace "confirmation prepared for device=${TARGET_DEVICE}"
		if ! ui_confirm "$confirm_message"; then
			write_information "Ventoy creation canceled by user."
			return 0
		fi
	else
		trace "confirmation previously completed"
	fi

	run_setup
	status=$?
	trace "setup finished status=${status}"

	if [[ $status -eq 0 ]]; then
		ui_notice "Ventoy USB setup complete.\n\nLog file: ${_LOGFILE}"
	else
		ui_notice "Ventoy USB setup failed.\n\nReview log file:\n${_LOGFILE}"
	fi

	return $status
}

main "$@"
