require_command() {
	local command_name="$1" package_name="${2:-$1}"
	command -v "$command_name" >/dev/null 2>&1 && return 0
	software::check_native_package_dependency "$package_name"
}

install_software() {
	software::check_native_package_dependency "$@"
}

ensure_optional_package() {
	local command_name="$1" package_name="${2:-$1}"
	command -v "$command_name" >/dev/null 2>&1 && return 0
	install_software "$package_name" >/dev/null 2>&1 || true
	command -v "$command_name" >/dev/null 2>&1
}

vendor_download_and_install() {
	local package_url="$1"
	mkdir -p "${_OEM_DIR:-/opt/rtd}/cache"
	software::vendor_download_and_install "$package_url"
}

install_systemd_service() {
	local source_script install_path service_file service_name
	source_script="$(readlink -f "$0")"
	install_path="$VPN_ROUTER_INSTALL_PATH"
	service_name="$VPN_ROUTER_SERVICE_NAME"
	service_file="/etc/systemd/system/${service_name}"

	command -v systemctl >/dev/null 2>&1 || {
		echo "systemd is required to install ${service_name}."
		return 1
	}

	install -d -m 0755 "$(dirname "$install_path")" /etc/systemd/system "$(dirname "$VPN_ROUTER_LOGFILE")"
	install -m 0755 "$source_script" "$install_path"

	cat >"$service_file" <<EOF_SERVICE
[Unit]
Description=RTD VPN Router
Documentation=man:systemd.service(5)
Wants=network-online.target
After=network-online.target

[Service]
Type=simple
Environment=BYOBU_MONITOR_ENABLED=0
Environment=VPN_ROUTER_NONINTERACTIVE=1
Environment=VPN_ROUTER_MONITOR_ONLY_WHEN_SERVICE_ACTIVE=0
Environment=VPN_ROUTER_RUN_USER=${RUN_USER}
Environment=VPN_ROUTER_LOGFILE=${VPN_ROUTER_LOGFILE}
Environment=VPN_PREFERRED_CLIENT=${VPN_PREFERRED_CLIENT}
Environment=_LOCALINT=${_LOCALINT}
Environment=_VPNINT=${_VPNINT}
Environment=_LOCALNET=${_LOCALNET}
Environment=_LOCALSUB=${_LOCALSUB}
ExecStart=${install_path}
Restart=on-failure
RestartSec=15

[Install]
WantedBy=multi-user.target
EOF_SERVICE

	systemctl daemon-reload
	systemctl enable "$service_name"
	systemctl restart "$service_name"
	echo "Installed and started ${service_name}."
	echo "Installed script: ${install_path}"
	echo "Service file: ${service_file}"
	echo "Status: systemctl status ${service_name}"
}

find_active_newtork_interface() {
	if [[ -z "${_LOCALINT}" ]]; then
		_LOCALINT="$(ip route show default 2>/dev/null | awk '{print $5}' | head -n1)"
	fi
	if [[ -z "${_LOCALINT}" ]]; then
		echo "Failed to determine local interface; please set _LOCALINT and rerun."
		exit 1
	fi
	echo "Active network interface is: ${_LOCALINT}"
}

derive_local_network() {
	local cidr

	[[ -n "${_LOCALNET}" ]] && return 0

	cidr="$(ip -4 -o addr show dev "${_LOCALINT}" 2>/dev/null | awk '{print $4}' | head -n1 || true)"
	if [[ -z "$cidr" ]]; then
		echo "Failed to derive local network for ${_LOCALINT}; please set _LOCALNET and _LOCALSUB."
		exit 1
	fi
	_LOCALNET="${cidr%/*}"
	_LOCALSUB="${cidr#*/}"
	echo "Derived local network: ${_LOCALNET}/${_LOCALSUB}"
}

find_active_bridge_interface() {
	if [[ -z "${_VPNINT}" ]]; then
		if ip link show tun0 &>/dev/null; then
			_VPNINT="tun0"
		else
			_VPNINT="$(
				ip -o link show |
					awk -F': ' '/: (tun[0-9]+|wg[^:@]*|nordlynx|proton[^:@]*|mullvad[^:@]*)/ { sub(/@.*/, "", $2); print $2; exit }'
			)"
		fi
	fi
	if [[ -z "${_VPNINT}" ]]; then
		local route_int
		route_int="$(ip route get 1.1.1.1 2>/dev/null | awk '{for (i=1; i<=NF; i++) if ($i == "dev") {print $(i+1); exit}}' || true)"
		if [[ -n "$route_int" && "$route_int" != "$_LOCALINT" ]]; then
			_VPNINT="$route_int"
		fi
	fi
	if [[ -z "${_VPNINT}" ]]; then
		echo "Failed to determine VPN interface; please set _VPNINT and rerun."
		return 1
	fi
	echo "VPN interface is: ${_VPNINT}"
}

wait_for_vpn_interface() {
	local attempt

	for ((attempt = 1; attempt <= VPN_INTERFACE_WAIT_SECONDS; attempt++)); do
		_VPNINT=""
		if find_active_bridge_interface; then
			return 0
		fi
		sleep 1
	done

	echo "VPN connect command returned, but no VPN interface was found."
	exit 1
}

setup_routing_for_vpn() {
	echo #---------------------------------------------------------------
	echo "Checking for iptables and install if not there..."
	echo #---------------------------------------------------------------
	software::check_native_package_dependency iptables

	derive_local_network

	echo #---------------------------------------------------------------
	echo "Removing old rules and tables..."
	echo #---------------------------------------------------------------
	iptables -F
	iptables -X
	iptables -t nat -F
	iptables -t nat -X
	iptables -t mangle -F
	iptables -t mangle -X

	echo #---------------------------------------------------------------
	echo "Default Policy - Drop everything!"
	echo #---------------------------------------------------------------
	iptables -P INPUT DROP
	iptables -P FORWARD DROP
	iptables -P OUTPUT DROP

	echo #---------------------------------------------------------------
	echo "Allow loopback and established connections."
	echo #---------------------------------------------------------------
	iptables -A INPUT -i lo -j ACCEPT
	iptables -A OUTPUT -o lo -j ACCEPT
	iptables -A INPUT -m conntrack --ctstate RELATED,ESTABLISHED -j ACCEPT
	iptables -A OUTPUT -m conntrack --ctstate RELATED,ESTABLISHED -j ACCEPT

	echo #---------------------------------------------------------------
	echo "Allow LAN traffic on local interface."
	echo #---------------------------------------------------------------
	iptables -A INPUT -i "${_LOCALINT}" -s "${_LOCALNET}/${_LOCALSUB}" -j ACCEPT
	iptables -A OUTPUT -o "${_LOCALINT}" -d "${_LOCALNET}/${_LOCALSUB}" -j ACCEPT

	echo #---------------------------------------------------------------
	echo "Allow VPN interface."
	echo #---------------------------------------------------------------
	iptables -A INPUT -i "${_VPNINT}" -j ACCEPT
	iptables -A FORWARD -i "${_VPNINT}" -j ACCEPT
	iptables -A OUTPUT -o "${_VPNINT}" -j ACCEPT

	echo #---------------------------------------------------------------
	echo "Forward all traffic to this host through the VPN."
	echo #---------------------------------------------------------------
	sysctl -w net.ipv4.ip_forward=1 >/dev/null
	iptables -A FORWARD -o "${_VPNINT}" -i "${_LOCALINT}" -s "${_LOCALNET}/${_LOCALSUB}" -m conntrack --ctstate NEW -j ACCEPT
	iptables -A FORWARD -m conntrack --ctstate ESTABLISHED,RELATED -j ACCEPT
	iptables -t nat -A POSTROUTING -o "${_VPNINT}" -j MASQUERADE
	iptables-save | tee /etc/iptables.sav >/dev/null
}

get_codename() {
	if command -v lsb_release >/dev/null 2>&1; then
		lsb_release -cs
	elif [[ -r /etc/os-release ]]; then
		# shellcheck source=/dev/null
		. /etc/os-release
		echo "${VERSION_CODENAME:-stable}"
	else
		echo "stable"
	fi
}

install_nordvpn_client() {
	echo "Installing NordVPN repository package..."
	if command -v apt-get >/dev/null 2>&1; then
		vendor_download_and_install "$NORDVPN_DEB_URL"
		apt-get update
		install_software nordvpn
	elif command -v rpm >/dev/null 2>&1; then
		vendor_download_and_install "$NORDVPN_RPM_URL"
		install_software nordvpn
	else
		err_vpn_install
	fi

	command -v nordvpn >/dev/null 2>&1
}

ensure_mullvad_repo() {
	if command -v apt-get >/dev/null 2>&1; then
		if [[ ! -f /etc/apt/sources.list.d/mullvad.list ]]; then
			install_software curl gpg
			curl -fsSL "$MULLVAD_APT_KEY_URL" -o /usr/share/keyrings/mullvad-keyring.asc
			echo "deb [signed-by=/usr/share/keyrings/mullvad-keyring.asc arch=$(dpkg --print-architecture)] ${MULLVAD_APT_REPO} stable main" | tee /etc/apt/sources.list.d/mullvad.list >/dev/null
			apt-get update
		fi
	elif command -v dnf >/dev/null 2>&1 || command -v yum >/dev/null 2>&1; then
		if [[ ! -f /etc/yum.repos.d/mullvad.repo ]]; then
			require_command curl
			curl -fsSL "$MULLVAD_RPM_REPO_URL" -o /etc/yum.repos.d/mullvad.repo
		fi
	fi
}

ensure_protonvpn_repo() {
	if command -v apt-get >/dev/null 2>&1; then
		vendor_download_and_install "$PROTONVPN_DEB_RELEASE_URL"
		apt-get update
	elif command -v rpm >/dev/null 2>&1; then
		vendor_download_and_install "$PROTONVPN_RPM_RELEASE_URL" || true
	fi
}

install_vpn_client() {
	local choice="$1"
	case "$choice" in
		nordvpn)
			install_nordvpn_client
			;;
		mullvad)
			ensure_mullvad_repo
			install_software mullvad-vpn
			;;
		protonvpn)
			ensure_protonvpn_repo
			install_software proton-vpn-cli || install_software protonvpn-cli
			;;
		*)
			return 1
			;;
	esac
}

detect_vpn_client() {
	if [[ -n "$VPN_PREFERRED_CLIENT" ]]; then
		case "$VPN_PREFERRED_CLIENT" in
			nordvpn|mullvad|protonvpn)
				echo "$VPN_PREFERRED_CLIENT"
				return 0
				;;
		esac
	fi

	if command -v nordvpn >/dev/null 2>&1; then
		echo "nordvpn"
	elif command -v mullvad >/dev/null 2>&1; then
		echo "mullvad"
	elif command -v protonvpn-cli >/dev/null 2>&1 || command -v protonvpn >/dev/null 2>&1; then
		echo "protonvpn"
	else
		echo ""
	fi
}

protonvpn_command() {
	if command -v protonvpn >/dev/null 2>&1; then
		echo "protonvpn"
	elif command -v protonvpn-cli >/dev/null 2>&1; then
		echo "protonvpn-cli"
	fi
}

prompt_vpn_country() {
	local answer=""
	local prompt

	if [[ "${VPN_ROUTER_NONINTERACTIVE}" == "1" ]]; then
		echo ""
		return 0
	fi

	prompt=$'Country to connect to (optional).\nUse a country code such as SE, US, DE, or leave blank.\nContinuing uses the nearest/fastest server: '
	if [[ -r /dev/tty && -w /dev/tty ]]; then
		printf '\n%s' "$prompt" >/dev/tty
		if read -r -t "$VPN_COUNTRY_TIMEOUT" answer </dev/tty; then
			printf '\n' >/dev/tty
		else
			printf '\nNo country selected; using nearest/fastest server.\n' >/dev/tty
			answer=""
		fi
	else
		read -r -t "$VPN_COUNTRY_TIMEOUT" -p "$prompt" answer || answer=""
	fi

	answer="${answer#"${answer%%[![:space:]]*}"}"
	answer="${answer%"${answer##*[![:space:]]}"}"
	echo "$answer"
}

connect_vpn_client() {
	local choice="$1" country="${2:-}" proton_cmd=""
	case "$choice" in
		nordvpn)
			if [[ -n "$country" ]]; then
				nordvpn connect "$country" || nordvpn connect
			else
				nordvpn connect
			fi
			;;
		mullvad)
			if [[ -n "$country" ]]; then
				mullvad relay set location "${country,,}" || return 1
			fi
			mullvad connect
			;;
		protonvpn)
			proton_cmd="$(protonvpn_command)"
			[[ -n "$proton_cmd" ]] || return 1
			if [[ "$proton_cmd" == "protonvpn" ]]; then
				if [[ -n "$country" ]]; then
					protonvpn connect --country "$country" || protonvpn connect -c "$country" || protonvpn connect
				else
					protonvpn connect
				fi
			else
				if [[ -n "$country" ]]; then
					protonvpn-cli c --cc "$country" || protonvpn-cli connect --country "$country" || protonvpn-cli connect -c "$country" || protonvpn-cli c -f
				else
					protonvpn-cli c -f || protonvpn-cli connect --fastest || protonvpn-cli connect
				fi
			fi
			;;
		*)
			return 1
			;;
	esac
}

check_menu_availability() {
	if command -v whiptail >/dev/null 2>&1; then
		rtd_menu="whiptail"
	elif command -v dialog >/dev/null 2>&1; then
		rtd_menu="dialog"
	else
		err_no_menu_system_found
	fi
}

choose_vpn_to_install() {
	local choice=""

	if [[ -n "$rtd_menu" ]]; then
		choice="$($rtd_menu --menu "No supported VPN CLI was found. Select one to install." 15 70 3 \
			"nordvpn" "NordVPN" \
			"mullvad" "Mullvad VPN" \
			"protonvpn" "Proton VPN CLI" \
			3>&1 1>&2 2>&3)"
	else
		read -r -p "No VPN client found. Install which? [nordvpn/mullvad/protonvpn]: " choice
	fi

	choice="${choice,,}"
	[[ -n "$choice" ]] || return 1
	echo "$choice"
}

run_vpn() {
	local vpn_client choice=""
	vpn_client="$(detect_vpn_client)"

	if [[ -z "$vpn_client" ]]; then
		choice="$(choose_vpn_to_install)" || {
			echo "No VPN client selected; exiting."
			exit 1
		}
		install_vpn_client "$choice" || {
			echo "Failed to install VPN client: $choice"
			exit 1
		}
		vpn_client="$choice"
	fi

	VPN_CLIENT="$vpn_client"
	VPN_COUNTRY="$(prompt_vpn_country)"
	echo "Connecting ${VPN_CLIENT}${VPN_COUNTRY:+ to ${VPN_COUNTRY}}..."
	connect_vpn_client "$VPN_CLIENT" "$VPN_COUNTRY" || {
		echo "Failed to start VPN client: $vpn_client"
		exit 1
	}
}

ensure_monitor_tool() {
	if ((BYOBU_MONITOR_ENABLED)); then
		ensure_optional_package byobu byobu || true
		ensure_optional_package htop htop || true
		ensure_optional_package "$BANDWIDTH_MONITOR_PREFERRED_TOOL" "$BANDWIDTH_MONITOR_PREFERRED_TOOL" || true
		ensure_optional_package nload nload || true
	fi

	if command -v "$MONITOR_PREFERRED_TOOL" >/dev/null 2>&1; then
		MONITOR_TOOL="$MONITOR_PREFERRED_TOOL"
		return 0
	fi

	echo "${MONITOR_PREFERRED_TOOL} is not installed; attempting to install btop for live monitoring."
	install_software btop || true
	if command -v btop >/dev/null 2>&1; then
		MONITOR_TOOL="btop"
	elif command -v htop >/dev/null 2>&1; then
		MONITOR_TOOL="htop"
	else
		MONITOR_TOOL="top"
	fi
}

write_monitor_readme() {
	mkdir -p "$(dirname "$VPN_ROUTER_README")" "$(dirname "$VPN_ROUTER_LOGFILE")" 2>/dev/null || true
	cat >"$VPN_ROUTER_README" <<EOF_README
FIREWALL VPN ROUTER

- Detach from this monitoring console with F6.
- Reattach with: sudo -H byobu attach -t ${BYOBU_SESSION_NAME}
- VPN client: ${VPN_CLIENT:-unknown}
- VPN interface: ${_VPNINT:-unknown}
- LAN interface: ${_LOCALINT:-unknown}
- LAN network: ${_LOCALNET:-unknown}/${_LOCALSUB:-unknown}

Quick checks:
  ip route get 1.1.1.1
  iptables -S
  iptables -t nat -S
  journalctl -f
EOF_README
}

append_monitor_log() {
	mkdir -p "$(dirname "$VPN_ROUTER_LOGFILE")" 2>/dev/null || true
	{
		printf '\n[%s] VPN router active\n' "$(date '+%Y-%m-%d %H:%M:%S')"
		printf 'VPN client: %s\n' "${VPN_CLIENT:-unknown}"
		printf 'VPN country: %s\n' "${VPN_COUNTRY:-nearest/fastest}"
		printf 'VPN interface: %s\n' "${_VPNINT:-unknown}"
		printf 'LAN interface: %s\n' "${_LOCALINT:-unknown}"
		printf 'LAN network: %s/%s\n' "${_LOCALNET:-unknown}" "${_LOCALSUB:-unknown}"
	} >>"$VPN_ROUTER_LOGFILE" 2>/dev/null || true
}

bandwidth_monitor_command() {
	if command -v speedometer >/dev/null 2>&1; then
		printf 'speedometer -r %q -t %q' "$_VPNINT" "$_VPNINT"
	elif command -v nload >/dev/null 2>&1; then
		printf 'nload %q' "$_VPNINT"
	else
		printf 'watch -n 1 %q' "ip -s link show dev $_VPNINT"
	fi
}

process_monitor_command() {
	if command -v htop >/dev/null 2>&1; then
		printf 'htop'
	else
		printf 'top'
	fi
}

start_byobu_monitoring() {
	local session="$BYOBU_SESSION_NAME"
	local process_cmd bandwidth_cmd quick_cmd

	command -v byobu >/dev/null 2>&1 || return 1
	process_cmd="$(process_monitor_command)"
	bandwidth_cmd="$(bandwidth_monitor_command)"
	write_monitor_readme
	append_monitor_log
	quick_cmd="cd ${RUN_HOME@Q}; cat ${VPN_ROUTER_README@Q}; exec bash"

	byobu kill-session -t "$session" >/dev/null 2>&1 || true
	byobu new-session -d -s "$session" -n status "$process_cmd"
	byobu split-window -h -t "$session:0.0" "$quick_cmd"
	byobu split-window -v -t "$session:0.0" "touch ${VPN_ROUTER_LOGFILE@Q}; tail -n 80 -f ${VPN_ROUTER_LOGFILE@Q}"
	byobu split-window -v -t "$session:0.1" "$bandwidth_cmd"
	byobu select-pane -t "$session:0.1"
	byobu attach-session -t "$session"
}

start_monitoring() {
	echo "VPN routing is active through ${_VPNINT}."
	if [[ "${BYOBU_MONITOR_ENABLED}" == "0" ]]; then
		append_monitor_log
		echo "Interactive monitoring disabled; keeping service process active."
		exec tail -n 0 -F "$VPN_ROUTER_LOGFILE"
	fi

	if ((BYOBU_MONITOR_ENABLED)) && start_byobu_monitoring; then
		return 0
	fi

	echo "Starting monitor: ${MONITOR_TOOL}"
	case "$MONITOR_TOOL" in
		btop|htop)
			exec "$MONITOR_TOOL"
			;;
		*)
			exec top
			;;
	esac
}

vpn_router_service_is_active() {
	command -v systemctl >/dev/null 2>&1 || return 1
	systemctl is-active --quiet "$VPN_ROUTER_SERVICE_NAME"
}

monitor_existing_service_only() {
	[[ "$#" -eq 0 ]] || return 1
	[[ "$VPN_ROUTER_NONINTERACTIVE" != "1" ]] || return 1
	[[ "$VPN_ROUTER_MONITOR_ONLY_WHEN_SERVICE_ACTIVE" == "1" ]] || return 1
	vpn_router_service_is_active
}

start_existing_service_monitor() {
	echo "${VPN_ROUTER_SERVICE_NAME} is already active; starting monitor only."
	find_active_newtork_interface
	derive_local_network
	wait_for_vpn_interface
	ensure_monitor_tool
	start_monitoring
}

err_vpn_install() {
	if [[ -n "$rtd_menu" ]]; then
		$rtd_menu --title "$_branding helper: PROBLEM" --msgbox "I was not able to install the selected VPN client. Please install it manually and try again." 8 90
	else
		echo "I was not able to install the selected VPN client. Please install it manually and try again."
	fi
	cleanup
	exit 1
}

err_no_menu_system_available() {
	echo "There is no menu or dialog software installed on this system."
	echo "If you want to use $me you must ensure that whiptail or dialog is installed."
	read -r -p "Press [ENTER] to exit... "
	cleanup
	exit 1
}

err_no_menu_system_found() {
	echo "There is no way to display menus on this system."
	echo "This is required to display the VPN client install choices."
	read -r -p "May I attempt to install whiptail? (y/n)? " choice
	case "$choice" in
		y|Y)
			install_software whiptail
			;;
		n|N)
			err_no_menu_system_available
			;;
		*)
			echo "Invalid Selection"
			err_no_menu_system_found
			;;
	esac
}


