main() {
	initialize_script "$@"
	pushd "$RUN_HOME" >/dev/null || echo "Failed to enter $RUN_HOME"

	if monitor_existing_service_only "$@"; then
		start_existing_service_monitor
		return $?
	fi

	find_active_newtork_interface
	derive_local_network
	check_menu_availability
	ensure_monitor_tool
	run_vpn
	wait_for_vpn_interface
	setup_routing_for_vpn
	start_monitoring
}

main "$@"
