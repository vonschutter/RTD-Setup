usage() {
	cat <<EOF_USAGE
Usage:
  $(basename "$0") [--help|-h]
  $(basename "$0") --install

Description:
  Configure the host as a VPN-backed router and fail closed if the VPN drops.
  Supported VPN CLIs: nordvpn, mullvad, protonvpn/protonvpn-cli.
  If no supported VPN CLI is installed, the script can offer to install one.

Options:
  --install                  Install this script as a systemd service and enable
                             automatic startup after server reboot.

Environment overrides:
  _LOCALINT                 Local LAN interface. Auto-detected when blank.
  _VPNINT                   VPN tunnel interface. Auto-detected after connect.
  _LOCALNET                 Local network address. Auto-derived when blank.
  _LOCALSUB                 Local network CIDR prefix. Default: 24.
  VPN_PREFERRED_CLIENT      nordvpn, mullvad, or protonvpn.
  VPN_COUNTRY_TIMEOUT       Country prompt timeout in seconds. Default: 10.
  MONITOR_PREFERRED_TOOL    Preferred monitor. Default: btop.
  BYOBU_MONITOR_ENABLED     Use byobu multi-pane monitor. Default: 1.
  BYOBU_SESSION_NAME        Byobu session name. Default: rtd-vpn-router.
  VPN_ROUTER_LOGFILE        Log pane file. Default: /var/log/rtd/rtd-vpn-router.log.
  VPN_ROUTER_NONINTERACTIVE Skip interactive prompts. Default: 0.
  VPN_ROUTER_SERVICE_NAME   Systemd service name. Default: rtd-vpn-router.service.
  VPN_ROUTER_INSTALL_PATH   Installed script path. Default: /usr/local/sbin/rtd-start-vpn-router.
  VPN_ROUTER_MONITOR_ONLY_WHEN_SERVICE_ACTIVE
                            With no arguments, monitor an active service instead
                            of starting another VPN connection. Default: 1.
  VPN_ROUTER_RUN_USER       User whose home directory should be used by service
                            and monitor sessions. Auto-detected by default.
  BANDWIDTH_MONITOR_PREFERRED_TOOL
                            Preferred bandwidth tool. Default: speedometer.
EOF_USAGE
}

rtd::bootstrap_library() {
	local library_name="${1:-_rtd_library}" minimum_version="" loaded_version path script_dir src_url tmp rc check
	local -a checks=()

	[[ $# -gt 0 && "${1:-}" != --* ]] && { library_name="$1"; shift; }
	[[ $# -gt 0 && "${1:-}" != --* ]] && { minimum_version="$1"; shift; }
	while [[ $# -gt 0 ]]; do
		case "$1" in
			--version|--check)
				[[ -n "${2:-}" ]] || { echo "Missing value for $1" >&2; return 1; }
				[[ "$1" == "--version" ]] && minimum_version="$2" || checks+=("$2")
				shift 2
			;;
			*)
				echo "Unknown rtd::bootstrap_library option: $1" >&2
				return 1
			;;
		esac
	done

	[[ "$library_name" == "_rtd_library" && ${#checks[@]} -eq 0 ]] && checks=(system::log_item library::apply_rtd_defaults software::vendor_download_and_install)

	rtd::bootstrap_library::ok() {
		loaded_version="${RTD_VERSION:-${RTDFUNCTIONS:-}}"
		if [[ "$library_name" == "_rtd_library" && -n "$minimum_version" ]]; then
			[[ -n "$loaded_version" ]] || return 1
			[[ "$(printf '%s\n%s\n' "$minimum_version" "$loaded_version" | sort -V | tail -n 1)" == "$loaded_version" ]] || return 1
		fi
		for check in "${checks[@]}"; do declare -F "$check" >/dev/null 2>&1 || return 1; done
	}

	[[ "$library_name" == "_rtd_library" && -n "$loaded_version" ]] && rtd::bootstrap_library::ok && return 0

	script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
	for path in \
		"${script_dir}/${library_name}" \
		"${script_dir}/../core/${library_name}" \
		"${script_dir}/../../core/${library_name}" \
		"/opt/${_TLA:-${_tla:-rtd}}/core/${library_name}" \
		"/opt/rtd/core/${library_name}" \
		"${HOME:-}/GIT/RTD-Setup/core/${library_name}" \
		"${HOME:-}/RTD-Setup/core/${library_name}"; do
		[[ -r "$path" ]] || continue
		# shellcheck source=/dev/null
		source "$path" ""
		rc=$?
		[[ $rc -eq 0 ]] && rtd::bootstrap_library::ok && return 0
	done

	src_url="https://github.com/${_GIT_PROFILE:-${GIT_Profile:-vonschutter}}/RTD-Setup/raw/main/core/${library_name}"
	tmp="$(mktemp "/tmp/${library_name}.XXXXXX" 2>/dev/null || echo "/tmp/${library_name}.$$")"
	rc=0
	if command -v curl >/dev/null 2>&1; then
		curl -fsSL "$src_url" -o "$tmp" || rc=$?
	elif command -v wget >/dev/null 2>&1; then
		wget -qO "$tmp" "$src_url" || rc=$?
	else
		rc=1
	fi
	[[ ${rc:-0} -eq 0 ]] || { rm -f "$tmp"; return "$rc"; }

	# shellcheck source=/dev/null
	source "$tmp" ""
	rc=$?
	rm -f "$tmp"
	[[ $rc -eq 0 ]] || return "$rc"
	rtd::bootstrap_library::ok && return 0

	echo "Loaded $library_name, but the requested version/functions are not available." >&2
	return 1
}

initialize_runtime_user() {
	RUN_USER="${VPN_ROUTER_RUN_USER:-${SUDO_USER:-${USER:-root}}}"
	[[ -n "$RUN_USER" ]] || RUN_USER="root"
	RUN_HOME="$(getent passwd "$RUN_USER" 2>/dev/null | awk -F: '{print $6}' || true)"
	[[ -n "$RUN_HOME" ]] || RUN_HOME="${HOME:-/root}"
	export SUDO_USER="$RUN_USER"
}

initialize_script() {
	if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
		usage
		exit 0
	fi

	if [[ "${EUID}" -ne 0 ]]; then
		echo "This script needs administrative access..."
		exec sudo -H SUDO_USER="${SUDO_USER:-$USER}" bash "$0" "$@"
	fi

	initialize_runtime_user

	rtd::bootstrap_library "_rtd_library" || {
		echo "Failed to load _rtd_library"
		exit 1
	}

	if [[ "${1:-}" == "--install" ]]; then
		install_systemd_service
		exit $?
	fi
}


