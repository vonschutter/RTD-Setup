#::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::

if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
	local_help
	exit 0
fi

# Ensure access to the rtd library functions:
if rtd::bootstrap_library "_rtd_library" ; then
	# Ensure elevated privs.
	security::ensure_admin

	# Attempt config of HUION:
	config_huion610
else
	{ echo "Library not found!" ; exit 1 ; }
	exit 1
fi
