#!/bin/bash


#::                                           RTD Script Menu
#::                               G R A P H I C A L    L A U N C H E R
#::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::
#::::::::::::::::::::::::::::::::::::::::::// RTD Script Menu //::::::::::::::::::::::::::::::::::::::// Linux //::::::::
#:: Module:     oem-system-admin.mod
#:: Script:     rtd-script-menu
#:: Author(s):  RTD Team (vonschutter)
#:: Version:    1.0
#::
#:: Purpose:    Show a Zenity-based picker for installed RTD scripts under the active RTD module tree.
#::
#:: Usage:      rtd-script-menu [--help]
#::
#:: Requires:   bash, find, zenity, and installed RTD module scripts under /opt/<tla>/modules.
#::
#:: Notes:      The organization prefix is inferred from the first three characters of the script name.
#::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::
#::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::

#::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::
#::::::::::::::                                          ::::::::::::::::::::::
#::::::::::::::          Script Safety Check             ::::::::::::::::::::::
#::::::::::::::                                          ::::::::::::::::::::::
#::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::

if (( BASH_VERSINFO[0] < 4 || (BASH_VERSINFO[0] == 4 && BASH_VERSINFO[1] < 4) )); then
	echo "ERROR: RTD _rtd_library requires Bash 4.4 or newer. Current shell: Bash ${BASH_VERSION}." >&2
	return 1 2>/dev/null || exit 1
fi

#::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::
#::::::::::::::                                          ::::::::::::::::::::::
#::::::::::::::          Script Settings                 ::::::::::::::::::::::
#::::::::::::::                                          ::::::::::::::::::::::
#::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::

:	${GIT_Profile:=vonschutter}
_scriptname=$(basename $0)
_tla=${_scriptname:0:3}


#::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::
#::::::::::::::                                          ::::::::::::::::::::::
#::::::::::::::          Script Initialization           ::::::::::::::::::::::
#::::::::::::::                                          ::::::::::::::::::::::
#::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::


if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
	cat <<EOF
Usage:
  $(basename "$0") [--help|-h]

Description:
  Show a Zenity-based picker for installed RTD scripts under /opt/$_tla/modules.
EOF
	exit 0
fi


#::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::
#::::::::::::::                                          ::::::::::::::::::::::
#::::::::::::::          Script Executive                ::::::::::::::::::::::
#::::::::::::::                                          ::::::::::::::::::::::
#::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::

_run=$(find /opt/$_tla/modules -name "${_tla}*"|cut -f6 -d/ | zenity --list --title "Search Results" --text "OEM Tools and Scripts List" --column "Files" --width=800 --height=600 2>/dev/null )
exit_status=$?

case $exit_status in
        1) clear && echo [Cancel] && exit ;;
        255) clear && echo [ESC] && exit ;;
esac

if [[ -n ${_run} ]] ; then bash ${_run} ; else echo "$0 Nothing requested..." ; fi
