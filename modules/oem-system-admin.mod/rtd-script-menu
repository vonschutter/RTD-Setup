#!/bin/bash
#
#::                                   A D M I N   C O M M A N D
#::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::
#::::::::::::::::::::::::::::::::::::::// RTD Script Menu //:::::::::::::::::::::::::::::::::::::::::// Linux //:::::::::
#:: Author(s):    RTD
#:: Version:      1.00
#::
#:: Purpose:      Present a simple graphical list of RTD scripts installed under
#::               the active RTD module tree and launch the selected script.
#::
#:: Value:        Useful on systems where the user knows RTD tools are installed
#::               but does not remember the exact command names or paths.
#::
#:: Usage:        Run the script, select a tool from the Zenity list, and the
#::               selected script will be executed.
#::
#:: Examples:
#::               rtd-script-menu
#::
#::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::

#::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::
#::::::::::::::                                          ::::::::::::::::::::::
#::::::::::::::          Script Settings                 ::::::::::::::::::::::
#::::::::::::::                                          ::::::::::::::::::::::
#::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::
# Variables that govern the behavior or the script and location of files are
# set here. There should be no reason to change any of this abcent strong preferences.


# Put a convenient link to the logs where logs are normally found...
# capture the 3 first letters as org TLA (Three Letter Acronym)
export _scriptname=$(basename $0)
export _tla=${_scriptname:0:3}

if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
	cat <<EOF
Usage:
  $(basename "$0") [--help|-h]

Description:
  Show a Zenity-based picker for installed RTD scripts under /opt/$_tla/modules.
EOF
	exit 0
fi


#::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::
#::::::::::::::                                          ::::::::::::::::::::::
#::::::::::::::          Execute tasks                   ::::::::::::::::::::::
#::::::::::::::                                          ::::::::::::::::::::::
#::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::

_run=$(find /opt/$_tla/modules -name "${_tla}*"|cut -f6 -d/ | zenity --list --title "Search Results" --text "OEM Tools and Scripts List" --column "Files" --width=800 --height=600 2>/dev/null )
exit_status=$?

case $exit_status in
        1) clear && echo [Cancel] && exit ;;
        255) clear && echo [ESC] && exit ;;
esac

if [[ -n ${_run} ]] ; then bash ${_run} ; else echo "$0 Nothing requested..." ; fi
