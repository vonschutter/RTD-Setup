if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
	cat <<EOF
Usage:
  $(basename "$0") [--help|-h]

Description:
  Build a bootable ISO image from a source directory and prompt for the required details.
EOF
	exit 0
fi

# Ensure access to the rtd library functions:
rtd::bootstrap_library "_rtd_library" || { echo "Failed to load _rtd_library"; exit 1; }

command -v dialog &>/dev/null || exit_on_error "dialog is not installed. Please install it and try again."

warn_deprecated
get_task_information
check_environment

mkisofs -r -J -T \
        -b isolinux/isolinux.bin \
        -no-emul-boot \
        -boot-load-size 4 \
        -boot-info-table \
        -o "${ISO_IMAGE}" \
        -V "${CD_LABEL}" \
        "${RH_BUILD_DIR}" || { write_error "Failed to create the ISO file!"; exit 1; }
