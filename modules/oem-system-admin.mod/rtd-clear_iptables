if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
	cat <<EOF
Usage:
  $(basename "$0") [--help|-h]

Description:
  Flush iptables rules and reset the default INPUT policy to ACCEPT.
EOF
	exit 0
fi

# Ensure access to the rtd library functions:
rtd::bootstrap_library "_rtd_library" || { echo "Failed to load _rtd_library"; exit 1; }

# Esure elevated privs:
security::ensure_admin


if hash iptables 2>/dev/null; then
	write_information "Flushing iptables rules..."
	iptables -F
	iptables -X
	iptables -t nat -F
	iptables -t nat -X
	iptables -t mangle -F
	iptables -t mangle -X
	iptables -P INPUT ACCEPT
else
	write_error "iptables is not installed on this system!"
	exit 1
fi

