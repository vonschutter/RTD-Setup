#:: Module:     oem-system-admin.mod
#:: Script:     rtd-netuse
#:: Author(s):  RTD Team (vonschutter)
#:: Version:    1.0
#::
#:: Purpose:    Mount one or more SMB/CIFS shares under a local mount base.
#::
#:: Usage:      rtd-netuse [options] SERVER SHARE [...]
#::
#:: Requires:   bash >= 4.4, cifs-utils or mount.cifs, sudo rights for mounting, and network access to the SMB server.
#::
#:: Notes:      Prompts for missing connection details and mounts each requested share individually.
#::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::
#::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::


:<<"::CMDLITERAL"
@ECHO OFF
GOTO :CMDSCRIPT
::CMDLITERAL


#::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::
#::::::::::::::                                          ::::::::::::::::::::::
#::::::::::::::          Script Safety Check             ::::::::::::::::::::::
#::::::::::::::                                          ::::::::::::::::::::::
#::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::

if (( BASH_VERSINFO[0] < 4 || (BASH_VERSINFO[0] == 4 && BASH_VERSINFO[1] < 4) )); then
	echo "ERROR: RTD _rtd_library requires Bash 4.4 or newer. Current shell: Bash ${BASH_VERSION}." >&2
	return 1 2>/dev/null || exit 1
fi

#::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::
#::::::::::::::                                          ::::::::::::::::::::::
#::::::::::::::          Script Settings                 ::::::::::::::::::::::
#::::::::::::::                                          ::::::::::::::::::::::
#::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::
_scriptname="$(basename "$0")"
_tla="${_scriptname:0:3}"
_LOGFILE="${RTD_LOG_DIR:-/var/log/rtd}/${_scriptname}.log"
if ! mkdir -p "$(dirname "$_LOGFILE")" 2>/dev/null || ! touch "$_LOGFILE" 2>/dev/null; then
	unset _LOGFILE
fi
export _LOGFILE

# Defaults
_GIT_PROFILE="${_GIT_PROFILE:-vonschutter}"
_default_mount_base=""
_default_opts=""

# Runtime args
server=""
shares=()
smb_user=""
smb_pass=""
smb_domain=""
mount_base=""
extra_opts=""
list_only=0
ask_missing=0

#::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::
#::::::::::::::                                          ::::::::::::::::::::::
#::::::::::::::          Helpers                          ::::::::::::::::::::::
#::::::::::::::                                          ::::::::::::::::::::::
#::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::

sanitize_args_for_log() {
	local arg redact_next=0
	local -a sanitized=()

	for arg in "$@"; do
		if [[ $redact_next -eq 1 ]]; then
			sanitized+=("<redacted>")
			redact_next=0
			continue
		fi

		case "$arg" in
			-p|--password)
				sanitized+=("$arg")
				redact_next=1
			;;
			--password=*)
				sanitized+=("--password=<redacted>")
			;;
			*)
				sanitized+=("$arg")
			;;
		esac
	done

	printf '%q ' "${sanitized[@]}"
}

require_option_value() {
	local option="$1" value="${2:-}"

	if [[ -z "$value" || "$value" == --* ]]; then
		write_error "Missing value for ${option}."
		usage
		exit 1
	fi
}

clear_screen() {
	if [[ -w /dev/tty ]]; then
		clear > /dev/tty 2>/dev/null || true
	else
		clear >&2 2>/dev/null || true
	fi
}

usage() {
	cat <<-USAGE

Usage:
  ${_scriptname} <server> <share1> [share2 ...] [options]
  ${_scriptname}                 Open a dialog form

Options:
  -s, --server <name>       SMB server name or IP
  -u, --user <name>         SMB username (default: current user)
  -p, --password <pass>     SMB password (if omitted, you will be prompted)
  -d, --domain <domain>     SMB domain (optional)
  -m, --mount-base <path>   Base mount dir (default: ~/mnt)
  -o, --options <opts>      Extra mount options (comma-separated)
  -l, --list                List available shares (requires smbclient)
  -a, --ask                 Prompt for missing values
  -h, --help                Show this help

Examples:
  ${_scriptname}
  ${_scriptname} fileserver Public Backups
  ${_scriptname} --server 10.0.0.10 --user alice --ask
  ${_scriptname} -s nas01 -u bob -m /mnt/smb -o "vers=3.0"

USAGE
}

rtd::bootstrap_library() {
	if (( BASH_VERSINFO[0] < 4 || (BASH_VERSINFO[0] == 4 && BASH_VERSINFO[1] < 4) )); then
		echo "ERROR: RTD _rtd_library requires Bash 4.4 or newer. Current shell: Bash ${BASH_VERSION}." >&2
		return 1
	fi
	local library_name="${1:-_rtd_library}" minimum_version="" loaded_version path script_dir src_url tmp rc check
	local -a checks=()

	[[ $# -gt 0 && "${1:-}" != --* ]] && { library_name="$1"; shift; }
	[[ $# -gt 0 && "${1:-}" != --* ]] && { minimum_version="$1"; shift; }
	while [[ $# -gt 0 ]]; do
		case "$1" in
			--version|--check)
				[[ -n "${2:-}" ]] || { echo "Missing value for $1" >&2; return 1; }
				[[ "$1" == "--version" ]] && minimum_version="$2" || checks+=("$2")
				shift 2
			;;
			*)
				echo "Unknown rtd::bootstrap_library option: $1" >&2
				return 1
			;;
		esac
	done

	[[ "$library_name" == "_rtd_library" && ${#checks[@]} -eq 0 ]] && checks=(system::log_item library::apply_rtd_defaults)

	rtd::bootstrap_library::ok() {
		loaded_version="${RTD_VERSION:-${RTDFUNCTIONS:-}}"
		if [[ "$library_name" == "_rtd_library" && -n "$minimum_version" ]]; then
			[[ -n "$loaded_version" ]] || return 1
			[[ "$(printf '%s\n%s\n' "$minimum_version" "$loaded_version" | sort -V | tail -n 1)" == "$loaded_version" ]] || return 1
		fi
		for check in "${checks[@]}"; do declare -F "$check" >/dev/null 2>&1 || return 1; done
	}

	[[ "$library_name" == "_rtd_library" && -n "$loaded_version" ]] && rtd::bootstrap_library::ok && return 0

	script_dir="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"
	for path in \
		"${script_dir}/${library_name}" \
		"${script_dir}/../core/${library_name}" \
		"${script_dir}/../../core/${library_name}" \
		"/opt/${_TLA:-${_tla:-rtd}}/core/${library_name}" \
		"/opt/rtd/core/${library_name}" \
		"${HOME:-}/GIT/RTD-Setup/core/${library_name}" \
		"${HOME:-}/RTD-Setup/core/${library_name}"; do
		[[ -r "$path" ]] || continue
		# shellcheck source=/dev/null
		source "$path" ""
		rc=$?
		[[ $rc -eq 0 ]] && rtd::bootstrap_library::ok && return 0
	done

	src_url="https://github.com/${_GIT_PROFILE:-${GIT_Profile:-vonschutter}}/RTD-Setup/raw/main/core/${library_name}"
	tmp="$(mktemp "/tmp/${library_name}.XXXXXX" 2>/dev/null || echo "/tmp/${library_name}.$$")"
	rc=0
	if command -v curl >/dev/null 2>&1; then
		curl -fsSL "$src_url" -o "$tmp" || rc=$?
	elif command -v wget >/dev/null 2>&1; then
		wget -qO "$tmp" "$src_url" || rc=$?
	else
		rc=1
	fi
	[[ ${rc:-0} -eq 0 ]] || { rm -f "$tmp"; return "$rc"; }

	# shellcheck source=/dev/null
	source "$tmp" ""
	rc=$?
	rm -f "$tmp"
	[[ $rc -eq 0 ]] || return "$rc"
	rtd::bootstrap_library::ok && return 0

	echo "Loaded $library_name, but the requested version/functions are not available." >&2
	return 1
}

prompt_text() {
	local title="$1" msg="$2" default="$3" out
	if command -v dialog >/dev/null 2>&1; then
		out=$(dialog --stdout --title "$title" --inputbox "$msg" 10 70 "$default")
		local rc=$?
		clear_screen
		if [[ $rc -ne 0 ]]; then
			return 1
		fi
		echo "$out"
	else
		read -r -p "$msg " out
		echo "$out"
	fi
}

prompt_password() {
	local title="$1" msg="$2" out
	: "${title:=Password}"

	if command -v dialog >/dev/null 2>&1; then
		out=$(dialog --stdout --insecure --title "$title" --passwordbox "$msg" 10 70)
		local rc=$?
		clear_screen
		[[ $rc -eq 0 ]] || return 1
	elif [[ -r /dev/tty && -w /dev/tty ]]; then
		printf '%s\n' "$title" > /dev/tty
		printf '%s ' "$msg" > /dev/tty
		IFS= read -r -s out < /dev/tty || return 1
		printf '\n' > /dev/tty
	else
		read -r -s -p "$msg " out
		printf '\n' >&2
	fi

	echo "$out"
}

parse_yes_no() {
	case "${1,,}" in
		y|yes|true|1|on)
			return 0
		;;
		*)
			return 1
		;;
	esac
}

prompt_netuse_form() {
	local output rc share_input list_input password_status
	local -a fields=()

	if command -v dialog >/dev/null 2>&1; then
		system::log_item "Opening dialog form for zero-argument run."
		output=$(dialog --stdout \
			--title "SMB Mount" \
			--form "Enter SMB connection details. Share names may be space-separated." 19 86 8 \
			"Server:"      1 2 "${server}"      1 24 52 0 \
			"Shares:"      2 2 ""              2 24 52 0 \
			"Username:"    3 2 "${smb_user}"    3 24 52 0 \
			"Domain:"      4 2 "${smb_domain}"  4 24 52 0 \
			"Mount base:"  5 2 "${mount_base}"  5 24 52 0 \
			"Options:"     6 2 "${extra_opts}"  6 24 52 0 \
			"List only:"   7 2 "no"            7 24 12 0)
		rc=$?
		clear_screen
		if [[ $rc -ne 0 ]]; then
			write_warning "Dialog form cancelled with rc=${rc}."
			return 1
		fi

		mapfile -t fields <<<"$output"
		server="${fields[0]}"
		share_input="${fields[1]}"
		smb_user="${fields[2]}"
		smb_domain="${fields[3]}"
		mount_base="${fields[4]}"
		extra_opts="${fields[5]}"
		list_input="${fields[6]}"
	else
		system::log_item "Dialog command not found; using terminal prompts for zero-argument run."
		server=$(prompt_text "SMB Server" "Enter SMB server name or IP:" "${server}") || return 1
		share_input=$(prompt_text "SMB Shares" "Enter share names (space-separated; leave blank when listing only):" "") || return 1
		smb_user=$(prompt_text "SMB Username" "Enter SMB username:" "${smb_user}") || return 1
		smb_domain=$(prompt_text "SMB Domain" "Enter SMB domain (optional):" "${smb_domain}") || return 1
		mount_base=$(prompt_text "Mount Base" "Enter base mount directory:" "${mount_base}") || return 1
		extra_opts=$(prompt_text "Mount Options" "Enter extra mount options (optional):" "${extra_opts}") || return 1
		list_input=$(prompt_text "List Only" "List available shares only? (yes/no):" "no") || return 1
	fi

	smb_pass=$(prompt_password "SMB Password" "Enter SMB password for ${smb_user}@${server}:") || {
		write_warning "Password prompt cancelled."
		return 1
	}

	shares=()
	if [[ -n "$share_input" ]]; then
		read -r -a shares <<<"$share_input"
	fi

	if parse_yes_no "$list_input"; then
		list_only=1
	else
		list_only=0
	fi

	password_status="not provided"
	[[ -n "$smb_pass" ]] && password_status="provided"
	write_information "Form captured: server='${server:-<empty>}', shares_count=${#shares[@]}, user='${smb_user:-<empty>}', domain='${smb_domain:-<empty>}', mount_base='${mount_base:-<empty>}', extra_opts='${extra_opts:-<empty>}', list_only=${list_only}, password=${password_status}."
}

parse_args() {
	while [[ $# -gt 0 ]]; do
		case "$1" in
			-s|--server)
				require_option_value "$1" "${2:-}"; server="$2"; shift 2;;
			-u|--user)
				require_option_value "$1" "${2:-}"; smb_user="$2"; shift 2;;
			-p|--password)
				require_option_value "$1" "${2:-}"; smb_pass="$2"; shift 2;;
			-d|--domain)
				require_option_value "$1" "${2:-}"; smb_domain="$2"; shift 2;;
			-m|--mount-base)
				require_option_value "$1" "${2:-}"; mount_base="$2"; shift 2;;
			-o|--options)
				require_option_value "$1" "${2:-}"; extra_opts="$2"; shift 2;;
			-l|--list)
				list_only=1; shift;;
			-a|--ask)
				ask_missing=1; shift;;
			-h|--help)
				usage; exit 0;;
			--)
				shift; break;;
			-*)
				write_error "Unknown option: $1"; usage; exit 1;;
			*)
				if [[ -z "$server" ]]; then
					server="$1"
				else
					shares+=("$1")
				fi
				shift;;
		esac
	done

	# Any remaining args are shares
	while [[ $# -gt 0 ]]; do
		shares+=("$1"); shift
	done
}

resolve_defaults() {
	local invoking_user
	invoking_user="${SUDO_USER:-$USER}"
	if [[ -z "$smb_user" ]]; then
		smb_user="$invoking_user"
	fi

	local home_dir
	if command -v getent >/dev/null 2>&1; then
		home_dir=$(getent passwd "$invoking_user" | cut -d: -f6)
	fi
	if [[ -z "$home_dir" ]]; then
		home_dir="$HOME"
	fi

	_default_mount_base="${home_dir}/mnt"
	mount_base="${mount_base:-${_default_mount_base}}"

	local uid gid
	uid=$(id -u "$invoking_user" 2>/dev/null || echo 0)
	gid=$(id -g "$invoking_user" 2>/dev/null || echo 0)
	_default_opts="uid=${uid},gid=${gid},file_mode=0644,dir_mode=0755,iocharset=utf8,vers=3.0"
}

create_credential_file() {
	local cred_file
	cred_file=$(mktemp "/tmp/${_scriptname}.credentials.XXXXXX") || return 1
	chmod 600 "$cred_file" || {
		rm -f "$cred_file"
		return 1
	}
	{
		echo "username=${smb_user}"
		echo "password=${smb_pass}"
		[[ -n "$smb_domain" ]] && echo "domain=${smb_domain}"
	} >"$cred_file"
	echo "$cred_file"
}

cleanup_credential_file() {
	local cred_file="$1"
	[[ -n "$cred_file" ]] && rm -f "$cred_file"
}

require_sudo_credentials() {
	if [[ $EUID -eq 0 ]]; then
		system::log_item "Administrative access already available."
		return 0
	fi

	if ! command -v sudo >/dev/null 2>&1; then
		write_error "sudo is required to mount SMB shares when not running as root."
		return 1
	fi

	write_information "Requesting administrative credentials for mount operations."
	sudo -v || {
		write_error "Administrative authentication failed."
		return 1
	}
}

run_admin_command() {
	if [[ $EUID -eq 0 ]]; then
		"$@"
	else
		sudo "$@"
	fi
}

ensure_mount_dir() {
	local mount_dir="$1"

	if mkdir -p "$mount_dir" 2>/dev/null; then
		return 0
	fi

	system::log_item "Could not create ${mount_dir} as current user; retrying with sudo."
	run_admin_command mkdir -p "$mount_dir" || {
		write_error "Failed to create mount directory: ${mount_dir}"
		return 1
	}
}

list_shares() {
	local cred_file rc output
	if ! command -v smbclient >/dev/null 2>&1; then
		write_warning "smbclient not available; cannot list shares."
		return 1
	fi
	cred_file=$(create_credential_file) || {
		write_error "Failed to create temporary credential file for smbclient."
		return 1
	}
	write_information "Listing shares on //${server} using smbclient -A <credential-file>."
	output=$(smbclient -L "//${server}" -A "$cred_file" 2>&1)
	rc=$?
	cleanup_credential_file "$cred_file"
	system::log_item "smbclient rc=${rc}; output follows:"
	while IFS= read -r line; do
		system::log_item "$line"
	done <<<"$output"
	printf '%s\n' "$output"
	[[ $rc -eq 0 ]] || {
		write_error "smbclient failed while listing shares on //${server}; rc=${rc}."
		return "$rc"
	}
	return 0
}

mount_share() {
	local share="$1" output rc
	local mount_dir="${mount_base}/${server}/${share}"
	ensure_mount_dir "$mount_dir" || return 1

	if command -v mountpoint >/dev/null 2>&1; then
		if mountpoint -q "$mount_dir"; then
			write_warning "Already mounted: $mount_dir"
			return 0
		fi
	fi

	local cred_file
	cred_file=$(create_credential_file) || {
		write_error "Failed to create temporary credential file for mount."
		return 1
	}

	local opts="credentials=${cred_file},${_default_opts}"
	if [[ -n "$extra_opts" ]]; then
		opts="${opts},${extra_opts}"
	fi

	write_information "Mounting //${server}/${share} -> ${mount_dir}"
	system::log_item "mount command: $( [[ $EUID -eq 0 ]] || printf 'sudo ' )mount -t cifs '//${server}/${share}' '${mount_dir}' -o 'credentials=<temporary-file>,${_default_opts}${extra_opts:+,${extra_opts}}'"
	output=$(run_admin_command mount -t cifs "//${server}/${share}" "$mount_dir" -o "$opts" 2>&1)
	rc=$?
	cleanup_credential_file "$cred_file"
	system::log_item "mount rc=${rc}; output follows:"
	while IFS= read -r line; do
		system::log_item "$line"
	done <<<"$output"

	if [[ $rc -ne 0 ]]; then
		[[ -n "$output" ]] && printf '%s\n' "$output" >&2
		write_error "Failed to mount //${server}/${share}; rc=${rc}."
		return 1
	fi

	write_information "Mounted: ${mount_dir}"
	return 0
}

#::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::
#::::::::::::::                                          ::::::::::::::::::::::
#::::::::::::::          Script Executive                ::::::::::::::::::::::
#::::::::::::::                                          ::::::::::::::::::::::
#::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::

rtd::bootstrap_library "_rtd_library" || { echo "Failed to load _rtd_library"; exit 1; }
write_information "Starting ${_scriptname}; log file: ${_LOGFILE}"
arg_count=$#
system::log_item "Argument count: ${arg_count}; args: $(sanitize_args_for_log "$@")"
parse_args "$@"
system::log_item "After parse_args: server='${server:-<empty>}', shares_count=${#shares[@]}, user='${smb_user:-<empty>}', domain='${smb_domain:-<empty>}', mount_base='${mount_base:-<empty>}', extra_opts='${extra_opts:-<empty>}', list_only=${list_only}, ask_missing=${ask_missing}, password=$([[ -n "$smb_pass" ]] && echo provided || echo not-provided)."
resolve_defaults
system::log_item "After resolve_defaults: smb_user='${smb_user:-<empty>}', mount_base='${mount_base:-<empty>}', default_opts='${_default_opts}'."

if [[ $arg_count -eq 0 ]]; then
	prompt_netuse_form || {
		write_warning "Cancelled."
		exit 1
	}
fi

if [[ -z "$server" && $ask_missing -eq 1 ]]; then
	write_information "Server missing and --ask was provided; prompting for server."
	server=$(prompt_text "SMB Server" "Enter SMB server name or IP:" "") || {
		write_warning "Cancelled."
		exit 1
	}
fi

if [[ -z "$server" ]]; then
	write_error "Server was not provided."
	usage
	exit 1
fi

if [[ -z "$smb_pass" ]]; then
	write_information "Password was not provided; prompting for SMB password."
	smb_pass=$(prompt_password "SMB Password" "Enter SMB password for ${smb_user}@${server}:") || {
		write_warning "Cancelled."
		exit 1
	}
	system::log_item "Password prompt completed: $([[ -n "$smb_pass" ]] && echo provided || echo empty)."
fi

if [[ $list_only -eq 1 ]]; then
	write_information "List-only mode selected."
	list_shares
	exit $?
fi

if [[ ${#shares[@]} -eq 0 && $ask_missing -eq 1 ]]; then
	write_information "Shares missing and --ask was provided; prompting for share list."
	share_input=$(prompt_text "SMB Shares" "Enter share names (space-separated):" "") || {
		write_warning "Cancelled."
		exit 1
	}
	read -r -a shares <<<"$share_input"
fi

if [[ ${#shares[@]} -eq 0 ]]; then
	write_error "No shares specified."
	usage
	exit 1
fi

write_information "Mount base: ${mount_base}"
write_information "Server: ${server}"
write_information "User: ${smb_user}"
write_information "Shares to mount: ${shares[*]}"

write_information "Checking dependency: cifs-utils."
if ! command -v mount.cifs >/dev/null 2>&1 && [[ ! -x /sbin/mount.cifs && ! -x /usr/sbin/mount.cifs ]]; then
	write_error "cifs-utils is required; mount.cifs was not found."
	exit 1
fi
write_information "Dependency check completed."

require_sudo_credentials || exit 1

exit_code=0
for share in "${shares[@]}"; do
	if ! mount_share "$share"; then
		exit_code=1
	fi
done

write_information "Done. exit_code=${exit_code}"
exit "$exit_code"

:CMDSCRIPT
echo "NO! Just say no! Please install Linux instead of Windows"
