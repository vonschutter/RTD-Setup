#!/bin/bash
#
#::                         A D M I N   C O M M A N D L E T
#:::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::
#::::::::::::::::::::::::::::::::::::::// Simple Admin Tool //::::::::::::::::::::::::::::::::::::::::// Linux //:::::::
#::
#::     Author:    SLS
#::     Version    1.11
#::
#::     Purpose: Mount one or more SMB/Windows shares from a given server.
#::              Supports interactive prompts when parameters are missing.
#::
#::     Value:   Useful for quickly mounting remote Windows or Samba shares
#::              from Linux without manually building long mount commands.
#::
#::     Usage:   Run with a server and one or more share names, or run it in
#::              interactive mode so the script can prompt for missing values.
#::
#::     Examples:
#::              rtd-netuse --server fileserver --share Public
#::              rtd-netuse --server nas01 --share Media --ask
#::
#:::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::
#
# This script was originally developed for RuntimeData, a small OEM in Buffalo Center, IA.
# This OEM and store nolonger exists as its owner has passed away.
# This script is shared in the hopes that someone will find it useful.

:<<"::CMDLITERAL"
@ECHO OFF
GOTO :CMDSCRIPT
::CMDLITERAL

#::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::
#::::::::::::::                                          ::::::::::::::::::::::
#::::::::::::::          Script Settings                 ::::::::::::::::::::::
#::::::::::::::                                          ::::::::::::::::::::::
#::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::
_scriptname="$(basename "$0")"
_tla="${_scriptname:0:3}"
_log_dir="${HOME}/.config/${_tla}/logs"
_log_file="${_log_dir}/${_scriptname}.log"
mkdir -p "${_log_dir}" && touch "${_log_file}"

# Defaults
_GIT_PROFILE="${_GIT_PROFILE:-vonschutter}"
_default_mount_base=""
_default_opts=""

# Runtime args
server=""
shares=()
smb_user=""
smb_pass=""
smb_domain=""
mount_base=""
extra_opts=""
list_only=0
ask_missing=0

#::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::
#::::::::::::::                                          ::::::::::::::::::::::
#::::::::::::::          Helpers                          ::::::::::::::::::::::
#::::::::::::::                                          ::::::::::::::::::::::
#::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::

log_info() {
	if type write_information &>/dev/null; then
		write_information "$*"
	else
		echo "$*"
	fi
}

log_warn() {
	if type write_warning &>/dev/null; then
		write_warning "$*"
	else
		echo "WARN: $*"
	fi
}

log_error() {
	if type write_error &>/dev/null; then
		write_error "$*"
	else
		echo "ERROR: $*"
	fi
}

usage() {
	cat <<-USAGE

Usage:
  ${_scriptname} <server> <share1> [share2 ...] [options]

Options:
  -s, --server <name>       SMB server name or IP
  -u, --user <name>         SMB username (default: current user)
  -p, --password <pass>     SMB password (if omitted, you will be prompted)
  -d, --domain <domain>     SMB domain (optional)
  -m, --mount-base <path>   Base mount dir (default: ~/mnt)
  -o, --options <opts>      Extra mount options (comma-separated)
  -l, --list                List available shares (requires smbclient)
  -a, --ask                 Prompt for missing values
  -h, --help                Show this help

Examples:
  ${_scriptname} fileserver Public Backups
  ${_scriptname} --server 10.0.0.10 --user alice --ask
  ${_scriptname} -s nas01 -u bob -m /mnt/smb -o "vers=3.0"

USAGE
}

rtd::bootstrap_library() {
	local library_name="${1:-_rtd_library}" minimum_version="" loaded_version path script_dir src_url tmp rc check
	local -a checks=()

	[[ $# -gt 0 && "${1:-}" != --* ]] && { library_name="$1"; shift; }
	[[ $# -gt 0 && "${1:-}" != --* ]] && { minimum_version="$1"; shift; }
	while [[ $# -gt 0 ]]; do
		case "$1" in
			--version|--check)
				[[ -n "${2:-}" ]] || { echo "Missing value for $1" >&2; return 1; }
				[[ "$1" == "--version" ]] && minimum_version="$2" || checks+=("$2")
				shift 2
			;;
			*)
				echo "Unknown rtd::bootstrap_library option: $1" >&2
				return 1
			;;
		esac
	done

	[[ "$library_name" == "_rtd_library" && ${#checks[@]} -eq 0 ]] && checks=(system::log_item library::apply_rtd_defaults)

	rtd::bootstrap_library::ok() {
		loaded_version="${RTD_VERSION:-${RTDFUNCTIONS:-}}"
		if [[ "$library_name" == "_rtd_library" && -n "$minimum_version" ]]; then
			[[ -n "$loaded_version" ]] || return 1
			[[ "$(printf '%s\n%s\n' "$minimum_version" "$loaded_version" | sort -V | tail -n 1)" == "$loaded_version" ]] || return 1
		fi
		for check in "${checks[@]}"; do declare -F "$check" >/dev/null 2>&1 || return 1; done
	}

	[[ "$library_name" == "_rtd_library" && -n "$loaded_version" ]] && rtd::bootstrap_library::ok && return 0

	script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
	for path in \
		"${script_dir}/${library_name}" \
		"${script_dir}/../core/${library_name}" \
		"${script_dir}/../../core/${library_name}" \
		"/opt/${_TLA:-${_tla:-rtd}}/core/${library_name}" \
		"/opt/rtd/core/${library_name}" \
		"${HOME:-}/GIT/RTD-Setup/core/${library_name}" \
		"${HOME:-}/RTD-Setup/core/${library_name}"; do
		[[ -r "$path" ]] || continue
		# shellcheck source=/dev/null
		source "$path" ""
		rc=$?
		[[ $rc -eq 0 ]] && rtd::bootstrap_library::ok && return 0
	done

	src_url="https://github.com/${_GIT_PROFILE:-${GIT_Profile:-vonschutter}}/RTD-Setup/raw/main/core/${library_name}"
	tmp="$(mktemp "/tmp/${library_name}.XXXXXX" 2>/dev/null || echo "/tmp/${library_name}.$$")"
	rc=0
	if command -v curl >/dev/null 2>&1; then
		curl -fsSL "$src_url" -o "$tmp" || rc=$?
	elif command -v wget >/dev/null 2>&1; then
		wget -qO "$tmp" "$src_url" || rc=$?
	else
		rc=1
	fi
	[[ ${rc:-0} -eq 0 ]] || { rm -f "$tmp"; return "$rc"; }

	# shellcheck source=/dev/null
	source "$tmp" ""
	rc=$?
	rm -f "$tmp"
	[[ $rc -eq 0 ]] || return "$rc"
	rtd::bootstrap_library::ok && return 0

	echo "Loaded $library_name, but the requested version/functions are not available." >&2
	return 1
}

prompt_text() {
	local title="$1" msg="$2" default="$3" out
	if command -v dialog >/dev/null 2>&1; then
		out=$(dialog --stdout --title "$title" --inputbox "$msg" 10 70 "$default")
		local rc=$?
		clear
		if [[ $rc -ne 0 ]]; then
			return 1
		fi
		echo "$out"
	else
		read -r -p "$msg " out
		echo "$out"
	fi
}

prompt_password() {
	local title="$1" msg="$2" out
	: "${title:=Password}"

	if [[ -r /dev/tty && -w /dev/tty ]]; then
		printf '%s\n' "$title" > /dev/tty
		printf '%s ' "$msg" > /dev/tty
		IFS= read -r -s out < /dev/tty || return 1
		printf '\n' > /dev/tty
	else
		read -r -s -p "$msg " out
		echo
	fi

	echo "$out"
}

parse_args() {
	while [[ $# -gt 0 ]]; do
		case "$1" in
		-s|--server)
			server="$2"; shift 2;;
		-u|--user)
			smb_user="$2"; shift 2;;
		-p|--password)
			smb_pass="$2"; shift 2;;
		-d|--domain)
			smb_domain="$2"; shift 2;;
		-m|--mount-base)
			mount_base="$2"; shift 2;;
		-o|--options)
			extra_opts="$2"; shift 2;;
		-l|--list)
			list_only=1; shift;;
		-a|--ask)
			ask_missing=1; shift;;
		-h|--help)
			usage; exit 0;;
		--)
			shift; break;;
		-*)
			log_error "Unknown option: $1"; usage; exit 1;;
		*)
			if [[ -z "$server" ]]; then
				server="$1"
			else
				shares+=("$1")
			fi
			shift;;
		esac
	done

	# Any remaining args are shares
	while [[ $# -gt 0 ]]; do
		shares+=("$1"); shift
	done
}

resolve_defaults() {
	local invoking_user
	invoking_user="${SUDO_USER:-$USER}"
	if [[ -z "$smb_user" ]]; then
		smb_user="$invoking_user"
	fi

	local home_dir
	if command -v getent >/dev/null 2>&1; then
		home_dir=$(getent passwd "$invoking_user" | cut -d: -f6)
	fi
	if [[ -z "$home_dir" ]]; then
		home_dir="$HOME"
	fi

	_default_mount_base="${home_dir}/mnt"
	mount_base="${mount_base:-${_default_mount_base}}"

	local uid gid
	uid=$(id -u "$invoking_user" 2>/dev/null || echo 0)
	gid=$(id -g "$invoking_user" 2>/dev/null || echo 0)
	_default_opts="uid=${uid},gid=${gid},file_mode=0644,dir_mode=0755,iocharset=utf8,vers=3.0"
}

list_shares() {
	if ! command -v smbclient >/dev/null 2>&1; then
		log_warn "smbclient not available; cannot list shares."
		return 1
	fi
	log_info "Listing shares on //${server} (may prompt)..."
	smbclient -L "//${server}" -U "${smb_user}%${smb_pass}" 2>/dev/null || return 1
	return 0
}

mount_share() {
	local share="$1"
	local mount_dir="${mount_base}/${server}/${share}"
	mkdir -p "$mount_dir" || return 1

	if command -v mountpoint >/dev/null 2>&1; then
		if mountpoint -q "$mount_dir"; then
			log_warn "Already mounted: $mount_dir"
			return 0
		fi
	fi

	local cred_file
	cred_file=$(mktemp)
	chmod 600 "$cred_file"
	{
		echo "username=${smb_user}"
		echo "password=${smb_pass}"
		[[ -n "$smb_domain" ]] && echo "domain=${smb_domain}"
	} >"$cred_file"

	local opts="credentials=${cred_file},${_default_opts}"
	if [[ -n "$extra_opts" ]]; then
		opts="${opts},${extra_opts}"
	fi

	log_info "Mounting //${server}/${share} -> ${mount_dir}"
	if ! mount -t cifs "//${server}/${share}" "$mount_dir" -o "$opts"; then
		log_error "Failed to mount //${server}/${share}"
		rm -f "$cred_file"
		return 1
	fi

	rm -f "$cred_file"
	log_info "Mounted: ${mount_dir}"
	return 0
}

#::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::
#::::::::::::::                                          ::::::::::::::::::::::
#::::::::::::::          Main                             ::::::::::::::::::::::
#::::::::::::::                                          ::::::::::::::::::::::
#::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::
rtd::bootstrap_library "_rtd_library" || { echo "Failed to load _rtd_library"; exit 1; }
parse_args "$@"
resolve_defaults

if [[ -z "$server" && $ask_missing -eq 1 ]]; then
	server=$(prompt_text "SMB Server" "Enter SMB server name or IP:" "") || {
		log_warn "Cancelled."
		exit 1
	}
fi

if [[ -z "$server" ]]; then
	usage
	exit 1
fi

if [[ -z "$smb_pass" ]]; then
	smb_pass=$(prompt_password "SMB Password" "Enter SMB password for ${smb_user}@${server}:") || {
		log_warn "Cancelled."
		exit 1
	}
fi

if [[ $list_only -eq 1 ]]; then
	list_shares
	exit $?
fi

# Ensure admin and dependencies
security::ensure_admin
software::check_native_package_dependency cifs-utils >/dev/null 2>&1 || {
	log_error "cifs-utils is required."; exit 1;
}

if [[ ${#shares[@]} -eq 0 && $ask_missing -eq 1 ]]; then
	share_input=$(prompt_text "SMB Shares" "Enter share names (space-separated):" "") || {
		log_warn "Cancelled."
		exit 1
	}
	read -r -a shares <<<"$share_input"
fi

if [[ ${#shares[@]} -eq 0 ]]; then
	log_error "No shares specified."
	usage
	exit 1
fi

log_info "Mount base: ${mount_base}"
log_info "Server: ${server}"
log_info "User: ${smb_user}"

exit_code=0
for share in "${shares[@]}"; do
	if ! mount_share "$share"; then
		exit_code=1
	fi
done

log_info "Done."
exit "$exit_code"

:CMDSCRIPT
echo "NO! Just say no! Please install Linux instead of Windows"
