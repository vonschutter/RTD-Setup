	cat <<EOF
Usage:
  $(basename "$0") [--help|-h]

Description:
  Inspect configured PPAs using the RTD library helper.
EOF
	exit 0
fi
rtd::bootstrap_library "_rtd_library" || { echo "Failed to load _rtd_library"; exit 1; }

