rtd::bootstrap_library() {
	local library_name="${1:-_rtd_library}"
	local minimum_version="${2:-}"
	local loaded_version="${RTD_VERSION:-${RTDFUNCTIONS:-}}"
	local script_dir path src_url tmp

	if [[ "$library_name" == "_rtd_library" && -n "$loaded_version" ]]; then
		if [[ -z "$minimum_version" ]] || [[ "$(printf '%s\n%s\n' "$minimum_version" "$loaded_version" | sort -V | tail -n 1)" == "$loaded_version" ]]; then
			return 0
		fi
	fi

	script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
	for path in \
		"${script_dir}/${library_name}" \
		"${script_dir}/../core/${library_name}" \
		"${script_dir}/../../core/${library_name}" \
		"/opt/${_TLA:-${_tla:-rtd}}/core/${library_name}" \
		"/opt/rtd/core/${library_name}" \
		"${HOME:-}/GIT/RTD-Setup/core/${library_name}" \
		"${HOME:-}/RTD-Setup/core/${library_name}"; do
		if [[ -r "$path" ]]; then
			# shellcheck source=/dev/null
			source "$path" ""
			return $?
		fi
	done

	src_url="https://github.com/${_GIT_PROFILE:-${GIT_Profile:-vonschutter}}/RTD-Setup/raw/main/core/${library_name}"
	tmp="$(mktemp "/tmp/${library_name}.XXXXXX" 2>/dev/null || echo "/tmp/${library_name}.$$")"
	if command -v curl >/dev/null 2>&1; then
		curl -fsSL "$src_url" -o "$tmp" || return 1
	elif command -v wget >/dev/null 2>&1; then
		wget -qO "$tmp" "$src_url" || return 1
	else
		return 1
	fi

	# shellcheck source=/dev/null
	source "$tmp" ""
	local rc=$?
	rm -f "$tmp"
	return $rc
}



local_help() {
	cat <<EOF
Usage:
  $(basename "$0") [--help|-h]

Description:
  Move a Dropbox folder onto a loop-mounted ext4 image for encrypted-home setups.
EOF
}

if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
	local_help
	exit 0
fi

if rtd::bootstrap_library "_rtd_library" ; then
        if [[ -d ~/Dropbox ]]; then
                killall dropbox
                mv Dropbox Dropbox.bak
                mkdir Dropbox
                dd if=/dev/zero of=~/.dropbox/storage bs=1M count=14072
                mkfs.ext4 /home/$USER/.dropbox/storage
                chattr +i /home/$USER/Dropbox
                /home/$USER/.dropbox/storage /home/$USER/Dropbox ext4 defaults,user_xattr,loop 0 0
                mount /home/$USER/Dropbox/


                chown -R $USER /home/$USER/Dropbox
                cp -a Dropbox.bak/* Dropbox/
        else
                echo "Dropbox folder not found!"
                exit 1
        fi
else
        echo "RTD functions NOT found!"
        exit 1
fi
