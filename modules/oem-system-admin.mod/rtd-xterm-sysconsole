#::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::
# Lunches 4 Xterm windows and starts system monitoring tool in them. This is intended to demonstrate how to
# launch windows from the ternminal and determin where on the screen they should appear.
#
# Xterm obeys the following on screen positions:
#
# +0+0    upper left hand corner.
# -0+0    upper right hand corner.
# -0-0    lower right hand corner.
# +0-0    lower left hand corner.

#::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::
#::::::::::::::                                          ::::::::::::::::::::::
#::::::::::::::          Script Functions                ::::::::::::::::::::::
#::::::::::::::                                          ::::::::::::::::::::::
#::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::

rtd::bootstrap_library() {
	local library_name="${1:-_rtd_library}"
	local minimum_version="${2:-}"
	local loaded_version="${RTD_VERSION:-${RTDFUNCTIONS:-}}"
	local script_dir path src_url tmp

	if [[ "$library_name" == "_rtd_library" && -n "$loaded_version" ]]; then
		if [[ -z "$minimum_version" ]] || [[ "$(printf '%s\n%s\n' "$minimum_version" "$loaded_version" | sort -V | tail -n 1)" == "$loaded_version" ]]; then
			return 0
		fi
	fi

	script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
	for path in \
		"${script_dir}/${library_name}" \
		"${script_dir}/../core/${library_name}" \
		"${script_dir}/../../core/${library_name}" \
		"/opt/${_TLA:-${_tla:-rtd}}/core/${library_name}" \
		"/opt/rtd/core/${library_name}" \
		"${HOME:-}/GIT/RTD-Setup/core/${library_name}" \
		"${HOME:-}/RTD-Setup/core/${library_name}"; do
		if [[ -r "$path" ]]; then
			# shellcheck source=/dev/null
			source "$path" ""
			return $?
		fi
	done

	src_url="https://github.com/${_GIT_PROFILE:-${GIT_Profile:-vonschutter}}/RTD-Setup/raw/main/core/${library_name}"
	tmp="$(mktemp "/tmp/${library_name}.XXXXXX" 2>/dev/null || echo "/tmp/${library_name}.$$")"
	if command -v curl >/dev/null 2>&1; then
		curl -fsSL "$src_url" -o "$tmp" || return 1
	elif command -v wget >/dev/null 2>&1; then
		wget -qO "$tmp" "$src_url" || return 1
	else
		return 1
	fi

	# shellcheck source=/dev/null
	source "$tmp" ""
	local rc=$?
	rm -f "$tmp"
	return $rc
}

if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
	cat <<EOF
Usage:
  $(basename "$0") [--help|-h]

Description:
  Launch four xterm windows for interactive system monitoring.
EOF
	exit 0
fi
rtd::bootstrap_library "_rtd_library" || { echo "Failed to load _rtd_library"; exit 1; }
software::check_native_package_dependency xterm htop syslog-ng-core watch df-core
software::check_native_package_dependency bmon

xterm  -geometry 110x30+0+0 -e 'htop' &
xterm  -geometry 110x30-0+0 -e 'tail -f /var/log/syslog' &
xterm  -geometry 110x30-0-0 -e 'watch df -h '&
xterm  -geometry 110x30+0-0 -e 'bmon' &
