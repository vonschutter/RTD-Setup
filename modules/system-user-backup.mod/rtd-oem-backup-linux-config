main() {
	parse_args "$@" || return 1
	if [[ $FORCE_GUI -eq 1 || ( $# -eq 0 && $NO_GUI -eq 0 && ( -n "${DISPLAY:-}" || -n "${WAYLAND_DISPLAY:-}" ) ) ]]; then
		launch_gui
		return $?
	fi
	case "$ACTION" in
		list) list_profiles ;;
		estimate)
			[[ ${#SELECTED_PROFILES[@]} -gt 0 ]] || { log_error "No profiles selected."; return 1; }
			estimate_bytes
			;;
		backup)
			[[ ${#SELECTED_PROFILES[@]} -gt 0 ]] || { log_error "No profiles selected."; return 1; }
			create_backup
			;;
		*) usage; return 1 ;;
	esac
}

main "$@"
