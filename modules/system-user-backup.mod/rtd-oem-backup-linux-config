#!/usr/bin/env bash

#
#::                                         RTD User Backup Tool
#::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::
#::::::::::::::::::::::::::::::::::::::://  RTD Management Tool   //::::::::::::::::::::::::::::::::::// Linux //::::::::
#::
#::  ADMIN TOOL
#::
#::  Purpose:
#::    Create encrypted, compressed backups of user data and selected
#::    desktop/application configuration for reinstall and migration work.
#::
#::  Value:
#::    Provides a GUI-first backup workflow for users and a CLI backend for
#::    scripted OEM/service work. Archives are compressed with zstd and
#::    encrypted with GPG symmetric AES256.
#::
#::  Usage:
#::    rtd-oem-backup-linux-config
#::    rtd-oem-backup-linux-config --no-gui --list-profiles
#::    rtd-oem-backup-linux-config --no-gui --estimate --profiles documents
#::    rtd-oem-backup-linux-config --no-gui --backup --profiles documents \
#::      --destination /media/$USER/Backup --passphrase-file /tmp/pass
#::
#::  Direct GitHub execution:
#::    bash <(curl -fsSL https://raw.githubusercontent.com/vonschutter/RTD-Setup/main/modules/system-user-backup.mod/rtd-oem-backup-linux-config)
#::    bash <(wget -qO- https://raw.githubusercontent.com/vonschutter/RTD-Setup/main/modules/system-user-backup.mod/rtd-oem-backup-linux-config)
#::
#::
#::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::
#::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::

#::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::
#:: Safety Check
#::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::

if (( BASH_VERSINFO[0] < 4 || (BASH_VERSINFO[0] == 4 && BASH_VERSINFO[1] < 4) )); then
	echo "ERROR: Bash 4.4 or newer is required. Current shell: Bash ${BASH_VERSION}." >&2
	return 1 2>/dev/null || exit 1
fi

set -o pipefail

#::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::
#:: Settings
#::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::

PUBLICATION="RTD User Backup Tool"
SCRIPT_VERSION="2.1"
SCRIPT_SOURCE="${BASH_SOURCE[0]}"
SCRIPT_PATH="$(readlink -f "$SCRIPT_SOURCE" 2>/dev/null || printf '%s' "$SCRIPT_SOURCE")"
SCRIPT_DIR="$(cd "$(dirname "$SCRIPT_PATH")" 2>/dev/null && pwd || pwd)"
RAW_BASE_URL="https://raw.githubusercontent.com/${_GIT_PROFILE:-${GIT_Profile:-vonschutter}}/RTD-Setup/main"
BACKEND_URL="${RAW_BASE_URL}/modules/system-user-backup.mod/rtd-oem-backup-linux-config"
GTK_FRONTEND_NAME="user-backup-gtk.py"
GTK_FRONTEND="${SCRIPT_DIR}/${GTK_FRONTEND_NAME}"
GTK_FRONTEND_URL="${RAW_BASE_URL}/modules/system-user-backup.mod/${GTK_FRONTEND_NAME}"
RTD_CACHE_DIR="${XDG_CACHE_HOME:-${HOME:-/tmp}/.cache}/rtd/system-user-backup"
DEFAULT_COMPRESSION_LEVEL=10
BACKUP_USER="${SUDO_USER:-${USER:-$(id -un)}}"
USER_HOME="${HOME:-}"
if [[ ${EUID:-1} -eq 0 && -n "${SUDO_USER:-}" ]]; then
	USER_HOME="$(getent passwd "$SUDO_USER" | cut -d: -f6)"
fi

declare -a SELECTED_PROFILES=()
declare -a SOURCE_PATHS=()
declare -a SOURCE_LABELS=()
declare -a EXCLUDES=()
declare -a GENERATED_PATHS=()
DESTINATION=""
PASSPHRASE_FILE=""
COMPRESSION_LEVEL="$DEFAULT_COMPRESSION_LEVEL"
GUI_BACKEND="$SCRIPT_PATH"
NO_GUI=0
FORCE_GUI=0
ACTION=""

#::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::
#:: RTD Library Bootstrap
#::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::

rtd::bootstrap_library() {
	local library_name="${1:-_rtd_library}" path tmp rc
	for path in \
		"${SCRIPT_DIR}/${library_name}" \
		"${SCRIPT_DIR}/../core/${library_name}" \
		"${SCRIPT_DIR}/../../core/${library_name}" \
		"/opt/rtd/core/${library_name}" \
		"${HOME:-}/GIT/RTD-Setup/core/${library_name}" \
		"${HOME:-}/RTD-Setup/core/${library_name}"; do
		[[ -r "$path" ]] || continue
		# shellcheck source=/dev/null
		source "$path" "" >/dev/null 2>&1
		declare -F system::log_item >/dev/null 2>&1 && return 0
	done
	tmp="$(mktemp "/tmp/${library_name}.XXXXXX")" || return 1
	rc=0
	if command -v curl >/dev/null 2>&1; then
		curl -fsSL "${RAW_BASE_URL}/core/${library_name}" -o "$tmp" || rc=$?
	elif command -v wget >/dev/null 2>&1; then
		wget -qO "$tmp" "${RAW_BASE_URL}/core/${library_name}" || rc=$?
	else
		rc=1
	fi
	if (( rc == 0 )); then
		# shellcheck source=/dev/null
		source "$tmp" "" >/dev/null 2>&1
		declare -F system::log_item >/dev/null 2>&1 || rc=1
	fi
	rm -f "$tmp"
	return "$rc"
}

#::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::
#:: Logging Helpers
#::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::

log_info() { command -v write_information >/dev/null 2>&1 && write_information "$*" || printf '%s\n' "$*"; }
log_status() { command -v write_status >/dev/null 2>&1 && write_status "$*" || printf '%s\n' "$*"; }
log_warn() { command -v write_warning >/dev/null 2>&1 && write_warning "$*" || printf 'Warning: %s\n' "$*" >&2; }
log_error() { command -v write_error >/dev/null 2>&1 && write_error "$*" || printf 'Error: %s\n' "$*" >&2; }

#::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::
#:: Dependency Helpers
#::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::

ensure_rtd_library() {
	rtd::bootstrap_library "_rtd_library"
}

ensure_commands() {
	local missing=() cmd
	ensure_rtd_library >/dev/null 2>&1 || true
	if declare -F dependency::command_exists >/dev/null 2>&1; then
		dependency::command_exists --auto "$@"
		return $?
	fi
	for cmd in "$@"; do
		command -v "$cmd" >/dev/null 2>&1 || missing+=("$cmd")
	done
	if [[ ${#missing[@]} -gt 0 ]]; then
		log_error "Missing required command(s): ${missing[*]}"
		return 1
	fi
}

ensure_backup_dependencies() {
	ensure_commands tar zstd gpg sha256sum du mktemp pv
}

ensure_estimate_dependencies() {
	ensure_commands du mktemp awk
}

ensure_profile_dependency() {
	local command_name="$1"
	ensure_rtd_library >/dev/null 2>&1 || true
	if declare -F dependency::command_exists >/dev/null 2>&1; then
		dependency::command_exists --auto "$command_name" >/dev/null 2>&1 || return 1
	else
		command -v "$command_name" >/dev/null 2>&1 || return 1
	fi
}

install_gui_dependencies() {
	local distro
	ensure_rtd_library >/dev/null 2>&1 || return 1
	declare -F software::check_native_package_dependency >/dev/null 2>&1 || return 1
	declare -F system::distribution_type >/dev/null 2>&1 && distro="$(system::distribution_type 2>/dev/null || true)"
	case "$distro" in
		fedora|redhat) software::check_native_package_dependency python3 python3-gobject gtk3 ;;
		suse) software::check_native_package_dependency python3 python3-gobject-Gdk typelib-1_0-Gtk-3_0 ;;
		*) software::check_native_package_dependency python3 python3-gi gir1.2-gtk-3.0 ;;
	esac
}

fetch_remote_file() {
	local url="$1" dest="$2" tmp="${dest}.tmp.$$"
	mkdir -p "$(dirname "$dest")" || return 1
	if command -v curl >/dev/null 2>&1; then
		curl -fsSL "$url" -o "$tmp" || { rm -f "$tmp"; return 1; }
	elif command -v wget >/dev/null 2>&1; then
		wget -qO "$tmp" "$url" || { rm -f "$tmp"; return 1; }
	else
		ensure_commands curl || ensure_commands wget || return 1
		fetch_remote_file "$url" "$dest"
		return $?
	fi
	mv "$tmp" "$dest" || return 1
	chmod 0700 "$dest" 2>/dev/null || true
}

resolve_gtk_frontend() {
	local candidate
	for candidate in \
		"${SCRIPT_DIR}/${GTK_FRONTEND_NAME}" \
		"/opt/rtd/modules/system-user-backup.mod/${GTK_FRONTEND_NAME}" \
		"/opt/RTD-Setup/modules/system-user-backup.mod/${GTK_FRONTEND_NAME}" \
		"${HOME:-}/GIT/RTD-Setup/modules/system-user-backup.mod/${GTK_FRONTEND_NAME}" \
		"${HOME:-}/RTD-Setup/modules/system-user-backup.mod/${GTK_FRONTEND_NAME}"; do
		[[ -r "$candidate" ]] || continue
		GTK_FRONTEND="$candidate"
		return 0
	done
	candidate="${RTD_CACHE_DIR}/${GTK_FRONTEND_NAME}"
	if [[ ! -r "$candidate" ]]; then
		log_info "Fetching GTK frontend: ${GTK_FRONTEND_URL}"
		fetch_remote_file "$GTK_FRONTEND_URL" "$candidate" || return 1
	fi
	GTK_FRONTEND="$candidate"
}

resolve_gui_backend() {
	local cached="${RTD_CACHE_DIR}/rtd-oem-backup-linux-config"
	case "$SCRIPT_PATH" in
		/dev/fd/*|/proc/*/fd/*)
			mkdir -p "$RTD_CACHE_DIR" || return 1
			if [[ -r "$SCRIPT_PATH" ]]; then
				cp "$SCRIPT_PATH" "$cached" || return 1
			else
				fetch_remote_file "$BACKEND_URL" "$cached" || return 1
			fi
			chmod 0700 "$cached" 2>/dev/null || true
			GUI_BACKEND="$cached"
			;;
		*)
			GUI_BACKEND="$SCRIPT_PATH"
			;;
	esac
}

#::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::
#:: Usage
#::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::

usage() {
	cat <<EOF
Usage:
  $(basename "$0") [--gui|--no-gui]
  $(basename "$0") --list-profiles
  $(basename "$0") --estimate --profiles <csv> [--user-home <path>]
  $(basename "$0") --backup --profiles <csv> --destination <dir> --passphrase-file <file> [options]

Options:
  --profiles <csv>          Comma-separated profile ids to back up.
  --destination <dir>       Destination directory for backup archives.
  --passphrase-file <file>  File containing the encryption passphrase.
  --compression-level <n>   zstd level 1-19, default ${DEFAULT_COMPRESSION_LEVEL}.
  --user-home <path>        User home to back up, useful when run through pkexec.
  --backup-user <name>      Username to include in archive metadata.
  --gui                     Force GTK frontend.
  --no-gui                  Force command-line backend behavior.
  -h, --help                Show this help.
EOF
}

#::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::
#:: Profile Definitions
#::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::

profile_rows() {
	cat <<'EOF'
documents	Personal documents	~/Documents	false
pictures	Pictures	~/Pictures	false
desktop	Desktop files	~/Desktop	false
downloads	Downloads	~/Downloads	false
gnome	GNOME desktop settings	dconf dump plus GNOME config	false
keyring	GNOME credentials and keyrings	~/.local/share/keyrings and ~/.gnupg	false
remmina	Remmina configuration	Remmina config and connection files	false
themes	User themes	~/.themes	false
icons	User icons	~/.icons and ~/.local/share/icons	false
fonts	User fonts	~/.fonts and ~/.local/share/fonts	false
firefox	Firefox profiles	~/.mozilla/firefox	false
chrome	Chrome profiles	~/.config/google-chrome	false
virtualbox	VirtualBox virtual machines	~/VirtualBox VMs	false
