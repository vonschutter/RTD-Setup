}

#::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::
#:: Source Selection
#::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::

expand_path() {
	local path="$1"
	case "$path" in
		"~") printf '%s' "$USER_HOME" ;;
		\~/*) printf '%s/%s' "$USER_HOME" "${path#\~/}" ;;
		*) printf '%s' "$path" ;;
	esac
}

add_existing_source() {
	local label="$1" path="$2" expanded
	expanded="$(expand_path "$path")"
	if [[ -e "$expanded" ]]; then
		SOURCE_LABELS+=("$label")
		SOURCE_PATHS+=("$expanded")
	else
		log_warn "Skipping missing source for ${label}: ${expanded}"
	fi
}

add_common_excludes() {
	local rel_home="${USER_HOME#/}"
	EXCLUDES+=(
		"--exclude=${rel_home}/.cache"
		"--exclude=${rel_home}/.local/share/Trash"
		"--exclude=${rel_home}/.thumbnails"
		"--exclude=${rel_home}/.var/app/*/cache"
		"--exclude=*.7z"
		"--exclude=*.tar"
		"--exclude=*.tar.zst"
		"--exclude=*.tar.zst.gpg"
	)
}

prepare_profile_sources() {
	local profile staging_dir="$1" dconf_file domains_file
	SOURCE_PATHS=()
	SOURCE_LABELS=()
	GENERATED_PATHS=()
	EXCLUDES=()
	add_common_excludes

	for profile in "${SELECTED_PROFILES[@]}"; do
		case "$profile" in
			documents) add_existing_source "documents" "~/Documents" ;;
			pictures) add_existing_source "pictures" "~/Pictures" ;;
			desktop) add_existing_source "desktop" "~/Desktop" ;;
			downloads) add_existing_source "downloads" "~/Downloads" ;;
			gnome)
				add_existing_source "gnome-config" "~/.config/gnome-session"
				add_existing_source "gtk-config" "~/.config/gtk-3.0"
				add_existing_source "gtk4-config" "~/.config/gtk-4.0"
				if ensure_profile_dependency dconf; then
					dconf_file="${staging_dir}/RTD_BACKUP_METADATA/generated/dconf-settings.ini"
					mkdir -p "$(dirname "$dconf_file")"
					if sudo -u "$BACKUP_USER" dconf dump / >"$dconf_file" 2>/dev/null || dconf dump / >"$dconf_file" 2>/dev/null; then
						GENERATED_PATHS+=("$dconf_file")
					fi
				fi
				;;
			keyring)
				add_existing_source "gnome-keyrings" "~/.local/share/keyrings"
				add_existing_source "gnupg" "~/.gnupg"
				;;
			remmina)
				add_existing_source "remmina-data" "~/.local/share/remmina"
				add_existing_source "remmina-config" "~/.config/remmina"
				;;
			themes) add_existing_source "themes" "~/.themes" ;;
			icons)
				add_existing_source "icons" "~/.icons"
				add_existing_source "local-icons" "~/.local/share/icons"
				;;
			fonts)
				add_existing_source "fonts" "~/.fonts"
				add_existing_source "local-fonts" "~/.local/share/fonts"
				;;
			firefox) add_existing_source "firefox" "~/.mozilla/firefox" ;;
			chrome) add_existing_source "chrome" "~/.config/google-chrome" ;;
			virtualbox) add_existing_source "virtualbox" "~/VirtualBox VMs" ;;
			teamviewer) add_existing_source "teamviewer" "~/.config/teamviewer" ;;
			home) add_existing_source "home" "~" ;;
			kvm)
				if [[ ${EUID:-1} -ne 0 ]]; then
					log_error "The kvm profile requires root privileges. Run from the GTK frontend with authorization or use sudo."
					return 1
				fi
				add_existing_source "libvirt" "/var/lib/libvirt"
				if ensure_profile_dependency virsh; then
					domains_file="${staging_dir}/RTD_BACKUP_METADATA/generated/libvirt-domains"
					mkdir -p "$domains_file"
					while IFS= read -r domain; do
						[[ -n "$domain" ]] || continue
						virsh dumpxml "$domain" >"${domains_file}/${domain}.xml" 2>/dev/null || true
					done < <(virsh list --all --name 2>/dev/null)
					GENERATED_PATHS+=("$domains_file")
				fi
				;;
			*) log_warn "Unknown backup profile ignored: $profile" ;;
		esac
	done
}

#::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::
#:: Argument Helpers
#::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::

csv_to_profiles() {
	local csv="$1" item
	SELECTED_PROFILES=()
	IFS=',' read -r -a SELECTED_PROFILES <<<"$csv"
	for item in "${!SELECTED_PROFILES[@]}"; do
		SELECTED_PROFILES[$item]="${SELECTED_PROFILES[$item]//[[:space:]]/}"
	done
}

#::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::
#:: Estimate
#::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::

estimate_bytes() {
	local staging_dir total=0 path size
	ensure_estimate_dependencies >/dev/null 2>&1 || return 1
	staging_dir="$(mktemp -d)" || return 1
	prepare_profile_sources "$staging_dir" || { rm -rf "$staging_dir"; return 1; }
	for path in "${SOURCE_PATHS[@]}" "${GENERATED_PATHS[@]}"; do
		[[ -e "$path" ]] || continue
		size="$(du -sb "$path" 2>/dev/null | awk '{print $1}')"
		[[ "$size" =~ ^[0-9]+$ ]] && total=$((total + size))
	done
	rm -rf "$staging_dir"
	printf '%s\n' "$total"
}

#::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::
#:: Metadata
#::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::

json_escape() {
	local s="$1"
	s="${s//\\/\\\\}"
	s="${s//\"/\\\"}"
	s="${s//$'\n'/\\n}"
	printf '%s' "$s"
}

write_manifest() {
	local staging_dir="$1" manifest="$1/RTD_BACKUP_METADATA/manifest.json" profile path first=1
	mkdir -p "$(dirname "$manifest")"
	{
		printf '{\n'
		printf '  "tool": "rtd-oem-backup-linux-config",\n'
		printf '  "version": "%s",\n' "$(json_escape "$SCRIPT_VERSION")"
		printf '  "created_utc": "%s",\n' "$(date -u --iso-8601=seconds)"
		printf '  "hostname": "%s",\n' "$(json_escape "$(hostname)")"
		printf '  "backup_user": "%s",\n' "$(json_escape "$BACKUP_USER")"
		printf '  "user_home": "%s",\n' "$(json_escape "$USER_HOME")"
		printf '  "profiles": ['
		for profile in "${SELECTED_PROFILES[@]}"; do
			[[ $first -eq 0 ]] && printf ', '
			printf '"%s"' "$(json_escape "$profile")"
			first=0
		done
		printf '],\n'
		printf '  "sources": [\n'
		first=1
		for path in "${SOURCE_PATHS[@]}" "${GENERATED_PATHS[@]}"; do
			[[ -e "$path" ]] || continue
			[[ $first -eq 0 ]] && printf ',\n'
			printf '    "%s"' "$(json_escape "$path")"
			first=0
		done
		printf '\n  ]\n'
		printf '}\n'
	} >"$manifest"
	GENERATED_PATHS+=("$manifest")
}

#::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::
#:: Backup Creation
#::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::

create_backup() {
	local staging_dir archive_base archive_path checksum_path passphrase estimate_bytes_value tar_rc passphrase path rel
	local -a rel_paths=()
	[[ -d "$DESTINATION" ]] || { log_error "Destination does not exist: $DESTINATION"; return 1; }
	[[ -w "$DESTINATION" ]] || { log_error "Destination is not writable: $DESTINATION"; return 1; }
	[[ -r "$PASSPHRASE_FILE" ]] || { log_error "Passphrase file is not readable."; return 1; }
	[[ "$COMPRESSION_LEVEL" =~ ^[0-9]+$ && "$COMPRESSION_LEVEL" -ge 1 && "$COMPRESSION_LEVEL" -le 19 ]] ||
		{ log_error "Compression level must be an integer from 1 to 19."; return 1; }
	ensure_backup_dependencies || { log_error "Required backup software could not be installed or found."; return 1; }

	staging_dir="$(mktemp -d)" || return 1
	trap 'rm -rf "$staging_dir"' RETURN
	prepare_profile_sources "$staging_dir" || return 1
	[[ ${#SOURCE_PATHS[@]} -gt 0 || ${#GENERATED_PATHS[@]} -gt 0 ]] || { log_error "No existing backup sources were selected."; return 1; }
	write_manifest "$staging_dir"
	for path in "${SOURCE_PATHS[@]}"; do
		[[ -e "$path" && "$path" = /* ]] || continue
		rel="${path#/}"
		rel_paths+=("$rel")
	done

	archive_base="${BACKUP_USER}-backup-$(date -u +%Y%m%dT%H%M%SZ)"
	archive_path="${DESTINATION%/}/${archive_base}.tar.zst.gpg"
	checksum_path="${archive_path}.sha256"
	estimate_bytes_value="$(estimate_bytes 2>/dev/null || echo 0)"
	passphrase="$(<"$PASSPHRASE_FILE")"

	log_status "Creating encrypted backup archive: $archive_path"
	printf 'RTD_PROGRESS phase=backup percent=5 current=%q\n' "Preparing archive"

	{
		tar -C / "${EXCLUDES[@]}" --ignore-failed-read --warning=no-file-changed --xattrs --acls --sparse -cf - "${rel_paths[@]}" -C "$staging_dir" RTD_BACKUP_METADATA |
			pv -s "${estimate_bytes_value:-0}" 2>/dev/null |
			zstd -T0 -"${COMPRESSION_LEVEL}" |
			gpg --batch --yes --pinentry-mode loopback --passphrase-fd 3 --symmetric --cipher-algo AES256 -o "$archive_path" - 3<<<"$passphrase"
	} || tar_rc=$?
	unset passphrase
	[[ ${tar_rc:-0} -eq 0 ]] || { log_error "Backup archive creation failed."; rm -f "$archive_path"; return 1; }

	printf 'RTD_PROGRESS phase=backup percent=90 current=%q\n' "Writing checksum"
	sha256sum "$archive_path" >"$checksum_path" || return 1
	chmod 0600 "$archive_path" "$checksum_path" 2>/dev/null || true
	printf 'RTD_PROGRESS phase=backup percent=100 current=%q\n' "Backup complete"
	log_info "Backup complete: $archive_path"
	log_info "Checksum: $checksum_path"
}

#::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::
#:: GTK Frontend
#::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::

gtk_frontend_ready() {
	command -v python3 >/dev/null 2>&1 &&
		python3 -c 'import gi; gi.require_version("Gtk", "3.0"); from gi.repository import Gtk' >/dev/null 2>&1
}

launch_gui() {
	resolve_gtk_frontend || { log_error "GTK frontend not found and could not be fetched."; return 1; }
	resolve_gui_backend || { log_error "Unable to prepare backend launcher for GTK frontend."; return 1; }
	gtk_frontend_ready || {
		install_gui_dependencies || true
	}
	gtk_frontend_ready || { log_error "Python GTK 3 bindings are required."; return 1; }
	exec env RTD_USER_BACKUP_BACKEND="$GUI_BACKEND" python3 "$GTK_FRONTEND"
}

#::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::
#:: Argument Parsing
#::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::

parse_args() {
	while [[ $# -gt 0 ]]; do
		case "$1" in
			-h|--help) usage; exit 0 ;;
			--gui) FORCE_GUI=1; shift ;;
			--no-gui) NO_GUI=1; shift ;;
			--list-profiles) ACTION="list"; shift ;;
			--estimate) ACTION="estimate"; shift ;;
			--backup) ACTION="backup"; shift ;;
			--profiles) csv_to_profiles "${2:-}"; shift 2 ;;
			--destination) DESTINATION="${2:-}"; shift 2 ;;
			--passphrase-file) PASSPHRASE_FILE="${2:-}"; shift 2 ;;
			--compression-level) COMPRESSION_LEVEL="${2:-$DEFAULT_COMPRESSION_LEVEL}"; shift 2 ;;
			--user-home) USER_HOME="${2:-$USER_HOME}"; shift 2 ;;
			--backup-user) BACKUP_USER="${2:-$BACKUP_USER}"; shift 2 ;;
			*) log_error "Unknown option: $1"; usage; return 1 ;;
		esac
	done
}

