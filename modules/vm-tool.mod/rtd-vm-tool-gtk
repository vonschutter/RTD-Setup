main() {
	if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
		cat <<EOF
Usage:
  $(basename "$0") [options]

Description:
  Open the GTK front-end for the RTD VM Tool. Menu navigation uses Zenity and
  selected workflows execute through the existing terminal VM backend.

Options:
  --sysprep                 Run virt-sysprep after cloning templates that support it.
  --customize <spec|script> Pass virt-customize options or script path to clone workflows.
  --trace                   Enable RTD_VM_TOOL_TRACE for terminal-backed actions.
  --about                   Show GTK about information and exit.
  --help, -h                Show this help text.
EOF
		exit 0
	fi

	command -v zenity >/dev/null 2>&1 || {
		printf 'Missing required command: zenity\n' >&2
		exit 1
	}

	if [[ "${1:-}" == "--about" || "${1:-}" == "about" ]]; then
		vmtoolgtk::show_about
		exit 0
	fi

	RTD_VM_TUI_SCRIPT="$(vmtoolgtk::find_tui_script)" || {
		vmtoolgtk::show_error "Unable to locate the companion rtd-vm-tool script."
		exit 1
	}

	local restore_nounset=0
	case "$-" in
		*u*) restore_nounset=1; set +u ;;
	esac
	# shellcheck source=/dev/null
	source "${RTD_VM_TUI_SCRIPT}"

	vmtoolgtk::parse_args "$@" || exit 1

	if ! rtd::bootstrap_library "_rtd_library"; then
		vmtoolgtk::show_error "Failed to load _rtd_library."
		exit 1
	fi
	(( restore_nounset )) && set -u

	# Preserve the original GTK options when the library re-executes this script
	# through pkexec or sudo.
	vmtoolgtk::with_legacy_nounset security::ensure_admin "$@" || exit 1

	if [[ -z "${DISPLAY:-}" && -z "${WAYLAND_DISPLAY:-}" ]]; then
		vmtoolgtk::show_error "No graphical session detected."
		exit 1
	fi

	vmtoolgtk::with_legacy_nounset vmtool::refresh_backtitle
	vmtoolgtk::show_main_menu
}

main "$@"
