		selection="$(vmtoolgtk::show_menu \
			"${VMTOOLGTK_TITLE} v${VMTOOLGTK_VERSION}" \
			"Select a VM management task. Terminal-backed workflows open in a new terminal window." \
			1020 560 \
			"1" "✨ Deploy Server VM's" "Clone a server template into a working VM." \
			"2" "✨ Deploy Virtual Desktop VM's" "Clone a VDI template into a working VM." \
			"3" "💿 Create VM Templates" "Open server and VDI template menus." \
			"4" "⚡ Start / Stop VM's" "Manage VM power state." \
