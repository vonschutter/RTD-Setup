set -u

: "${VMTOOLGTK_VERSION:=0.1}"
: "${VMTOOLGTK_TITLE:=RunTime Data: VM Tool GTK}"

RTD_VM_TUI_SCRIPT=""
RTD_VM_TOOL_TRACE=0

vmtoolgtk::find_tui_script() {
	local script_dir candidate

	script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
	for candidate in \
		"${script_dir}/rtd-vm-tool" \
		"/opt/rtd/modules/vm-tool.mod/rtd-vm-tool" \
		"${HOME:-}/GIT/RTD-Setup/modules/vm-tool.mod/rtd-vm-tool" \
		"${HOME:-}/RTD-Setup/modules/vm-tool.mod/rtd-vm-tool"
	do
		if [[ -r "${candidate}" ]]; then
			printf '%s\n' "${candidate}"
			return 0
		fi
	done

	return 1
}

vmtoolgtk::show_error() {
	local message="$1"
	if command -v zenity >/dev/null 2>&1; then
		zenity --error --title "${VMTOOLGTK_TITLE}" --width 640 --text "${message}"
	else
		printf 'ERROR: %s\n' "${message}" >&2
	fi
}

vmtoolgtk::show_info() {
	local message="$1"
	zenity --info --title "${VMTOOLGTK_TITLE}" --width 720 --text "${message}"
}

vmtoolgtk::show_about() {
	zenity --info \
		--title "${VMTOOLGTK_TITLE}" \
		--width 760 \
		--height 520 \
		--no-wrap \
		--text "<span size='large'><b>${VMTOOLGTK_TITLE}</b></span>

A GTK menu front-end for the RTD VM tool.

This interface mirrors the main menu tree from the terminal VM tool:
- Deploy Server VM's
- Deploy Virtual Desktop VM's
- Create VM Templates
- Start / Stop VM's
- Tool Settings
- Maintenance

Selected tasks are executed through the existing RTD VM backend in a terminal window so the existing installer and VM workflows remain intact."
}

vmtoolgtk::show_menu() {
	local title="$1"
	local text="$2"
	local width="${3:-980}"
	local height="${4:-640}"
	shift 4

	zenity --list \
		--title "${title}" \
		--text "${text}" \
		--width "${width}" \
		--height "${height}" \
		--column "ID" \
		--column "Action" \
		--column "Details" \
		--hide-column=1 \
		--print-column=1 \
		"$@"
}

vmtoolgtk::find_terminal_emulator() {
	local candidate
	for candidate in x-terminal-emulator gnome-terminal kgx tilix xfce4-terminal mate-terminal konsole xterm; do
		if command -v "${candidate}" >/dev/null 2>&1; then
			printf '%s\n' "${candidate}"
			return 0
		fi
	done

	return 1
}

vmtoolgtk::launch_terminal_payload() {
	local title="$1"
	local payload="$2"
	local terminal

	terminal="$(vmtoolgtk::find_terminal_emulator)" || {
		vmtoolgtk::show_error "No supported terminal emulator was found. Install x-terminal-emulator, gnome-terminal, kgx, tilix, xfce4-terminal, mate-terminal, konsole, or xterm."
		return 1
	}

	case "${terminal}" in
		gnome-terminal|tilix|xfce4-terminal|mate-terminal)
			"${terminal}" --title="${title}" -- bash -lc "${payload}"
			;;
		kgx)
			"${terminal}" --title="${title}" bash -lc "${payload}"
			;;
		konsole)
			"${terminal}" --new-tab -p tabtitle="${title}" -e bash -lc "${payload}"
			;;
		x-terminal-emulator)
			"${terminal}" -e bash -lc "${payload}"
			;;
		xterm)
			"${terminal}" -T "${title}" -e bash -lc "${payload}"
			;;
		*)
			"${terminal}" -e bash -lc "${payload}"
			;;
	esac
}

vmtoolgtk::launch_tui_action() {
	local title="$1"
	local action_snippet="$2"
	local payload

	printf -v payload 'source %q; RTD_GUI=dialog; export RTD_GUI RTD_VM_TOOL_TRACE; rtd::bootstrap_library %q || exit 1; vmtool::refresh_backtitle; %s; rc=$?; printf "\\nExit status: %%s\\n" "$rc"; if [[ -t 0 ]]; then read -r -p "Press Enter to close..." _; fi; exit "$rc"' \
		"${RTD_VM_TUI_SCRIPT}" \
		"_rtd_library" \
		"${action_snippet}"

	vmtoolgtk::launch_terminal_payload "${title}" "${payload}"
}

