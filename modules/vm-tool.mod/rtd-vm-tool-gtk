#!/usr/bin/env bash
#
#::                                       A D M I N   T O O L
#::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::
#:::::::::::::::::::::::::::::::::::::::::::::// RTD VM Tool GTK //::::::::::::::::::::::::::::::::::::// Linux //:::::::
#:: Author(s):    RTD
#:: Version:      0.1
#::
#:: Purpose:      Provide a GTK front-end for the RTD VM Tool menu tree.
#::               Menu navigation is handled through Zenity and the selected
#::               task is executed in a terminal-backed TUI/backend session.
#::
#:: Usage:        Run without arguments to open the GTK VM menu.
#::               Use --help to display a short help text.
#::
#::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::

set -u

: "${VMTOOLGTK_VERSION:=0.1}"
: "${VMTOOLGTK_TITLE:=RunTime Data: VM Tool GTK}"

RTD_VM_TUI_SCRIPT=""
RTD_VM_TOOL_TRACE=0
RTD_VM_GTK_ACTION_LOG="/var/log/rtd/rtd-vm-tool-gtk-actions.log"
: "${RTD_VM_GTK_TERMINAL_GEOMETRY:=132x42}"
: "${RTD_VM_GTK_XTERM_FONT_SIZE:=14}"
declare -a RTD_VM_CLONE_ARGS=()

vmtoolgtk::find_tui_script() {
	local script_dir candidate

	script_dir="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"
	for candidate in \
		"${script_dir}/rtd-vm-tool" \
		"/opt/rtd/modules/vm-tool.mod/rtd-vm-tool" \
		"${HOME:-}/GIT/RTD-Setup/modules/vm-tool.mod/rtd-vm-tool" \
		"${HOME:-}/RTD-Setup/modules/vm-tool.mod/rtd-vm-tool"
	do
		if [[ -r "${candidate}" ]]; then
			printf '%s\n' "${candidate}"
			return 0
		fi
	done

	return 1
}

vmtoolgtk::show_error() {
	local message="$1"
	if command -v zenity >/dev/null 2>&1; then
		zenity --error --title "${VMTOOLGTK_TITLE}" --width 640 --text "${message}"
	else
		printf 'ERROR: %s\n' "${message}" >&2
	fi
}

vmtoolgtk::show_info() {
	local message="$1"
	zenity --info --title "${VMTOOLGTK_TITLE}" --width 720 --text "${message}"
}

vmtoolgtk::log() {
	local message="$1"
	local logfile="${_LOGFILE:-/var/log/rtd/rtd-vm-tool-gtk.log}"

	printf '%(%Y/%m/%d %H:%M:%S)T rtd-vm-tool-gtk: %s\n' -1 "${message}" >>"${logfile}" 2>/dev/null || true
}

vmtoolgtk::with_legacy_nounset() {
	local restore_nounset=0
	local rc

	case "$-" in
		*u*) restore_nounset=1; set +u ;;
	esac

	"$@"
	rc=$?

	(( restore_nounset )) && set -u
	return "${rc}"
}

vmtoolgtk::prompt_yes_no() {
	local title="$1"
	local message="$2"

	zenity --question \
		--title "${title}" \
		--width 560 \
		--text "${message}"
}

vmtoolgtk::show_about() {
	zenity --info \
		--title "${VMTOOLGTK_TITLE}" \
		--width 760 \
		--height 520 \
		--no-wrap \
		--text "<span size='large'><b>${VMTOOLGTK_TITLE}</b></span>

A GTK menu front-end for the RTD VM tool.

This interface mirrors the main menu tree from the terminal VM tool:
- Deploy Server VM's
- Deploy Virtual Desktop VM's
- Create VM Templates
- Start / Stop VM's
- Tool Settings
- Maintenance

Clone deployment uses GTK dialogs for template selection and optional CI/CD settings.
Template creation, settings, and maintenance workflows still open the existing backend in a terminal window where those workflows require it."
}

vmtoolgtk::show_menu() {
	local title="$1"
	local text="$2"
	local width="${3:-980}"
	local height="${4:-640}"
	shift 4

	zenity --list \
		--title "${title}" \
		--text "${text}" \
		--width "${width}" \
		--height "${height}" \
		--column "ID" \
		--column "Action" \
		--column "Details" \
		--cancel-label "Back" \
		--hide-column=1 \
		--print-column=1 \
		"$@"
}

vmtoolgtk::find_terminal_emulator() {
	local candidate

	while IFS= read -r candidate; do
		printf '%s\n' "${candidate}"
		return 0
	done < <(vmtoolgtk::terminal_candidates)

	return 1
}

vmtoolgtk::terminal_candidates() {
	local candidate
	local -a candidates

	if [[ "${EUID}" -eq 0 ]]; then
		candidates=(gnome-terminal konsole xterm uxterm lxterm xfce4-terminal mate-terminal kgx tilix x-terminal-emulator)
	else
		candidates=(gnome-terminal konsole kgx tilix xfce4-terminal mate-terminal xterm uxterm lxterm x-terminal-emulator)
	fi

	for candidate in "${candidates[@]}"; do
		if vmtoolgtk::terminal_is_usable "${candidate}"; then
			printf '%s\n' "${candidate}"
		fi
	done
}

vmtoolgtk::terminal_is_usable() {
	local terminal="$1"

	command -v "${terminal}" >/dev/null 2>&1 || return 1

	case "${terminal}" in
		gnome-terminal)
			# GNOME Terminal needs a session bus. In sudo/root launches, wrap it
			# with dbus-run-session when available; otherwise skip it if neither
			# dbus-run-session nor dbus-launch exists.
			if [[ "${EUID}" -eq 0 ]]; then
				command -v dbus-run-session >/dev/null 2>&1 || command -v dbus-launch >/dev/null 2>&1
				return $?
			fi
			;;
	esac

	return 0
}

vmtoolgtk::find_terminal_font() {
	local font matched
	local -a preferred_fonts=(
		"JetBrainsMono Nerd Font"
		"CaskaydiaMono Nerd Font"
		"CaskaydiaCove Nerd Font"
		"MesloLGS NF"
		"Hack Nerd Font"
		"FiraCode Nerd Font"
		"Symbols Nerd Font Mono"
		"DejaVu Sans Mono"
	)

	if command -v fc-match >/dev/null 2>&1; then
		for font in "${preferred_fonts[@]}"; do
			matched="$(fc-match -f '%{family[0]}' "${font}" 2>/dev/null || true)"
			if [[ "${matched}" == "${font}" ]]; then
				printf '%s\n' "${font}"
				return 0
			fi
		done
	fi

	printf '%s\n' "monospace"
}

vmtoolgtk::parse_args() {
	while [[ $# -gt 0 ]]; do
		case "$1" in
			--sysprep)
				RTD_VM_CLONE_ARGS+=("--sysprep")
				shift
				;;
			--customize)
				if [[ -z "${2:-}" ]]; then
					vmtoolgtk::show_error "--customize requires an argument specifying virt-customize options or a script path."
					return 1
				fi
				RTD_VM_CLONE_ARGS+=("--customize" "$2")
				shift 2
				;;
			--trace)
				RTD_VM_TOOL_TRACE=1
				export RTD_VM_TOOL_TRACE
				shift
				;;
			*)
				vmtoolgtk::show_error "Unknown option: $1"
				return 1
				;;
		esac
	done
}

vmtoolgtk::launch_terminal_payload() {
	local title="$1"
	local payload="$2"
	local terminal terminal_geometry xterm_font xterm_font_size rc runner
	local -a attempted_terminals=()

	terminal_geometry="${RTD_VM_GTK_TERMINAL_GEOMETRY:-132x42}"
	runner=$(mktemp "${TMPDIR:-/tmp}/rtd-vm-tool-gtk.XXXXXX") || {
		vmtoolgtk::show_error "Unable to create the temporary terminal action runner. Check that ${TMPDIR:-/tmp} is writable."
		return 1
	}
	if ! printf '#!/usr/bin/env bash\nrm -f -- "$0"\n%s\n' "${payload}" >"${runner}" || ! chmod 700 "${runner}"; then
		rm -f -- "${runner}"
		vmtoolgtk::show_error "Unable to prepare the terminal action runner."
		return 1
	fi
	vmtoolgtk::log "Prepared terminal action runner: ${runner}"

	if ! vmtoolgtk::find_terminal_emulator >/dev/null; then
		rm -f -- "${runner}"
		vmtoolgtk::show_error "No supported terminal emulator was found. Install x-terminal-emulator, gnome-terminal, kgx, tilix, xfce4-terminal, mate-terminal, konsole, or xterm."
		return 1
	fi

	while IFS= read -r terminal; do
		attempted_terminals+=("${terminal}")
		vmtoolgtk::log "Launching terminal-backed action with ${terminal}: ${title}"

		case "${terminal}" in
			gnome-terminal)
				if [[ "${EUID}" -eq 0 && "$(command -v dbus-run-session || true)" ]]; then
					dbus-run-session -- "${terminal}" --wait --geometry="${terminal_geometry}" --title="${title}" -- "${runner}"
				else
					"${terminal}" --geometry="${terminal_geometry}" --title="${title}" -- "${runner}"
				fi
				;;
			tilix)
				"${terminal}" --geometry="${terminal_geometry}" --title="${title}" --command="${runner}"
				;;
			xfce4-terminal)
				"${terminal}" --geometry="${terminal_geometry}" --title="${title}" --command="${runner}"
				;;
			mate-terminal)
				"${terminal}" --geometry="${terminal_geometry}" --title="${title}" -- "${runner}"
				;;
			kgx)
				"${terminal}" --title="${title}" -- "${runner}"
				;;
			konsole)
				"${terminal}" --geometry "${terminal_geometry}" --new-tab -p tabtitle="${title}" -e "${runner}"
				;;
			x-terminal-emulator)
				"${terminal}" -e "${runner}"
				;;
			xterm|uxterm|lxterm)
				xterm_font="$(vmtoolgtk::find_terminal_font)"
				xterm_font_size="${RTD_VM_GTK_XTERM_FONT_SIZE:-14}"
				"${terminal}" -u8 -fa "${xterm_font}" -fs "${xterm_font_size}" -geometry "${terminal_geometry}" -T "${title}" -e "${runner}"
				;;
			*)
				"${terminal}" -e "${runner}"
				;;
		esac
		rc=$?

		if (( rc == 0 )); then
			vmtoolgtk::log "Terminal-backed action launched with ${terminal}: ${title}"
			return 0
		fi

		vmtoolgtk::log "Terminal launch failed with status ${rc}: ${terminal} (${title}); trying next terminal."
	done < <(vmtoolgtk::terminal_candidates)

	rm -f -- "${runner}"
	vmtoolgtk::show_error "Failed to launch the terminal-backed action. Tried: ${attempted_terminals[*]:-none}."
	return 1
}

vmtoolgtk::launch_tui_action() {
	local title="$1"
	local action_snippet="$2"
	local payload clone_args_snippet quoted_clone_args

	if (( ${#RTD_VM_CLONE_ARGS[@]} )); then
		printf -v quoted_clone_args '%q ' "${RTD_VM_CLONE_ARGS[@]}"
	else
		quoted_clone_args=""
	fi
	clone_args_snippet="RTD_VM_CLONE_ARGS=(${quoted_clone_args})"

	vmtoolgtk::log "Selected terminal-backed action: title=${title}; tui=${RTD_VM_TUI_SCRIPT}; action=${action_snippet}"

	printf -v payload 'exec > >(tee -a %q) 2>&1; printf "\\n==== RTD VM GTK action: %%s ====\\n" "$(date "+%%F %%T")"; printf "Title: %%s\\nTUI script: %%s\\nAction: %%s\\n\\n" %q %q %q; source %q || { rc=$?; printf "\\nFailed to source TUI script (status %%s).\\n" "$rc"; if [[ -t 0 ]]; then read -r -p "Press Enter to close..." _; fi; exit "$rc"; }; RTD_GUI=dialog; RTD_VM_TOOL_EMBEDDED_ACTION=1; export RTD_GUI RTD_VM_TOOL_TRACE RTD_VM_TOOL_EMBEDDED_ACTION; rtd::bootstrap_library %q || { rc=$?; printf "\\nFailed to load _rtd_library (status %%s).\\n" "$rc"; if [[ -t 0 ]]; then read -r -p "Press Enter to close..." _; fi; exit "$rc"; }; vmtool::refresh_backtitle; %s; %s; rc=$?; printf "\\nExit status: %%s\\n" "$rc"; if [[ -t 0 ]]; then read -r -p "Press Enter to close..." _; fi; exit "$rc"' \
		"${RTD_VM_GTK_ACTION_LOG}" \
		"${title}" \
		"${RTD_VM_TUI_SCRIPT}" \
		"${action_snippet}" \
		"${RTD_VM_TUI_SCRIPT}" \
		"_rtd_library" \
		"${clone_args_snippet}" \
		"${action_snippet}"

	vmtoolgtk::launch_terminal_payload "${title}" "${payload}"
}

vmtoolgtk::start_stop_vm_menu() {
	if ! command -v virsh >/dev/null 2>&1; then
		vmtoolgtk::show_error "virsh was not found. Install libvirt clients/tools before managing VM power state."
		return 1
	fi

	while true; do
		local -a menu_entries=()
		local vm state label action_hint selection latest_state

		while IFS= read -r vm; do
			[[ -z "${vm}" ]] && continue
			state="$(virsh domstate "${vm}" 2>/dev/null | tr '[:upper:]' '[:lower:]')"
			case "${state}" in
				running)
					label="Running"
					action_hint="Stop"
					;;
				paused)
					label="Paused"
					action_hint="Stop"
					;;
				shut*|off)
					label="Off"
					action_hint="Start"
					;;
				*)
					label="${state:-unknown}"
					action_hint="Toggle"
					;;
			esac
			menu_entries+=("${vm}" "${label}" "${action_hint}")
		done < <(virsh list --all --name | grep -vi '^Template' | sed '/^$/d')

		if (( ${#menu_entries[@]} == 0 )); then
			vmtoolgtk::show_info "No non-Template VMs found to manage."
			return 0
		fi

		selection="$(zenity --list \
			--title "${VMTOOLGTK_TITLE} - Start / Stop VMs" \
			--text "Select a VM to start or stop. Template images are hidden automatically." \
			--width 920 \
			--height 620 \
			--column "VM" \
			--column "State" \
			--column "Action" \
			--print-column=1 \
			--cancel-label "Back" \
			"${menu_entries[@]}")" || return 0

		[[ -z "${selection}" ]] && continue
		state="$(virsh domstate "${selection}" 2>/dev/null | tr '[:upper:]' '[:lower:]')"
		case "${state}" in
			shut*|off|"")
				vmtoolgtk::prompt_yes_no \
					"Start VM" \
					"Start \"${selection}\"?\n\nCurrent state: ${state:-unknown}" || continue
				if virsh start "${selection}"; then
					vmtoolgtk::with_legacy_nounset kvm::wait_for_domain_start --domain "${selection}" --timeout 90 ||
						vmtoolgtk::with_legacy_nounset write_warning "Start signal sent but no start event observed for ${selection}."
					latest_state="$(virsh domstate "${selection}" 2>/dev/null || echo unknown)"
					vmtoolgtk::show_info "Launch requested for \"${selection}\".\n\nLatest state: ${latest_state}"
				else
					vmtoolgtk::show_error "Failed to start \"${selection}\"."
				fi
				;;
			running|paused|pmsuspended*)
				vmtoolgtk::prompt_yes_no \
					"Stop VM" \
					"Stop \"${selection}\" gracefully?\n\nCurrent state: ${state}" || continue
				if virsh shutdown "${selection}"; then
					if vmtoolgtk::with_legacy_nounset vmtool::wait_for_vm_stop "${selection}" 45; then
						vmtoolgtk::show_info "\"${selection}\" is now stopped."
					elif vmtoolgtk::prompt_yes_no \
						"Force Stop?" \
						"\"${selection}\" did not stop within 45 seconds.\n\nForce power off?"; then
						if virsh destroy "${selection}"; then
							vmtoolgtk::show_info "\"${selection}\" was forcefully powered off."
						else
							vmtoolgtk::show_error "Failed to force stop \"${selection}\"."
						fi
					fi
				else
					vmtoolgtk::show_error "Failed to send shutdown signal to \"${selection}\"."
				fi
				;;
			*)
				vmtoolgtk::show_error "Unknown state for \"${selection}\"; cannot toggle automatically."
				;;
		esac
	done
}

vmtoolgtk::select_clone_template() {
	local pattern="$1"
	local title="$2"
	local prompt="$3"
	local empty_message="$4"
	local vm_list template_name
	local -a menu_entries=()

	if ! command -v virsh >/dev/null 2>&1; then
		vmtoolgtk::show_error "virsh was not found. Install libvirt clients/tools before cloning VMs."
		return 1
	fi

	vm_list="$(virsh list --all --name | grep -i '^Template' | grep -Ei -- "${pattern}" || true)"
	if [[ -z "${vm_list}" ]]; then
		vmtoolgtk::show_info "${empty_message}"
		return 1
	fi

	while IFS= read -r template_name; do
		[[ -z "${template_name}" ]] && continue
			menu_entries+=("${template_name}" "$(vmtoolgtk::with_legacy_nounset kvm::clone_template_vm::_display_template_label "${template_name}")")
	done <<< "${vm_list}"

	if (( ${#menu_entries[@]} == 0 )); then
		vmtoolgtk::show_info "${empty_message}"
		return 1
	fi

	zenity --list \
		--title "${title}" \
		--text "${prompt}" \
		--width 1040 \
		--height 560 \
		--column "Template" \
		--column "Details" \
		--print-column=1 \
		--cancel-label "Back" \
		"${menu_entries[@]}"
}

vmtoolgtk::prompt_cicd_options() {
	local task_selection llm_selection llm_models
	local repo_default playbook_default
	local -a task_menu_entries=()
	local -a checklist_entries=()
	local -a mapped_tasks=()
	local -a selected_roles=()

	RTD_CICD_ENABLE=0
	RTD_CICD_REPO="${RTD_ANSIBLE_REPO:-https://github.com/vonschutter/RTD-Ansible.git}"
	RTD_CICD_PLAYBOOK="${RTD_ANSIBLE_PLAYBOOK:-playbooks/server-auto-config.yml}"
	RTD_CICD_TASKS="openssh-server"
	RTD_CICD_LLM_VARIANT="none"
	RTD_CICD_LLM_MODELS=""

	if ! vmtoolgtk::prompt_yes_no "CI/CD" "Seed the cloned server VM with a CI/CD ISO and auto-run ansible-pull on first boot?"; then
		return 0
	fi

	repo_default="${RTD_CICD_REPO}"
	playbook_default="${RTD_CICD_PLAYBOOK}"
	RTD_CICD_REPO="$(zenity --entry \
		--title "CI/CD Settings" \
		--text "Ansible repo URL:" \
		--width 760 \
		--cancel-label "Skip" \
		--entry-text "${repo_default}")" || return 0
	RTD_CICD_REPO="${RTD_CICD_REPO:-$repo_default}"

	RTD_CICD_PLAYBOOK="$(zenity --entry \
		--title "CI/CD Settings" \
		--text "Ansible playbook path:" \
		--width 760 \
		--cancel-label "Skip" \
		--entry-text "${playbook_default}")" || return 0
	RTD_CICD_PLAYBOOK="${RTD_CICD_PLAYBOOK:-$playbook_default}"

	vmtoolgtk::with_legacy_nounset vmtool::ensure_ansible_repo || vmtoolgtk::with_legacy_nounset write_warning "Using fallback CI/CD role menu because RTD-Ansible is not available."
	vmtoolgtk::with_legacy_nounset vmtool::build_server_role_menu task_menu_entries

	local i label desc state checked
	for (( i=0; i<${#task_menu_entries[@]}; i+=3 )); do
		label="${task_menu_entries[i]}"
		desc="${task_menu_entries[i+1]}"
		state="${task_menu_entries[i+2]}"
		checked="FALSE"
		[[ "${state}" == "ON" ]] && checked="TRUE"
		checklist_entries+=("${checked}" "${label}" "${desc}")
	done

	task_selection="$(zenity --list \
		--checklist \
		--title "CI/CD Server Roles" \
		--text "Select server meta-packages to apply." \
		--width 760 \
		--height 520 \
		--separator='|' \
		--column "Apply" \
		--column "Role" \
		--column "Description" \
		--cancel-label "Skip" \
		"${checklist_entries[@]}")" || return 0

	local item mapped
	IFS='|' read -ra selected_roles <<< "${task_selection}"
	for item in "${selected_roles[@]}"; do
		item="${item//\"/}"
		[[ -z "${item}" ]] && continue
		mapped="$(vmtoolgtk::with_legacy_nounset vmtool::map_role_to_server_task "${item}")"
		[[ -n "${mapped}" ]] && mapped_tasks+=("${mapped}")
	done
	if (( ${#mapped_tasks[@]} == 0 )); then
		mapped_tasks=("openssh-server")
	fi
	RTD_CICD_TASKS="$(IFS=','; echo "${mapped_tasks[*]}")"

	llm_selection="$(zenity --list \
		--title "CI/CD LLM Option" \
		--text "Choose an optional LLM stack for the cloned server VM." \
		--width 700 \
		--height 320 \
		--column "ID" \
		--column "Option" \
		--hide-column=1 \
		--print-column=1 \
		--cancel-label "Skip" \
		"none" "No LLM stack" \
		"ollama" "Ollama service" \
		"text-generation-webui" "text-generation-webui")" || llm_selection="none"
	RTD_CICD_LLM_VARIANT="${llm_selection:-none}"

	if [[ "${RTD_CICD_LLM_VARIANT}" == "ollama" ]]; then
		llm_models="$(zenity --entry \
			--title "Ollama Models" \
			--text "Ollama models to pre-pull, comma-separated:" \
			--width 560 \
			--cancel-label "Skip" \
			--entry-text "llama3")" || llm_models=""
		RTD_CICD_LLM_MODELS="${llm_models}"
	else
		RTD_CICD_LLM_MODELS=""
	fi

	RTD_CICD_ENABLE=1
}

vmtoolgtk::run_clone_with_progress() {
	local title="$1"
	local template_name="$2"
	local clone_kind="$3"
	local log_file rc_file pid rc last_line summary created_vm
	shift 3
	local -a clone_args=("$@")

	log_file="$(mktemp "${TMPDIR:-/tmp}/rtd-vm-tool-gtk-clone.XXXXXX.log")" || {
		vmtoolgtk::show_error "Unable to create a temporary clone log."
		return 1
	}
	rc_file="$(mktemp "${TMPDIR:-/tmp}/rtd-vm-tool-gtk-clone.XXXXXX.rc")" || {
		rm -f -- "${log_file}"
		vmtoolgtk::show_error "Unable to create a temporary clone status file."
		return 1
	}
	: > "${rc_file}"

	(
		set +u
		if [[ "${clone_kind}" == "server" ]]; then
			kvm::clone_server_template_vm --template "${template_name}" --post-clone-handler vmtool::post_clone_ansible_pull "${clone_args[@]}"
		else
			kvm::clone_vdi_template_vm --template "${template_name}" "${clone_args[@]}"
		fi
		printf '%s\n' "$?" > "${rc_file}"
	) > "${log_file}" 2>&1 &
	pid=$!

	(
		while kill -0 "${pid}" 2>/dev/null; do
			last_line="$(tail -n 1 "${log_file}" 2>/dev/null || true)"
			printf '# %s\n' "${last_line:-Working...}"
			sleep 1
		done
		printf '100\n'
	) | zenity --progress \
		--title "${title}" \
		--text "Starting clone..." \
		--width 720 \
		--pulsate \
		--auto-close \
		--no-cancel

	wait "${pid}" 2>/dev/null || true
	rc="$(cat "${rc_file}" 2>/dev/null || printf '1')"

	if [[ "${rc}" == "0" ]]; then
		created_vm="$(sed -n 's/.*new VM will be \([^[:space:]]*\).*/\1/p' "${log_file}" | tail -n 1)"
		vmtoolgtk::show_info "Clone completed successfully.${created_vm:+\n\nCreated VM: ${created_vm}}"
		rm -f -- "${log_file}" "${rc_file}"
		return 0
	fi

	summary="$(tail -n 30 "${log_file}" 2>/dev/null || true)"
	vmtoolgtk::show_error "Clone failed or was cancelled.\n\n${summary}"
	rm -f -- "${log_file}" "${rc_file}"
	return 1
}

vmtoolgtk::clone_server_template_menu() {
	local template_name

	template_name="$(vmtoolgtk::select_clone_template \
		"server" \
		"${VMTOOLGTK_TITLE} - Deploy Server VM" \
		"Select a server template VM to clone." \
		"No server template VMs were found. Create a server template first.")" || return 0

	vmtoolgtk::prompt_cicd_options || return 0
	vmtoolgtk::run_clone_with_progress "RTD VM Tool - Clone Server VM" "${template_name}" "server" "${RTD_VM_CLONE_ARGS[@]}"
}

vmtoolgtk::clone_vdi_template_menu() {
	local template_name

	template_name="$(vmtoolgtk::select_clone_template \
