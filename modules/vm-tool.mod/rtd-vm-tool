vmtool::gnome_boxes_target_user() {
	local target_user="${SUDO_USER:-${USER:-}}"

	if [[ -z "$target_user" || "$target_user" == "root" ]]; then
		target_user="$(logname 2>/dev/null || printf '%s' "${target_user:-root}")"
	fi
	printf '%s\n' "$target_user"
}


vmtool::gnome_boxes_target_home() {
	local target_user="$1"
	local target_home="/home/${target_user}"

	if [[ ! -d "$target_home" ]]; then
		target_home="$(getent passwd "$target_user" 2>/dev/null | cut -d: -f6)"
	fi

	[[ -n "$target_home" && -d "$target_home" ]] || return 1
	printf '%s\n' "$target_home"
}


vmtool::gnome_boxes_integration_enabled() {
	local target_user target_home
	target_user="$(vmtool::gnome_boxes_target_user)"
	target_home="$(vmtool::gnome_boxes_target_home "$target_user" 2>/dev/null)" || return 1

	[[ -f "${target_home}/.config/gnome-boxes/sources/QEMU System" ||
		-f "${target_home}/.var/app/org.gnome.Boxes/config/gnome-boxes/sources/QEMU System" ]]
}


vmtool::toggle_gnome_boxes_integration() {
	if vmtool::gnome_boxes_integration_enabled; then
		vmtool::remove_gnome_boxes_integration
	else
		vmtool::install_gnome_boxes_integration
	fi
}


vmtool::install_gnome_boxes_integration() {
	local target_user
	local target_group
	local target_home
	local source_name="QEMU System"
	local -a base_dirs=()
	local -a written_files=()
	local flatpak_override_status="not needed"

	target_user="$(vmtool::gnome_boxes_target_user)"
	if ! target_home="$(vmtool::gnome_boxes_target_home "$target_user")"; then
		dialog::display_error "Unable to find a home directory for ${target_user:-the target user}."
		return 1
	fi
	target_group="$(id -gn "$target_user" 2>/dev/null || printf '%s' "$target_user")"

	base_dirs=(
		"${target_home}/.config/gnome-boxes"
		"${target_home}/.var/app/org.gnome.Boxes/config/gnome-boxes"
	)

	write_status "Installing GNOME Boxes integration for ${target_user}..."
	for base_dir in "${base_dirs[@]}"; do
		if [[ ! -d "$base_dir" ]]; then
			write_information "GNOME Boxes config directory not found, skipping: ${base_dir}"
			continue
		fi

		local sources_dir="${base_dir}/sources"
		local source_file="${sources_dir}/${source_name}"
		local source_uri="qemu+unix:///system"

		if [[ "$base_dir" == *"/.var/app/org.gnome.Boxes/"* ]]; then
			source_uri="qemu+unix:///system?socket=/run/libvirt/libvirt-sock"
		fi

		mkdir -p "$sources_dir" || {
			write_warning "Unable to create ${sources_dir}"
			continue
		}

		cat >"$source_file" <<EOF || {
[source]
name=QEMU System
type=libvirt
uri=${source_uri}
save-on-quit=true
EOF
			write_warning "Unable to write ${source_file}"
			continue
		}

		chown -R "${target_user}:${target_group}" "$sources_dir" 2>/dev/null || true
		written_files+=("$source_file")
	done

	if [[ -d "${target_home}/.var/app/org.gnome.Boxes/config/gnome-boxes" ]] && command -v flatpak >/dev/null 2>&1; then
		if [[ "${EUID:-$(id -u)}" -eq 0 && "$target_user" != "root" ]] && command -v sudo >/dev/null 2>&1; then
			if sudo -u "$target_user" flatpak override --user --filesystem=/run/libvirt org.gnome.Boxes; then
				flatpak_override_status="configured for ${target_user}"
			else
				flatpak_override_status="failed"
			fi
		elif flatpak override --user --filesystem=/run/libvirt org.gnome.Boxes; then
			flatpak_override_status="configured"
		else
			flatpak_override_status="failed"
		fi
	fi

	if (( ${#written_files[@]} == 0 )); then
		result="No GNOME Boxes config directories were found for ${target_user}.

Checked:
 - ${base_dirs[0]}
 - ${base_dirs[1]}

Open GNOME Boxes once, then run this task again."
		dialog::display_result "GNOME Boxes Integration"
		return 0
	fi

	result="GNOME Boxes can now see the system libvirt connection.

Written:
$(printf ' - %s\n' "${written_files[@]}")

Flatpak /run/libvirt access: ${flatpak_override_status}

Restart GNOME Boxes if it is already open."
	dialog::display_result "GNOME Boxes Integration"
}


vmtool::remove_gnome_boxes_integration() {
	local target_user target_home
	local source_file
	local -a source_files=()
	local -a removed_files=()
	local flatpak_override_status="not needed"

	target_user="$(vmtool::gnome_boxes_target_user)"
	if ! target_home="$(vmtool::gnome_boxes_target_home "$target_user")"; then
		dialog::display_error "Unable to find a home directory for ${target_user:-the target user}."
		return 1
	fi

	source_files=(
		"${target_home}/.config/gnome-boxes/sources/QEMU System"
		"${target_home}/.var/app/org.gnome.Boxes/config/gnome-boxes/sources/QEMU System"
	)

	write_status "Removing GNOME Boxes integration for ${target_user}..."
	for source_file in "${source_files[@]}"; do
		if [[ -f "$source_file" ]]; then
			if rm -f "$source_file"; then
				removed_files+=("$source_file")
			else
				write_warning "Unable to remove ${source_file}"
			fi
		fi
	done

	if [[ -d "${target_home}/.var/app/org.gnome.Boxes/config/gnome-boxes" ]] && command -v flatpak >/dev/null 2>&1; then
		if [[ "${EUID:-$(id -u)}" -eq 0 && "$target_user" != "root" ]] && command -v sudo >/dev/null 2>&1; then
			if sudo -u "$target_user" flatpak override --user --nofilesystem=/run/libvirt org.gnome.Boxes; then
				flatpak_override_status="removed for ${target_user}"
			else
				flatpak_override_status="failed"
			fi
		elif flatpak override --user --nofilesystem=/run/libvirt org.gnome.Boxes; then
			flatpak_override_status="removed"
		else
			flatpak_override_status="failed"
		fi
	fi

	result="GNOME Boxes system libvirt integration has been removed.

Removed:
$(if (( ${#removed_files[@]} )); then printf ' - %s\n' "${removed_files[@]}"; else printf ' - No source files were present.\n'; fi)

Flatpak /run/libvirt access: ${flatpak_override_status}

Restart GNOME Boxes if it is already open."
	dialog::display_result "GNOME Boxes Integration"
}


vmtool::run_cleanup_task() {
	local task_title="$1"
	local func_name="$2"
	local match_regex="$3"
	local default_dir="$4"
	local summary_label="$5"
	local mode_flag="$6"

	local mode_label="execute"
	local -a args=()
	if [[ "$mode_flag" == "--dry-run" ]]; then
		mode_label="dry-run"
		args+=(--dry-run)
	fi

	local tmpfile display_file
	tmpfile=$(mktemp) || return 1

	write_status "Running ${task_title} (${mode_label})..."
	if ! ( TERMUITXT="nocolor" "$func_name" "${args[@]}" ) &>"$tmpfile"; then
		local cleanup_status=$?
		$RTD_GUI --backtitle "$BACKTITLE" --title "${task_title} (${mode_label}) failed" --textbox "$tmpfile" "$HEIGHT" "$WIDTH"
		rm -f "$tmpfile"
		write_warning "${task_title} (${mode_label}) failed with exit code ${cleanup_status}. See dialog for details."
		return 1
	fi

	display_file=$(mktemp) || { rm -f "$tmpfile"; return 1; }

	local summary_dir
	summary_dir=$(grep -o 'Directory=[^ ]*' "$tmpfile" | head -n1 | cut -d= -f2)
	[[ -z "$summary_dir" ]] && summary_dir="$default_dir"
	local title_suffix=""
	if [[ -n "$summary_dir" ]]; then
		title_suffix=" — ${summary_dir}"
	fi

	local summary_line
	summary_line=$(grep -m1 "$summary_label" "$tmpfile" || true)

	printf "Directory: %s\nMode: %s\n\n" "${summary_dir}" "${mode_label}" >"$display_file"

	local listed=0
	local regex="$match_regex"
	while IFS= read -r line; do
		if [[ "$line" =~ $regex ]]; then
			local captured="${BASH_REMATCH[1]}"
			printf " - %s\n" "$(basename "$captured")" >>"$display_file"
			listed=1
		fi
	done <"$tmpfile"

	local summary_msg="${summary_line:-$(tail -n1 "$tmpfile")}"
	if (( listed == 0 )); then
		summary_msg=${summary_msg:-"No items found in ${summary_dir}."}
		write_status "${task_title} found nothing to remove; showing notice."
		$RTD_GUI --backtitle "$BACKTITLE" --title "${task_title}${title_suffix}" --msgbox "${summary_msg}" "$HEIGHT" "$WIDTH"
	else
		printf "\n%s\n" "${summary_msg}" >>"$display_file"
		write_status "Opening ${task_title} summary dialog (${task_title}${title_suffix})..."
		$RTD_GUI --backtitle "$BACKTITLE" --title "${task_title}${title_suffix}" --textbox "$display_file" "$HEIGHT" "$WIDTH"
	fi

	rm -f "$tmpfile" "$display_file"
	write_status "${task_title} (${mode_label}) finished; returning to maintenance menu."
}


