#!/usr/bin/env bash
#
#::                                       A D M I N   T O O L
#::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::
#:::::::::::::::::::::::::::::::::::::::// RTD GNOME Theme Manager //::::::::::::::::::::::::::::::::// Linux //::::::::
#:: Author(s):    RTD
#:: Version:      1.00
#::
#:: Purpose:      Discover available GNOME themes, let the user choose one, and
#::               apply GTK, Shell, icon, cursor, and optional wallpaper changes.
#::
#:: Value:        Simplifies theme switching and reduces the manual GNOME and
#::               extension setup usually required to fully apply a desktop theme.
#::
#:: Usage:        Run without arguments to launch the selector GUI, or use
#::               --help to show the built-in help dialog.
#::
#:: Examples:
#::               rtd-theme-manager
#::               rtd-theme-manager --help
#::
#:: Requirements: gsettings, zenity, gnome-extensions
#::
#::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::

set -euo pipefail

die() { echo "Error: $*" >&2; exit 1; }
warn() { echo "Warning: $*" >&2; }

require() { command -v "$1" >/dev/null 2>&1 || die "Missing required command: $1"; }

require gsettings
require zenity
require gnome-extensions

find_themes() {
	local -a themes=()
	# Prefer user themes, but include system themes too.
	while IFS= read -r -d '' dir; do
		themes+=("$(basename "$dir")")
	done < <(find "$HOME/.themes" /usr/share/themes -mindepth 1 -maxdepth 1 -type d -print0 2>/dev/null | sort -z)

	# Keep unique names in order
	printf '%s\n' "${themes[@]}" | awk '!seen[$0]++'
}

theme_path() {
	local theme="$1"
	local -a roots=("$HOME/.themes" "/usr/share/themes")
	local dir
	for dir in "${roots[@]}"; do
		if [[ -d "${dir}/${theme}" ]]; then
			printf '%s\n' "${dir}/${theme}"
			return 0
		fi
	done
	return 1
}

find_theme_wallpapers() {
	local theme="$1"
	local tpath
	tpath=$(theme_path "$theme") || return 1
	find "$tpath" -maxdepth 3 -type f \( -iname 'wallpaper.*' -o -iname 'background.*' -o -iname '*.jpg' -o -iname '*.jpeg' -o -iname '*.png' -o -iname '*.webp' \) \
		-print0 2>/dev/null | sort -z
}

pick_wallpaper() {
	local theme="$1"
	local selected
	local -a wallpapers
	mapfile -d '' wallpapers < <(find_theme_wallpapers "$theme")

	if ((${#wallpapers[@]} == 0)); then
		return 0
	fi

	local options=(TRUE "None" "Don't change wallpaper")
	for wallpaper in "${wallpapers[@]}"; do
		options+=(FALSE "$(basename "$wallpaper")" "$wallpaper")
	done

	selected=$(zenity --list \
		--title="Wallpaper Selection" \
		--text="Select a wallpaper to apply" \
		--radiolist \
		--column="Select" --column="Wallpaper" --column="Path" \
		--height=400 --width=500 \
		--print-column=3 \
		"${options[@]}") || return 1

	if [[ "$selected" == "Don't change wallpaper" ]]; then
		echo "None"
	else
		echo "$selected"
	fi
}


pick_theme() {
	local themes
	themes=$(find_themes) || return 1

	[[ -z "$themes" ]] && die "No themes found in ~/.themes or /usr/share/themes."

	zenity --list \
		--title="GNOME Theme Manager" \
		--text="Select a theme to apply" \
		--column="Themes" \
		--height=400 --width=320 \
		--hide-header <<<"$themes"
}

find_installer() {
	# First, try PATH
	if command -v rtd-gnome-shell-extension-installer >/dev/null 2>&1; then
		command -v rtd-gnome-shell-extension-installer
		return
	fi

	# Then search common RTD locations
	local candidate
	candidate=$(find /opt -maxdepth 4 -type f -name 'rtd-gnome-shell-extension-installer' 2>/dev/null | head -n1 || true)
	if [[ -n "$candidate" && -x "$candidate" ]]; then
		echo "$candidate"
		return
	fi

	# Fallback: download a fresh copy to a temp location
	local tmp_installer
	tmp_installer="$(mktemp -p /tmp rtd-gnome-extension-installer.XXXXXX)"
	if curl -fsSL "https://raw.githubusercontent.com/vonschutter/RTD-Setup/main/modules/gnome-shell-extension-installer.mod/rtd-gnome-shell-extension-installer" -o "$tmp_installer"; then
		chmod +x "$tmp_installer"
		echo "$tmp_installer"
		return
	fi

	warn "Unable to download rtd-gnome-shell-extension-installer."
}

ensure_extension() {
	local uuid="$1" id="$2"

	if gnome-extensions list 2>/dev/null | grep -Fxq "$uuid"; then
		enable_extension_uuid "$uuid"
		return 0
	fi

	local installer
	installer=$(find_installer)
	if [[ -z "$installer" ]]; then
		warn "Extension '${uuid}' not installed and no installer found. Please install manually."
		return 1
	fi

	echo "Installing GNOME extension ${uuid} (id ${id})..."
	if bash "$installer" "$id" --yes >/dev/null 2>&1; then
		enable_extension_uuid "$uuid"
	else
		warn "Failed to install extension ${uuid}."
		return 1
	fi
}

ensure_dependencies() {
	# Allow user extensions to load
	gsettings set org.gnome.shell disable-user-extensions false 2>/dev/null || true

	# Ensure key extensions are present and enabled (best effort)
	ensure_extension "user-theme@gnome-shell-extensions.gcampax.github.com" "19" || warn "Could not ensure User Themes extension."
	ensure_extension "dash-to-dock@micxgx.gmail.com" "307" || warn "Could not ensure Dash-to-Dock extension."
	ensure_extension "dash-to-panel@jderose9.github.com" "1160" || warn "Could not ensure Dash-to-Panel extension."
}

enable_extension_uuid() {
	local uuid="$1"

	# Primary: gnome-extensions
	if gnome-extensions enable "$uuid" 2>/dev/null; then
		return 0
	fi

	# Fallback: D-Bus call to GNOME Shell (works on Wayland without full reload)
	if command -v busctl >/dev/null 2>&1; then
		busctl --user call org.gnome.Shell /org/gnome/Shell org.gnome.Shell.Extensions EnableExtension s "$uuid" >/dev/null 2>&1 && return 0
	fi

	# Final fallback: gsettings to toggle user extensions back on (forces reload when possible)
	gsettings set org.gnome.shell disable-user-extensions false >/dev/null 2>&1 || true
	return 1
}

apply_theme() {
	local theme="$1"
	local wallpaper="${2:-}"

	gsettings set org.gnome.desktop.interface gtk-theme "$theme" || warn "Failed to set GTK theme."
	# GTK 4 uses same setting; also align icon/cursor if present
	gsettings set org.gnome.desktop.interface icon-theme "$theme" >/dev/null 2>&1 || true
	gsettings set org.gnome.desktop.interface cursor-theme "$theme" >/dev/null 2>&1 || true

	# Apply shell theme if user-theme extension is available
	if gsettings writable org.gnome.shell.extensions.user-theme name >/dev/null 2>&1; then
		gsettings set org.gnome.shell.extensions.user-theme name "$theme" || warn "Failed to set GNOME Shell theme."
	else
		warn "User Themes extension not available; skipping shell theme."
	fi

	if [[ -n "$wallpaper" && -f "$wallpaper" ]]; then
		local uri="file://$wallpaper"
		gsettings set org.gnome.desktop.background picture-uri "$uri" || warn "Failed to set wallpaper."
		# Keep dark-mode background in sync when available
		gsettings set org.gnome.desktop.background picture-uri-dark "$uri" >/dev/null 2>&1 || true
	fi
}

show_help() {
	zenity --info --title="About RTD Theme Manager" --width=400 --no-wrap --text="<span size='large'><b>RTD GNOME Theme Manager</b></span>\n\nA simple graphical tool to apply GNOME themes.\n\n<b>Usage:</b>\n  - Run without arguments to launch the theme selector.\n  - Use <b>--help</b> or <b>-h</b> to show this message.\n\n<b>How it works:</b>\n1. It finds themes in <b>~/.themes</b> and <b>/usr/share/themes</b>.\n2. You select a theme from the list.\n3. It applies the GTK, Shell, Icon, and Cursor themes.\n4. If a wallpaper is found in the theme's folder, it will be set."
}

main() {
	if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
		show_help
		exit 0
	fi

	local theme wallpaper

	ensure_dependencies

	theme=$(pick_theme) || exit 1
	[[ -z "$theme" ]] && exit 0

	wallpaper=$(pick_wallpaper "$theme" || true)
	if [[ "$wallpaper" == "None" ]]; then
		wallpaper=""
	fi

	apply_theme "$theme" "$wallpaper"

	zenity --info --title="GNOME Theme Manager" --text="Applied theme: $theme${wallpaper:+\nWallpaper: $wallpaper}"
}

main "$@"
