if (( BASH_VERSINFO[0] < 4 || (BASH_VERSINFO[0] == 4 && BASH_VERSINFO[1] < 4) )); then
	echo "ERROR: RTD _rtd_library requires Bash 4.4 or newer. Current shell: Bash ${BASH_VERSION}." >&2
	return 1 2>/dev/null || exit 1
fi


set -euo pipefail

readonly KEEP="__KEEP__"
readonly SCRIPT_PATH="$(readlink -f "${BASH_SOURCE[0]}")"
readonly SCRIPT_DIR="$(cd "$(dirname "$SCRIPT_PATH")" && pwd)"
readonly BANNER="${SCRIPT_DIR}/Media_files/theme-manager-banner.png"
readonly GTK_FRONTEND="${SCRIPT_DIR}/theme-manager-gtk.py"

die() { echo "Error: $*" >&2; exit 1; }
warn() { echo "Warning: $*" >&2; }
info() { echo "Info: $*" >&2; }

require() {
	command -v "$1" >/dev/null 2>&1 || die "Missing required command: $1"
}

desktop_matches() {
	rtd::bootstrap_library "_rtd_library" >/dev/null 2>&1 || return 1
	declare -F dependency::desktop >/dev/null 2>&1 || return 1
	dependency::desktop "$1"
}

is_kde_desktop() {
	desktop_matches kde
}

is_gnome_desktop() {
	desktop_matches gnome
}

launch_native_kde_look_settings() {
	if command -v kcmshell6 >/dev/null 2>&1; then
		exec kcmshell6 kcm_lookandfeel
	elif command -v kcmshell5 >/dev/null 2>&1; then
		exec kcmshell5 kcm_lookandfeel
	elif command -v systemsettings >/dev/null 2>&1; then
		exec systemsettings kcm_lookandfeel
	fi
	die "KDE look-and-feel settings were requested, but kcmshell6, kcmshell5, and systemsettings are not available."
}

apply_kde_look_and_feel() {
	launch_native_kde_look_settings
}

rtd::bootstrap_library() {
	if (( BASH_VERSINFO[0] < 4 || (BASH_VERSINFO[0] == 4 && BASH_VERSINFO[1] < 4) )); then
		echo "ERROR: RTD _rtd_library requires Bash 4.4 or newer. Current shell: Bash ${BASH_VERSION}." >&2
		return 1
	fi
	local library_name="${1:-_rtd_library}" path tmp rc

	for path in \
		"${SCRIPT_DIR}/${library_name}" \
		"${SCRIPT_DIR}/../core/${library_name}" \
		"${SCRIPT_DIR}/../../core/${library_name}" \
		"/opt/rtd/core/${library_name}" \
		"${HOME:-}/GIT/RTD-Setup/core/${library_name}" \
		"${HOME:-}/RTD-Setup/core/${library_name}"; do
		[[ -r "$path" ]] || continue
		# shellcheck source=/dev/null
		source "$path" ""
		declare -F software::check_native_package_dependency >/dev/null 2>&1 && return 0
	done

	tmp="$(mktemp "/tmp/${library_name}.XXXXXX")" || return 1
	rc=0
	if command -v curl >/dev/null 2>&1; then
		curl -fsSL "https://github.com/vonschutter/RTD-Setup/raw/main/core/${library_name}" -o "$tmp" || rc=$?
	elif command -v wget >/dev/null 2>&1; then
		wget -qO "$tmp" "https://github.com/vonschutter/RTD-Setup/raw/main/core/${library_name}" || rc=$?
	else
		rc=1
	fi
	if ((rc == 0)); then
		# shellcheck source=/dev/null
		source "$tmp" ""
		declare -F software::check_native_package_dependency >/dev/null 2>&1 || rc=1
	fi
	rm -f "$tmp"
	return "$rc"
}

gtk_frontend_ready() {
	command -v python3 >/dev/null 2>&1 &&
		python3 -c 'import gi; gi.require_version("Gtk", "3.0"); from gi.repository import GdkPixbuf, Gtk' >/dev/null 2>&1
}

install_python_gtk_dependencies() {
	local distro
	rtd::bootstrap_library "_rtd_library" || return 1
	distro="$(system::distribution_type)"

	case "$distro" in
		ubuntu|debian)
			software::check_native_package_dependency python3 python3-gi gir1.2-gtk-3.0
			;;
		fedora|redhat)
			software::check_native_package_dependency python3 python3-gobject gtk3
			;;
		suse)
			software::check_native_package_dependency python3 python3-gobject-Gdk typelib-1_0-Gtk-3_0
			;;
		*)
			warn "Automatic Python GTK setup is not available for distribution family: ${distro}."
			return 1
			;;
	esac
}

ensure_python_gtk_frontend() {
	gtk_frontend_ready && return 0
	info "Installing the Python GTK components required by the RTD Theme Manager."
	rtd::bootstrap_library "_rtd_library" || {
		warn "Unable to load the RTD dependency installer."
		return 1
	}
	if ((EUID == 0)); then
		install_python_gtk_dependencies || return 1
	else
		( security::ensure_admin --sudo --setup-python-gtk-dependencies ) || return 1
	fi
	hash -r
	gtk_frontend_ready
}

ensure_dialog_backend() {
	local requested="${1:-}"
	if [[ -n "$requested" ]]; then
		[[ "$requested" =~ ^(yad|zenity)$ ]] || return 1
		command -v "$requested" >/dev/null 2>&1 && { printf '%s\n' "$requested"; return 0; }
	else
		command -v yad >/dev/null 2>&1 && { printf 'yad\n'; return 0; }
		command -v zenity >/dev/null 2>&1 && { printf 'zenity\n'; return 0; }
	fi
	rtd::bootstrap_library "_rtd_library" || return 1

	info "Installing a graphical dialog fallback."
	if ((EUID == 0)); then
		if [[ -n "$requested" ]]; then
			software::check_native_package_dependency "$requested" || return 1
		else
			software::check_native_package_dependency yad ||
				software::check_native_package_dependency zenity || return 1
		fi
	else
		if [[ -n "$requested" ]]; then
			( security::ensure_admin --sudo --setup-dialog-dependency "$requested" ) || return 1
		else
			( security::ensure_admin --sudo --setup-dialog-dependency yad ) ||
				( security::ensure_admin --sudo --setup-dialog-dependency zenity ) || return 1
		fi
	fi
	hash -r
	[[ -n "$requested" ]] && command -v "$requested" >/dev/null 2>&1 && { printf '%s\n' "$requested"; return 0; }
	command -v yad >/dev/null 2>&1 && { printf 'yad\n'; return 0; }
	command -v zenity >/dev/null 2>&1 && { printf 'zenity\n'; return 0; }
	return 1
}

setting_is_writable() {
	gsettings writable "$1" "$2" 2>/dev/null | grep -Fxq true
}

enable_extension_uuid() {
	local uuid="$1"

	command -v gnome-extensions >/dev/null 2>&1 &&
		gnome-extensions enable "$uuid" >/dev/null 2>&1 &&
		return 0
	command -v busctl >/dev/null 2>&1 &&
		busctl --user call org.gnome.Shell /org/gnome/Shell org.gnome.Shell.Extensions EnableExtension s "$uuid" >/dev/null 2>&1 &&
		return 0
	return 1
}

find_extension_installer() {
	local candidate
	for candidate in \
		"${SCRIPT_DIR}/../gnome-shell-extension-installer.mod/rtd-gnome-shell-extension-installer" \
		"/opt/rtd/modules/gnome-shell-extension-installer.mod/rtd-gnome-shell-extension-installer"; do
		[[ -r "$candidate" ]] && { printf '%s\n' "$candidate"; return 0; }
	done
	command -v rtd-gnome-shell-extension-installer 2>/dev/null
}

ensure_user_theme_extension() {
	local uuid="user-theme@gnome-shell-extensions.gcampax.github.com"
	local installer

	gsettings set org.gnome.shell disable-user-extensions false >/dev/null 2>&1 || true
	if command -v gnome-extensions >/dev/null 2>&1 &&
		gnome-extensions list 2>/dev/null | grep -Fxq "$uuid"; then
		enable_extension_uuid "$uuid" || warn "The GNOME User Themes extension is installed but could not be enabled."
		return 0
	fi

	installer="$(find_extension_installer)" || {
		warn "Could not find the RTD GNOME extension installer."
		return 1
	}
	info "Installing the GNOME User Themes extension."
	rtd::bootstrap_library "_rtd_library" &&
		software::check_native_package_dependency curl unzip >/dev/null 2>&1 || true
	bash "$installer" 19 --yes >/dev/null 2>&1 || {
		warn "Unable to install the GNOME User Themes extension."
		return 1
	}
	enable_extension_uuid "$uuid" || warn "Log out and back in if the new GNOME User Themes extension is not active yet."
}

find_component_names() {
	local component="$1"
	local -a roots=()

	case "$component" in
		gtk) roots=("$HOME/.themes" /usr/share/themes) ;;
		shell) roots=("$HOME/.themes" /usr/share/themes) ;;
		icons|cursors) roots=("$HOME/.icons" "$HOME/.local/share/icons" /usr/share/icons) ;;
	esac
	find "${roots[@]}" -mindepth 1 -maxdepth 1 -type d 2>/dev/null |
		while IFS= read -r path; do
			case "$component" in
				gtk) [[ -d "$path/gtk-3.0" || -d "$path/gtk-4.0" ]] ;;
				shell) [[ -d "$path/gnome-shell" ]] ;;
				icons) [[ -f "$path/index.theme" ]] ;;
				cursors) [[ -d "$path/cursors" ]] ;;
			esac && basename "$path"
		done | awk '!seen[$0]++' | sort -f
}

component_value_or_keep() {
	local component="$1" requested="$2"
	find_component_names "$component" | grep -Fxq "$requested" &&
		printf '%s\n' "$requested" ||
		printf '%s\n' "$KEEP"
}

dialog_info() {
	local backend="$1" title="$2" text="$3"
	if [[ "$backend" == yad ]]; then
		if [[ -r "$BANNER" ]]; then
			yad --info --title="$title" --text="$text" --image="$BANNER" --width=620 --button="OK:0"
		else
			yad --info --title="$title" --text="$text" --width=620 --button="OK:0"
		fi
	else
		zenity --info --title="$title" --text="$text" --width=620
	fi
}

dialog_list() {
	local backend="$1" title="$2" text="$3"
	shift 3
	if [[ "$backend" == yad ]]; then
		yad --list --title="$title" --text="$text" --width=780 --height=480 \
			--column="Choice" "$@" --button="Select:0" --button="Cancel:1"
	else
		zenity --list --title="$title" --text="$text" --width=780 --height=480 \
			--column="Choice" "$@" --ok-label="Select" --cancel-label="Cancel"
	fi
}

pick_component() {
	local backend="$1" component="$2" title="$3"
	local -a values=()
	mapfile -t values < <(find_component_names "$component")
	((${#values[@]} > 0)) || { printf '%s\n' "$KEEP"; return 0; }
	dialog_list "$backend" "$title" "Select the ${title,,}, or cancel to keep the current setting." "${values[@]}" ||
		printf '%s\n' "$KEEP"
}

run_dialog_fallback() {
	local backend backend_label action theme gtk shell icons cursors color wallpaper profile
	backend="$(ensure_dialog_backend "${1:-}")" || die "Unable to install Python GTK, YAD, or Zenity."
	backend_label="$(printf '%s' "$backend" | tr '[:lower:]' '[:upper:]')"
	warn "Using the ${backend_label} compatibility interface because Python GTK is unavailable."
	action="$(dialog_list "$backend" "RTD GNOME Theme Manager" \
		"Choose how you want to shape your GNOME desktop." \
		"Apply a complete installed theme" \
		"Customize individual elements" \
		"Open RTD Desktop Profiles")" || exit 0

	case "$action" in
		"Apply a complete installed theme")
			mapfile -t themes < <(
				{ find_component_names gtk; find_component_names shell; find_component_names icons; find_component_names cursors; } |
					awk '!seen[$0]++' | sort -f
			)
			theme="$(dialog_list "$backend" "Complete Theme" "Select an installed theme." "${themes[@]}")" || exit 0
			apply_theme \
				"$(component_value_or_keep gtk "$theme")" \
				"$(component_value_or_keep shell "$theme")" \
				"$(component_value_or_keep icons "$theme")" \
				"$(component_value_or_keep cursors "$theme")" \
				"$KEEP" "$KEEP"
			;;
		"Customize individual elements")
			gtk="$(pick_component "$backend" gtk "application theme")"
			shell="$(pick_component "$backend" shell "GNOME Shell theme")"
			icons="$(pick_component "$backend" icons "icon theme")"
			cursors="$(pick_component "$backend" cursors "cursor theme")"
			color="$(dialog_list "$backend" "Light Or Dark Preference" "Select the GNOME color preference." \
				default prefer-light prefer-dark)" || color="$KEEP"
			wallpaper="$KEEP"
			apply_theme "$gtk" "$shell" "$icons" "$cursors" "$color" "$wallpaper"
			;;
		"Open RTD Desktop Profiles")
			profile="$(dialog_list "$backend" "RTD Desktop Profiles" \
				"Select a complete RTD desktop profile." \
				"Windows 10 Dark Mode" \
				"Windows 10 Light Mode" \
				"Mac OS Bright" \
				"Mac OS Dusk" \
				"Crisp Day" \
				"Crisp Evening" \
				"Moca Smooth" \
				"Distribution Reset")" || exit 0
			case "$profile" in
				"Windows 10 Dark Mode") apply_desktop_profile win10-dark ;;
				"Windows 10 Light Mode") apply_desktop_profile win10-light ;;
				"Mac OS Bright") apply_desktop_profile mac-bright ;;
				"Mac OS Dusk") apply_desktop_profile mac-dusk ;;
				"Crisp Day") apply_desktop_profile crisp-day ;;
				"Crisp Evening") apply_desktop_profile crisp-evening ;;
				"Moca Smooth") apply_desktop_profile moca-smooth ;;
				"Distribution Reset") apply_desktop_profile distro-reset ;;
			esac
			;;
	esac
	dialog_info "$backend" "RTD GNOME Theme Manager" "Your GNOME appearance settings have been updated."
}

set_setting() {
	local schema="$1" key="$2" value="$3" description="$4"

	[[ "$value" == "$KEEP" ]] && return 0
	if setting_is_writable "$schema" "$key"; then
		gsettings set "$schema" "$key" "$value" || warn "Failed to set ${description}."
	else
		warn "${description} is not available in this GNOME session."
	fi
}

apply_theme() {
	local gtk_theme="$1" shell_theme="$2" icon_theme="$3" cursor_theme="$4"
	local color_scheme="$5" wallpaper="$6"

	require gsettings

	set_setting org.gnome.desktop.interface gtk-theme "$gtk_theme" "GTK theme"
	set_setting org.gnome.desktop.interface icon-theme "$icon_theme" "icon theme"
	set_setting org.gnome.desktop.interface cursor-theme "$cursor_theme" "cursor theme"
	set_setting org.gnome.desktop.interface color-scheme "$color_scheme" "color scheme"

	if [[ "$shell_theme" != "$KEEP" ]]; then
		ensure_user_theme_extension || true
		if setting_is_writable org.gnome.shell.extensions.user-theme name; then
			gsettings set org.gnome.shell.extensions.user-theme name "$shell_theme" ||
				warn "Failed to set GNOME Shell theme."
		else
			warn "GNOME User Themes is not active yet. Log out and back in, then apply the Shell theme again."
		fi
	fi

	if [[ "$wallpaper" != "$KEEP" && -f "$wallpaper" ]]; then
		local uri
		uri="$(python3 -c 'from pathlib import Path; import sys; print(Path(sys.argv[1]).resolve().as_uri())' "$wallpaper" 2>/dev/null ||
			printf 'file://%s' "$wallpaper")"
		set_setting org.gnome.desktop.background picture-uri "$uri" "wallpaper"
		set_setting org.gnome.desktop.background picture-uri-dark "$uri" "dark wallpaper"
	fi
}

require_profile_functions() {
	rtd::bootstrap_library "_rtd_library" || die "Unable to load the RTD desktop profile library."
	declare -F dependency::desktop >/dev/null 2>&1 || die "The RTD library does not provide desktop detection."
	declare -F gnome::set_ui_win10_tweaks_for_user >/dev/null 2>&1 || die "The RTD library does not provide GNOME desktop profiles."
}

apply_desktop_profile() {
	local profile="$1" keyboard_language

	require gsettings
	require_profile_functions

	if ! dependency::desktop gnome; then
		dependency::desktop kde && apply_kde_look_and_feel
		die "RTD desktop profiles require a GNOME desktop session."
	fi

	case "$profile" in
		win10-dark)
			gnome::set_ui_win10_tweaks_for_user Dark
			;;
		win10-light)
			gnome::set_ui_win10_tweaks_for_user Light
			;;
		mac-bright)
			gnome::set_ui_mac_tweaks_for_user Light
			;;
		mac-dusk)
			gnome::set_ui_mac_tweaks_for_user Dark
			;;
		crisp-day)
			gnome::set_ui_corporate_crisp_tweaks_for_user Light
			;;
		crisp-evening)
			gnome::set_ui_corporate_crisp_tweaks_for_user Dark
			;;
		moca-smooth)
			gnome::set_ui_moca_tweaks_for_user
			;;
		distro-reset)
			keyboard_language="$(gsettings get org.gnome.desktop.input-sources sources 2>/dev/null || true)"
			if command -v dconf >/dev/null 2>&1; then
				dconf reset -f /org/gnome/
			else
				warn "dconf is not installed; GNOME settings could not be fully reset."
			fi
			busctl --user call org.gnome.Shell /org/gnome/Shell org.gnome.Shell Eval s 'Meta.restart("Reloading GNOME with the new settings...")' >/dev/null 2>&1 || true
			[[ -n "$keyboard_language" ]] &&
				gsettings set org.gnome.desktop.input-sources sources "$keyboard_language" || true
			;;
		*)
			die "Unknown RTD desktop profile: $profile"
			;;
	esac

	command -v notify-send >/dev/null 2>&1 &&
		notify-send --urgency=low "RTD desktop profile applied" "$profile" || true
}

show_help() {
	cat <<EOF
Usage:
  $(basename "$0")
  $(basename "$0") [--yad | --zenity]
  $(basename "$0") --apply GTK SHELL ICONS CURSOR COLOR_SCHEME WALLPAPER
  $(basename "$0") --apply-profile PROFILE
  $(basename "$0") --kde-look-settings
  $(basename "$0") --help

Description:
  Launch the RTD GNOME Theme Manager. Use the Complete Theme page for a
  coordinated theme, customize individual GNOME appearance elements, apply
  integrated RTD desktop profiles, or hand KDE users to the RTD KDE Look and
  Feel helper.
  Use --yad or --zenity to force a compatibility interface.
EOF
}

main() {
	case "${1:-}" in
		--apply)
			[[ $# -eq 7 ]] || die "--apply requires six values."
			apply_theme "$2" "$3" "$4" "$5" "$6" "$7"
			;;
		--apply-profile)
			[[ $# -eq 2 ]] || die "--apply-profile requires a profile id."
			apply_desktop_profile "$2"
			;;
		--kde-look-settings)
			apply_kde_look_and_feel
			;;
		--yad|--zenity)
			run_dialog_fallback "${1#--}"
			;;
		--setup-python-gtk-dependencies)
			install_python_gtk_dependencies
			;;
		--setup-dialog-dependency)
			[[ $# -eq 2 && "$2" =~ ^(yad|zenity)$ ]] || die "--setup-dialog-dependency requires yad or zenity."
			rtd::bootstrap_library "_rtd_library" || die "Unable to load the RTD dependency installer."
			software::check_native_package_dependency "$2"
			;;
		--help|-h)
			show_help
			;;
		"")
			if is_kde_desktop && ! is_gnome_desktop; then
				apply_kde_look_and_feel
			fi
			if ensure_python_gtk_frontend; then
				exec python3 "$GTK_FRONTEND"
			fi
			run_dialog_fallback
			;;
		*)
			die "Unknown option: $1"
			;;
	esac
}

main "$@"
