# These allow the script to display basic messages before _rtd_library is loaded. Once the library is sourced,
# its richer implementations replace these fallback definitions, including RTD formatting and logging.
write_information() { printf 'INFO: %s\n' "$*"; }
write_warning() { printf 'WARN: %s\n' "$*" >&2; }
write_error() { printf 'ERROR: %s\n' "$*" >&2; }
system::log_item() { :; }

rtd::bootstrap_library() {
	local library_name="${1:-_rtd_library}" loaded_version path script_dir src_url tmp rc check
	local -a checks=()

	[[ "$library_name" == "_rtd_library" && ${#checks[@]} -eq 0 ]] && checks=(
		system::log_item
		write_information
		write_warning
		write_error
		software::ensure_flatpak_package_managment
		software::from_flathub.org
	)

	rtd::bootstrap_library::ok() {
		loaded_version="${RTD_VERSION:-${RTDFUNCTIONS:-}}"
		for check in "${checks[@]}"; do declare -F "$check" >/dev/null 2>&1 || return 1; done
	}

	[[ "$library_name" == "_rtd_library" && -n "$loaded_version" ]] && rtd::bootstrap_library::ok && return 0

	script_dir="$_script_dir"
	# Prefer an installed or nearby library, then download a temporary copy as a last resort.
	for path in \
		"${script_dir}/${library_name}" \
		"${script_dir}/../core/${library_name}" \
		"${script_dir}/../../core/${library_name}" \
		"/opt/${_TLA:-${_tla:-rtd}}/core/${library_name}" \
		"/opt/rtd/core/${library_name}" \
		"${HOME:-}/GIT/RTD-Setup/core/${library_name}" \
		"${HOME:-}/RTD-Setup/core/${library_name}"; do
		[[ -r "$path" ]] || continue
		# shellcheck source=/dev/null
		source "$path" ""
		rc=$?
		[[ $rc -eq 0 ]] && rtd::bootstrap_library::ok && return 0
	done

	src_url="https://github.com/${_GIT_PROFILE:-${GIT_Profile:-vonschutter}}/RTD-Setup/raw/main/core/${library_name}"
	tmp="$(mktemp "/tmp/${library_name}.XXXXXX" 2>/dev/null || echo "/tmp/${library_name}.$$")"
	rc=0
	if command -v curl >/dev/null 2>&1; then
		curl -fsSL "$src_url" -o "$tmp" || rc=$?
	elif command -v wget >/dev/null 2>&1; then
		wget -qO "$tmp" "$src_url" || rc=$?
	else
		rc=1
	fi
	[[ ${rc:-0} -eq 0 ]] || { rm -f "$tmp"; return "$rc"; }

	# shellcheck source=/dev/null
	source "$tmp" ""
	rc=$?
	rm -f "$tmp"
	[[ $rc -eq 0 ]] || return "$rc"
	rtd::bootstrap_library::ok && return 0
	return 1
}


