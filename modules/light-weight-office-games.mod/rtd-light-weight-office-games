# Never run in Windows, even if the file extension is .cmd or .bat.
:<<"::CMDLITERAL"
@ECHO OFF
GOTO :CMDSCRIPT
::CMDLITERAL

# only run on Linux, since the games are Linux-only and the script is not designed for cross-platform compatibility.
case "${OSTYPE:-unknown}" in
    linux*)
        ;;
    darwin*)
        echo "macOS is currently unsupported by $(basename "$0")." >&2
        exit 1
        ;;
    cygwin*)
        echo "Cygwin is currently unsupported." >&2
        exit 1
        ;;
    msys*)
        echo "MSYS is currently unsupported." >&2
        exit 1
        ;;
    freebsd*)
        echo "FreeBSD is currently unsupported." >&2
        exit 1
        ;;
    *)
        echo "This operating system is unknown to $(basename "$0"): ${OSTYPE:-unset}" >&2
        exit 1
        ;;
esac



