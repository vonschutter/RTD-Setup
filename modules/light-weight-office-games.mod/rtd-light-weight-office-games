	fi
}

choose_scope() {
	local key selected yad_status
	# Use the richer side-by-side YAD layout when a display and sidebar image are available.
	if [[ "$_ui_tool" == "yad" && -n "${DISPLAY:-}" && -r "$_sidebar_image" ]]; then
		key=$((BASHPID + RANDOM))
		_scope_result_file="$(mktemp "/tmp/${_scriptname}.scope.XXXXXX")" || return 1

		GDK_BACKEND=x11 yad --plug="$key" --tabnum=1 \
			--picture --filename="$_sidebar_image" --size=fit --no-buttons \
			>/dev/null 2>&1 &
		_scope_left_pid=$!

		GDK_BACKEND=x11 yad --plug="$key" --tabnum=2 \
			--list --radiolist --no-buttons \
			--text="<b>Install scope</b>\nChoose who should have access to these games." \
			--text-align=left \
			--column="" --column="Install for" --column="Description" --column="Scope:HD" \
			TRUE "Just me" "Install for the current user without changing the whole system." "user" \
			FALSE "All users" "Install system-wide. This may require sudo or PolicyKit." "system" \
			--print-column=4 --separator="" \
			--grid-lines=horizontal --wrap-cols=3 --wrap-width=280 --expand-column=3 \
			>"$_scope_result_file" 2>/dev/null &
		_scope_right_pid=$!

		GDK_BACKEND=x11 yad --paned --key="$key" --orient=horizontal --splitter=225 \
			"${_yad_common_args[@]}" \
			--width=745 --height=420 \
			--button="Continue:0" --button="Cancel:1"
		yad_status=$?

		if ((yad_status != 0)); then
			kill "$_scope_left_pid" "$_scope_right_pid" 2>/dev/null || true
		fi
		wait "$_scope_left_pid" "$_scope_right_pid" 2>/dev/null || true
		_scope_left_pid=""
		_scope_right_pid=""
		selected="$(<"$_scope_result_file")"
		rm -f -- "$_scope_result_file"
		_scope_result_file=""
		((yad_status == 0)) || return 1
	elif [[ "$_ui_tool" == "yad" ]]; then
		selected=$(yad --list --radiolist \
			"${_yad_sidebar_args[@]}" \
			--text="<b>Install scope</b>\nChoose whether these games should be installed only for you or for all users." \
			--text-align=left \
			--width 760 --height 360 \
			--column "" --column "Scope" --column "Description" \
			TRUE "user" "Install for the current user without changing the whole system." \
			FALSE "system" "Install for all users. This may require sudo or PolicyKit." \
			--print-column=2 --separator="" \
			--button="Continue:0" --button="Cancel:1") || return 1
	else
		selected=$(zenity --list --radiolist \
			"${_zenity_icon_args[@]}" \
			--title "$_title" \
			--text "Choose installation scope" \
			--width 640 --height 240 \
			--column "" --column "Scope" --column "Description" \
			TRUE "user" "Install for the current user only." \
			FALSE "system" "Install for all users.") || return 1
	fi
	_install_scope="${selected:-user}"
}

select_games() {
	local selected row app_id name type installs favorites summary
	local -a ui_rows=()

	# Convert the catalog into checklist rows while keeping Flatpak IDs hidden from the user.
	for row in "${GAME_CATALOG[@]}"; do
		IFS='|' read -r app_id name type installs favorites summary <<<"$row"
		ui_rows+=(TRUE "$name" "$type" "${installs}/mo, ${favorites} fav" "$app_id" "$summary")
	done

	if [[ "$_ui_tool" == "yad" ]]; then
		selected=$(yad --list --checklist \
			"${_yad_icon_args[@]}" \
			--text="<b>Choose games to install</b>\nCurated from popular Flathub board, card, tile, and puzzle games. Uncheck anything you do not want." \
			--width 980 --height 560 --center \
			--column "Install" --column "Game" --column "Type" --column "Popularity" --column "Flatpak ID" --column "Summary" \
			"${ui_rows[@]}" \
			--print-column=5 --hide-column=5 --separator=$'\n' \
			--grid-lines=horizontal --search-column=2 --expand-column=6 --wrap-cols=6 --wrap-width=340 \
			--button="Install Games:0" --button="Cancel:1") || return 1
	else
		selected=$(zenity --list --checklist \
			"${_zenity_icon_args[@]}" \
			--title "$_title" \
			--text "Choose games to install" \
			--width 980 --height 560 \
			--column "Install" --column "Game" --column "Type" --column "Popularity" --column "Flatpak ID" --column "Summary" \
			"${ui_rows[@]}" \
			--print-column=5 --hide-column=5 --separator=$'\n' \
			--ok-label "Install Games" --cancel-label "Cancel") || return 1
	fi

	if [[ -z "$selected" ]]; then
		return 2
	fi

	printf '%s\n' "$selected"
}

install_games() {
	local selected="$1" total count app_id row name rc=0
	local -a pipeline_status=()
	local -a selected_apps=()
	local -A game_name_by_id=()
	# Normalize dialog output because YAD may emit blank lines between selected rows.
	mapfile -t selected_apps < <(
		printf '%s\n' "$selected" | sed '/^[[:space:]]*$/d'
	)
	total="${#selected_apps[@]}"
	_selected_game_count="$total"
	count=0
	_install_summary_file="$(mktemp "${TMPDIR:-/tmp}/rtd-office-games-summary.XXXXXX")" || return 1

	for row in "${GAME_CATALOG[@]}"; do
		IFS='|' read -r app_id name _ <<<"$row"
		game_name_by_id["$app_id"]="$name"
	done

	# Feed installation messages and percentages directly into the graphical progress dialog.
	{
		printf '# Installing selected games from Flathub...\n'
		for app_id in "${selected_apps[@]}"; do
			((count++))
			name="${game_name_by_id[$app_id]:-$app_id}"
			printf '# Installing %s (%s of %s)\n' "$name" "$count" "$total"
			if ! software::from_flathub.org "$app_id" "--${_install_scope}"; then
				rc=1
				printf 'failed\t%s\n' "$name" >>"$_install_summary_file"
				printf '# Failed: %s\n' "$name"
			elif [[ "${_RTD_FLATHUB_ACTION_RESULT:-}" == "already-installed" ]]; then
				printf 'already-installed\t%s\n' "$name" >>"$_install_summary_file"
				printf '# Already installed: %s\n' "$name"
			else
				printf 'installed\t%s\n' "$name" >>"$_install_summary_file"
			fi
			printf '%s\n' $(( count * 100 / total ))
		done
		exit "$rc"
	} 2>&1 | office_games::log_progress_output | show_progress
	pipeline_status=("${PIPESTATUS[@]}")
	((pipeline_status[2] == 0)) || return 130
	return "${pipeline_status[0]}"
}

office_games::log_progress_output() {
	if [[ -n "${_LOGFILE:-}" ]]; then
		tee -a "$_LOGFILE"
	else
		cat
	fi
}

show_progress() {
	if [[ "$_ui_tool" == "yad" ]]; then
		yad --progress \
			"${_yad_icon_args[@]}" \
			--text="Installing selected Flatpak games" \
			--width 760 --height 430 --center \
			--percentage=0 \
			--auto-close --auto-kill \
			--enable-log --log-expanded --log-on-top --log-height 260 \
			--button="Cancel:1"
	else
		zenity --progress \
			"${_zenity_icon_args[@]}" \
			--title "$_title" \
			--text "Installing selected Flatpak games" \
			--width 620 \
			--percentage=0 \
			--auto-close --auto-kill
	fi
}

build_install_summary() {
	local heading="${1:-Installation complete}" status name
	local installed=0
	local already_installed=0
	local failed=0
	local failed_names=""

	# Turn the per-game result file into a concise completion message.
	while IFS=$'\t' read -r status name; do
		[[ -n "$status" ]] || continue
		case "$status" in
			installed)
				((installed+=1))
				;;
			already-installed)
				((already_installed+=1))
				;;
			failed)
				((failed+=1))
				failed_names+="${failed_names:+, }${name}"
				;;
		esac
	done <"${_install_summary_file:-/dev/null}"

	[[ -n "$_install_summary_file" ]] && rm -f -- "$_install_summary_file"
	_install_summary_file=""
	_install_summary="<b>${heading}</b>\n\nScope: ${_install_scope}\nSelected: ${_selected_game_count}\nInstalled: ${installed}\nAlready available: ${already_installed}\nFailed: ${failed}"
	[[ -n "$failed_names" ]] && _install_summary+="\n\nFailed games: ${failed_names}"
}


#::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::
#::::::::::::::                                          ::::::::::::::::::::::
#::::::::::::::          Script Executive                ::::::::::::::::::::::
#::::::::::::::                                          ::::::::::::::::::::::
#::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::

main() {
	local selected_games select_status install_status
	# Handle public options and the internal elevated setup modes first.
	parse_args "$@" || exit $?
	if ((_show_help)); then
		usage
		exit 0
	fi

	# Load the shared RTD helpers before checking dependencies or installing applications.
	rtd::bootstrap_library "_rtd_library" || {
		write_error "Unable to load the RTD function library."
		exit 1
	}
	# Logging is useful for diagnostics, but a logging failure must not block the installer.
	if _LOGFILE="$(system::determine_logfile)"; then
		export _LOGFILE
	else
		unset _LOGFILE
		printf 'WARN: Unable to determine a writable log file; continuing without logging.\n' >&2
	fi
	if [[ -n "$_setup_ui_dependency" ]]; then
		software::check_native_package_dependency "$_setup_ui_dependency"
		exit $?
	fi
	if ((_setup_flatpak_capability)); then
		software::ensure_flatpak_package_managment
		exit $?
	fi
	# Start the interactive workflow after elevated helper invocations have been handled.
	write_information "Starting ${_scriptname}; log file: ${_LOGFILE:-unavailable}"
	detect_ui_tool || exit 1
	show_welcome || exit 0
	ensure_flatpak_capability_for_installer
	case $? in
		0)
			;;
		2)
			ui_message info "$_title" "<b>Installation canceled</b>\n\nFlatpak support was not changed and no games were installed."
			exit 0
			;;
		*)
			ui_message error "$_title" "Flatpak capability could not be configured. Review the terminal output or RTD log."
			exit 1
			;;
	esac
	# Collect the install scope and selected games before starting any application installs.
	choose_scope || {
		ui_message info "$_title" "<b>Installation canceled</b>\n\nNo games were installed."
		exit 0
	}
	selected_games="$(select_games)"
	select_status=$?
	case "$select_status" in
		0)
			;;
		1)
			ui_message info "$_title" "<b>Installation canceled</b>\n\nNo games were installed."
			exit 0
			;;
		2)
			ui_message warning "$_title" "<b>No games selected</b>\n\nSelect at least one game to start an installation."
			exit 0
			;;
		*)
			ui_message error "$_title" "The game selection dialog failed."
			exit 1
			;;
	esac
	# Install each selected Flatpak and present a summary that distinguishes cancellation from failure.
	write_information "Installing selected games for scope: ${_install_scope}"
	if install_games "$selected_games"; then
		build_install_summary
		ui_message info "$_title" "$_install_summary"
	else
		install_status=$?
		if ((install_status == 130)); then
			build_install_summary "Installation canceled"
			ui_message warning "$_title" "${_install_summary}\n\nThe remaining games were not installed."
			exit 0
		else
			build_install_summary "Installation failed"
			ui_message error "$_title" "${_install_summary}\n\nReview the terminal output or RTD log for details."
			exit 1
		fi
	fi
}

trap office_games::cleanup EXIT
trap 'office_games::handle_signal 130' INT
trap 'office_games::handle_signal 143' TERM

main "$@"
exit $?

