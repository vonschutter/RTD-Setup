			--text-align=left \
			--width=720 --height=390 \
			--button="Continue:0" --button="Cancel:1"
	else
		zenity --question \
			"${_zenity_icon_args[@]}" \
			--title "$_title" \
			--text "Choose from a curated collection of board, card, tile, and puzzle games from Flathub.\n\nThe installer will verify Flatpak support before showing the game list." \
			--width 560 \
