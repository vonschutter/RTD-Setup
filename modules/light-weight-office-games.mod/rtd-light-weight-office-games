#::::::::::::::                                          ::::::::::::::::::::::
#::::::::::::::          Script Executive                ::::::::::::::::::::::
#::::::::::::::                                          ::::::::::::::::::::::
#::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::

main() {
	local selected_games select_status install_status
	parse_args "$@" || exit $?
	if ((_show_help)); then
		usage
		exit 0
	fi

	rtd::bootstrap_library "_rtd_library" || {
		write_error "Unable to load the RTD function library."
		exit 1
	}
	if [[ -n "$_setup_ui_dependency" ]]; then
		software::check_native_package_dependency "$_setup_ui_dependency"
		exit $?
	fi
	if ((_setup_flatpak_capability)); then
		software::ensure_flatpak_package_managment
		exit $?
	fi
	write_information "Starting ${_scriptname}; log file: ${_LOGFILE:-default RTD log}"
	detect_ui_tool || exit 1
	show_welcome || exit 0
	ensure_flatpak_capability_for_installer
	case $? in
		0)
			;;
		2)
			ui_message info "$_title" "<b>Installation canceled</b>\n\nFlatpak support was not changed and no games were installed."
			exit 0
			;;
		*)
			ui_message error "$_title" "Flatpak capability could not be configured. Review the terminal output or RTD log."
			exit 1
			;;
	esac
	choose_scope || {
		ui_message info "$_title" "<b>Installation canceled</b>\n\nNo games were installed."
		exit 0
	}
	selected_games="$(select_games)"
	select_status=$?
	case "$select_status" in
		0)
			;;
		1)
			ui_message info "$_title" "<b>Installation canceled</b>\n\nNo games were installed."
			exit 0
			;;
		2)
			ui_message warning "$_title" "<b>No games selected</b>\n\nSelect at least one game to start an installation."
			exit 0
			;;
		*)
			ui_message error "$_title" "The game selection dialog failed."
			exit 1
			;;
	esac
	write_information "Installing selected games for scope: ${_install_scope}"
	if install_games "$selected_games"; then
		build_install_summary
		ui_message info "$_title" "$_install_summary"
	else
		install_status=$?
		if ((install_status == 130)); then
			build_install_summary "Installation canceled"
			ui_message warning "$_title" "${_install_summary}\n\nThe remaining games were not installed."
			exit 0
		else
			build_install_summary "Installation failed"
			ui_message error "$_title" "${_install_summary}\n\nReview the terminal output or RTD log for details."
			exit 1
		fi
	fi
}

main "$@"
exit $?

