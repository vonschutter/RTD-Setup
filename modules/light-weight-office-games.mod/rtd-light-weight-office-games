usage() {
	cat <<USAGE
Usage:
  ${_scriptname} [--yad | --zenity] [--help]

Launches a graphical installer for lightweight Flatpak games.

Options:
  --yad       Use YAD dialogs. This is the preferred default when available.
  --zenity    Use Zenity dialogs instead of YAD.
  -h, --help  Show this help text.
USAGE
}

parse_args() {
	local requested_tool

	while (($# > 0)); do
		case "$1" in
			--yad|--zenity)
				requested_tool="${1#--}"
				if [[ -n "$_requested_ui_tool" && "$_requested_ui_tool" != "$requested_tool" ]]; then
					printf 'ERROR: Use either --yad or --zenity, not both.\n' >&2
					return 2
				fi
				_requested_ui_tool="$requested_tool"
			;;
			-h|--help)
				_show_help=1
			;;
			--setup-flatpak-capability)
				_setup_flatpak_capability=1
			;;
			--setup-ui-dependency)
				case "${2:-}" in
					yad|zenity)
						_setup_ui_dependency="$2"
						shift
					;;
					*)
						printf 'ERROR: --setup-ui-dependency requires yad or zenity.\n' >&2
						return 2
					;;
				esac
			;;
			*)
				printf 'ERROR: Unknown option: %s\n' "$1" >&2
				usage >&2
				return 2
			;;
		esac
		shift
	done
}

ui_message() {
	local kind="$1" title="$2" message="$3"
	case "$_ui_tool" in
		yad)
			yad "--${kind}" "${_yad_icon_args[@]}" --title "$title" --text "$message" --width 560 --button="OK:0"
		;;
		zenity)
			zenity "--${kind}" "${_zenity_icon_args[@]}" --title "$title" --text "$message" --width 520
		;;
		*)
			printf '%s: %s\n' "$title" "$message"
		;;
	esac
}

detect_ui_tool() {
	if [[ -z "${DISPLAY:-}" && -z "${WAYLAND_DISPLAY:-}" ]]; then
		write_error "This installer requires a graphical desktop session. DISPLAY and WAYLAND_DISPLAY are both unset."
		return 1
	fi

	if [[ -n "$_requested_ui_tool" ]]; then
		command -v "$_requested_ui_tool" >/dev/null 2>&1 || install_requested_ui_tool "$_requested_ui_tool" || return 1
		_ui_tool="$_requested_ui_tool"
	elif command -v yad >/dev/null 2>&1; then
		_ui_tool="yad"
	elif command -v zenity >/dev/null 2>&1; then
		_ui_tool="zenity"
	else
		confirm_ui_tool_installation || {
			write_error "This installer requires YAD or Zenity."
			return 1
		}
		if install_ui_dependency yad; then
			_ui_tool="yad"
		else
			write_warning "YAD could not be installed. Trying Zenity instead."
			install_ui_dependency zenity || {
				write_error "Unable to install YAD or Zenity."
				return 1
			}
			_ui_tool="zenity"
		fi
	fi
	system::log_item "Using UI tool: ${_ui_tool}${_requested_ui_tool:+ (requested)}"
}

confirm_ui_tool_installation() {
	local answer=""

	if [[ -r /dev/tty && -w /dev/tty ]]; then
		printf '\n%s\n' "A graphical dialog tool is required. May RTD install YAD or, if YAD is unavailable, Zenity? [y/N] " >/dev/tty
		read -r answer </dev/tty || return 1
	elif [[ -t 0 ]]; then
		printf '\n%s\n' "A graphical dialog tool is required. May RTD install YAD or, if YAD is unavailable, Zenity? [y/N] "
		read -r answer || return 1
	else
		write_error "YAD and Zenity are missing. Install one of them and rerun ${_scriptname}."
		return 1
	fi

	[[ "$answer" =~ ^[Yy]([Ee][Ss])?$ ]]
}

install_ui_dependency() {
	local dependency="$1"

	write_information "Installing graphical dialog dependency: ${dependency}."
	if ((EUID == 0)); then
		software::check_native_package_dependency "$dependency"
	else
		( security::ensure_admin --sudo --setup-ui-dependency "$dependency" )
	fi
	hash -r
	command -v "$dependency" >/dev/null 2>&1
}

install_requested_ui_tool() {
	local dependency="$1"

	confirm_ui_tool_installation || {
		write_error "Requested UI backend '${dependency}' is not installed."
		return 1
	}
	install_ui_dependency "$dependency" || {
		write_error "Requested UI backend '${dependency}' could not be installed."
		return 1
	}
}

flatpak_capability_is_present() {
	command -v flatpak >/dev/null 2>&1 || return 1
	flatpak remotes --system --columns=name 2>/dev/null | grep -qx "flathub" || return 1
	flatpak info --system com.github.tchx84.Flatseal >/dev/null 2>&1 || return 1
}

confirm_flatpak_capability_setup() {
	local message="<b>Flatpak support is required</b>\n\nThis installer needs Flatpak, the Flathub application source, and the Flatseal permissions manager.\n\nMay RTD add the missing Flatpak support now? Administrative authentication may be requested."

	case "$_ui_tool" in
		yad)
			yad --question \
				"${_yad_icon_args[@]}" \
				--text="$message" \
				--text-align=left \
				--width=600 \
				--button="Add Flatpak Support:0" --button="Cancel:1"
		;;
		zenity)
			zenity --question \
				"${_zenity_icon_args[@]}" \
				--title "$_title" \
				--text "$message" \
				--width 560 \
				--ok-label "Add Flatpak Support" --cancel-label "Cancel"
		;;
	esac
}

show_flatpak_setup_progress() {
	if [[ "$_ui_tool" == "yad" ]]; then
		yad --progress \
			"${_yad_icon_args[@]}" \
			--text="Adding Flatpak support" \
			--width 760 --height 430 --center \
			--pulsate --auto-close --no-cancel \
			--enable-log --log-expanded --log-on-top --log-height 260
	else
		zenity --progress \
			"${_zenity_icon_args[@]}" \
			--title "$_title" \
			--text "Adding Flatpak support" \
			--width 560 \
			--pulsate --auto-close --no-cancel
	fi
}

setup_flatpak_capability_as_admin() {
	if ((EUID == 0)); then
		software::ensure_flatpak_package_managment
	else
		security::ensure_admin --sudo --setup-flatpak-capability
	fi
}

ensure_flatpak_capability_for_installer() {
	local -a pipeline_status=()

	if flatpak_capability_is_present; then
		software::ensure_flatpak_package_managment
		return
	fi

	confirm_flatpak_capability_setup || return 2
	write_information "User approved Flatpak capability setup."
	{
		printf '# Adding Flatpak support...\n'
		setup_flatpak_capability_as_admin
	} 2>&1 | show_flatpak_setup_progress
	pipeline_status=("${PIPESTATUS[@]}")

	((pipeline_status[1] == 0)) || return 1
	((pipeline_status[0] == 0)) || return "${pipeline_status[0]}"

	# Refresh this user-level process after the elevated setup subprocess completes.
	software::ensure_flatpak_package_managment
}

show_welcome() {
	local message="<b>Lightweight Office Games</b>\n\nChoose from a curated collection of board, card, tile, and puzzle games from Flathub.\n\nThe installer will verify Flatpak support before showing the game list. Administrative authentication is requested only when system setup or an all-users installation requires it."

	if [[ "$_ui_tool" == "yad" ]]; then
		yad --question \
			"${_yad_sidebar_args[@]}" \
			--text="$message" \
			--text-align=left \
			--width=720 --height=390 \
			--button="Continue:0" --button="Cancel:1"
	else
		zenity --question \
			"${_zenity_icon_args[@]}" \
			--title "$_title" \
			--text "Choose from a curated collection of board, card, tile, and puzzle games from Flathub.\n\nThe installer will verify Flatpak support before showing the game list." \
			--width 560 \
			--ok-label "Continue" --cancel-label "Cancel"
	fi
}

choose_scope() {
	local key left_pid right_pid result_file selected yad_status
	if [[ "$_ui_tool" == "yad" && -n "${DISPLAY:-}" && -r "$_sidebar_image" ]]; then
		key=$((BASHPID + RANDOM))
		result_file="$(mktemp "/tmp/${_scriptname}.scope.XXXXXX")" || return 1

		GDK_BACKEND=x11 yad --plug="$key" --tabnum=1 \
			--picture --filename="$_sidebar_image" --size=fit --no-buttons \
			>/dev/null 2>&1 &
		left_pid=$!

		GDK_BACKEND=x11 yad --plug="$key" --tabnum=2 \
			--list --radiolist --no-buttons \
			--text="<b>Install scope</b>\nChoose who should have access to these games." \
			--text-align=left \
			--column="" --column="Install for" --column="Description" --column="Scope:HD" \
			TRUE "Just me" "Install for the current user without changing the whole system." "user" \
			FALSE "All users" "Install system-wide. This may require sudo or PolicyKit." "system" \
			--print-column=4 --separator="" \
			--grid-lines=horizontal --wrap-cols=3 --wrap-width=280 --expand-column=3 \
			>"$result_file" 2>/dev/null &
		right_pid=$!

		GDK_BACKEND=x11 yad --paned --key="$key" --orient=horizontal --splitter=225 \
			"${_yad_common_args[@]}" \
			--width=745 --height=420 \
			--button="Continue:0" --button="Cancel:1"
		yad_status=$?

		if ((yad_status != 0)); then
			kill "$left_pid" "$right_pid" 2>/dev/null || true
		fi
		wait "$left_pid" "$right_pid" 2>/dev/null || true
		selected="$(<"$result_file")"
		rm -f "$result_file"
		((yad_status == 0)) || return 1
	elif [[ "$_ui_tool" == "yad" ]]; then
		selected=$(yad --list --radiolist \
			"${_yad_sidebar_args[@]}" \
			--text="<b>Install scope</b>\nChoose whether these games should be installed only for you or for all users." \
			--text-align=left \
			--width 760 --height 360 \
			--column "" --column "Scope" --column "Description" \
			TRUE "user" "Install for the current user without changing the whole system." \
			FALSE "system" "Install for all users. This may require sudo or PolicyKit." \
			--print-column=2 --separator="" \
			--button="Continue:0" --button="Cancel:1") || return 1
	else
		selected=$(zenity --list --radiolist \
			"${_zenity_icon_args[@]}" \
			--title "$_title" \
			--text "Choose installation scope" \
			--width 640 --height 240 \
			--column "" --column "Scope" --column "Description" \
			TRUE "user" "Install for the current user only." \
			FALSE "system" "Install for all users.") || return 1
	fi
	_install_scope="${selected:-user}"
}

select_games() {
	local selected row app_id name type installs favorites summary
	local -a ui_rows=()

	for row in "${GAME_CATALOG[@]}"; do
		IFS='|' read -r app_id name type installs favorites summary <<<"$row"
		ui_rows+=(TRUE "$name" "$type" "${installs}/mo, ${favorites} fav" "$app_id" "$summary")
	done

	if [[ "$_ui_tool" == "yad" ]]; then
		selected=$(yad --list --checklist \
			"${_yad_icon_args[@]}" \
			--text="<b>Choose games to install</b>\nCurated from popular Flathub board, card, tile, and puzzle games. Uncheck anything you do not want." \
			--width 980 --height 560 --center \
			--column "Install" --column "Game" --column "Type" --column "Popularity" --column "Flatpak ID" --column "Summary" \
			"${ui_rows[@]}" \
			--print-column=5 --hide-column=5 --separator=$'\n' \
			--grid-lines=horizontal --search-column=2 --expand-column=6 --wrap-cols=6 --wrap-width=340 \
			--button="Install Games:0" --button="Cancel:1") || return 1
	else
		selected=$(zenity --list --checklist \
			"${_zenity_icon_args[@]}" \
			--title "$_title" \
			--text "Choose games to install" \
			--width 980 --height 560 \
			--column "Install" --column "Game" --column "Type" --column "Popularity" --column "Flatpak ID" --column "Summary" \
			"${ui_rows[@]}" \
			--print-column=5 --hide-column=5 --separator=$'\n' \
			--ok-label "Install Games" --cancel-label "Cancel") || return 1
	fi

	if [[ -z "$selected" ]]; then
		return 2
	fi

	printf '%s\n' "$selected"
}

install_games() {
	local selected="$1" total count app_id row name rc=0
	local -a pipeline_status=()
	local -a selected_apps=()
	local -A game_name_by_id=()
	mapfile -t selected_apps <<<"$selected"
	total="${#selected_apps[@]}"
	_selected_game_count="$total"
	count=0
	_install_summary_file="$(mktemp "${TMPDIR:-/tmp}/rtd-office-games-summary.XXXXXX")" || return 1

	for row in "${GAME_CATALOG[@]}"; do
		IFS='|' read -r app_id name _ <<<"$row"
		game_name_by_id["$app_id"]="$name"
	done

	{
		printf '# Installing selected games from Flathub...\n'
		for app_id in "${selected_apps[@]}"; do
			((count++))
			name="${game_name_by_id[$app_id]:-$app_id}"
			printf '# Installing %s (%s of %s)\n' "$name" "$count" "$total"
			if ! software::from_flathub.org "$app_id" "--${_install_scope}"; then
				rc=1
				printf 'failed\t%s\n' "$name" >>"$_install_summary_file"
				printf '# Failed: %s\n' "$name"
			elif [[ "${_RTD_FLATHUB_ACTION_RESULT:-}" == "already-installed" ]]; then
				printf 'already-installed\t%s\n' "$name" >>"$_install_summary_file"
				printf '# Already installed: %s\n' "$name"
			else
				printf 'installed\t%s\n' "$name" >>"$_install_summary_file"
			fi
			printf '%s\n' $(( count * 100 / total ))
		done
		exit "$rc"
	} 2>&1 | show_progress
	pipeline_status=("${PIPESTATUS[@]}")
	((pipeline_status[1] == 0)) || return 130
	return "${pipeline_status[0]}"
}

show_progress() {
	if [[ "$_ui_tool" == "yad" ]]; then
		yad --progress \
			"${_yad_icon_args[@]}" \
			--text="Installing selected Flatpak games" \
			--width 760 --height 430 --center \
			--percentage=0 \
			--auto-close --auto-kill \
			--enable-log --log-expanded --log-on-top --log-height 260 \
			--button="Cancel:1"
	else
		zenity --progress \
			"${_zenity_icon_args[@]}" \
			--title "$_title" \
			--text "Installing selected Flatpak games" \
			--width 620 \
			--percentage=0 \
			--auto-close --auto-kill
	fi
}

build_install_summary() {
	local heading="${1:-Installation complete}" status name
	local installed=0
	local already_installed=0
	local failed=0
	local failed_names=""

	while IFS=$'\t' read -r status name; do
		[[ -n "$status" ]] || continue
		case "$status" in
			installed)
				((installed+=1))
				;;
			already-installed)
				((already_installed+=1))
				;;
			failed)
				((failed+=1))
				failed_names+="${failed_names:+, }${name}"
				;;
		esac
	done <"${_install_summary_file:-/dev/null}"

	rm -f -- "${_install_summary_file:-}"
	_install_summary_file=""
	_install_summary="<b>${heading}</b>\n\nScope: ${_install_scope}\nSelected: ${_selected_game_count}\nInstalled: ${installed}\nAlready available: ${already_installed}\nFailed: ${failed}"
	[[ -n "$failed_names" ]] && _install_summary+="\n\nFailed games: ${failed_names}"
}


