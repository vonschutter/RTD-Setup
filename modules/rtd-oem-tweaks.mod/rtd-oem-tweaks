main() {
	local selection
	local menu_rc

	if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
		cat <<EOF
Usage:
  $(basename "$0") [--help|-h] [--status] [--list-tweaks]
  $(basename "$0") [--apply <tweak-id>...]
  $(basename "$0") [--set <tweak-id> <on|off>]
  $(basename "$0") [--list-profiles]
  $(basename "$0") [--apply-profile <profile-name>]
  $(basename "$0") [--gtk|--zenity]

Description:
  Open the RTD OEM GNOME tweaks selector and apply one or more desktop tweaks.
  Profiles are stored under ${PROFILE_DIR}.
EOF
		exit 0
	fi

	if ! rtd::bootstrap_library "_rtd_library"; then
		echo "Failed to load _rtd_library." >&2
		exit 1
	fi

	if ! dependency::os_linux; then
		write_error "This module is intended for Linux systems only."
		exit 1
	fi

	if [[ "${UID}" -eq 0 ]]; then
		write_error "Run this tool as the desktop user, not as root."
		exit 1
	fi

	if ! dependency::desktop gnome; then
		if command -v zenity >/dev/null 2>&1; then
			zenity --error --title "${PUBLICATION}" --text "GNOME desktop session not detected."
		else
			write_error "GNOME desktop session not detected."
		fi
		exit 1
	fi

	command -v gsettings >/dev/null 2>&1 || {
		write_error "Required command missing: gsettings"
		exit 1
	}

	initialize_menu_state

	case "${1:-}" in
	--status)
		print_status
		exit 0
		;;
	--list-tweaks)
		print_tweak_catalog
		exit 0
		;;
	--apply)
		shift
		apply_tweaks_cli "$@"
		exit $?
		;;
	--set)
		shift
		set_tweak_state_cli "${1:-}" "${2:-}"
		exit $?
		;;
	--list-profiles)
		print_profile_list
		exit 0
		;;
	--apply-profile)
		shift
		apply_profile_cli "${1:-}"
		exit $?
		;;
	--gtk)
		shift
		launch_gtk_frontend "$@" || {
			write_error "Python GTK frontend is not available."
			exit 1
		}
		;;
	"")
		launch_gtk_frontend || true
		;;
	--zenity)
		shift
		;;
	*)
		write_error "Unknown option: $1"
		exit 64
		;;
	esac

	command -v zenity >/dev/null 2>&1 || software::check_native_package_dependency zenity || exit 1

	while true; do
		selection="$(show_gtk_menu 2>/dev/null)"
		menu_rc=$?

		case "${selection}" in
		"SAVE PROFILE")
			save_profile
			initialize_menu_state
			continue
			;;
		"LOAD PROFILE")
			load_profile
			initialize_menu_state
			continue
			;;
		"DELETE PROFILE")
			delete_profile
			initialize_menu_state
			continue
			;;
		esac

		case "${menu_rc}" in
		0)
			capture_menu_selection "${selection}"
			run_selected_tweaks
			sync_menu_state_from_selection
			;;
		*)
			exit 0
			;;
		esac
	done
}

main "$@"
