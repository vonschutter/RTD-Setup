rtd::bootstrap_library() {
	local library_name="${1:-_rtd_library}" minimum_version="" loaded_version path script_dir src_url tmp rc check
	local -a checks=()

	[[ $# -gt 0 && "${1:-}" != --* ]] && { library_name="$1"; shift; }
	[[ $# -gt 0 && "${1:-}" != --* ]] && { minimum_version="$1"; shift; }
	while [[ $# -gt 0 ]]; do
		case "$1" in
			--version|--check)
				[[ -n "${2:-}" ]] || { echo "Missing value for $1" >&2; return 1; }
				[[ "$1" == "--version" ]] && minimum_version="$2" || checks+=("$2")
				shift 2
			;;
			*)
				echo "Unknown rtd::bootstrap_library option: $1" >&2
				return 1
			;;
		esac
	done

	[[ "$library_name" == "_rtd_library" && ${#checks[@]} -eq 0 ]] && checks=(system::log_item library::apply_rtd_defaults)

	rtd::bootstrap_library::ok() {
		loaded_version="${RTD_VERSION:-${RTDFUNCTIONS:-}}"
		if [[ "$library_name" == "_rtd_library" && -n "$minimum_version" ]]; then
			[[ -n "$loaded_version" ]] || return 1
			[[ "$(printf '%s\n%s\n' "$minimum_version" "$loaded_version" | sort -V | tail -n 1)" == "$loaded_version" ]] || return 1
		fi
		for check in "${checks[@]}"; do declare -F "$check" >/dev/null 2>&1 || return 1; done
	}

	[[ "$library_name" == "_rtd_library" && -n "$loaded_version" ]] && rtd::bootstrap_library::ok && return 0

	script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
	for path in \
		"${script_dir}/${library_name}" \
		"${script_dir}/../core/${library_name}" \
		"${script_dir}/../../core/${library_name}" \
		"/opt/${_TLA:-${_tla:-rtd}}/core/${library_name}" \
		"/opt/rtd/core/${library_name}" \
		"${HOME:-}/GIT/RTD-Setup/core/${library_name}" \
		"${HOME:-}/RTD-Setup/core/${library_name}"; do
		[[ -r "$path" ]] || continue
		# shellcheck source=/dev/null
		source "$path" ""
		rc=$?
		[[ $rc -eq 0 ]] && rtd::bootstrap_library::ok && return 0
	done

	src_url="https://github.com/${_GIT_PROFILE:-${GIT_Profile:-vonschutter}}/RTD-Setup/raw/main/core/${library_name}"
	tmp="$(mktemp "/tmp/${library_name}.XXXXXX" 2>/dev/null || echo "/tmp/${library_name}.$$")"
	rc=0
	if command -v curl >/dev/null 2>&1; then
		curl -fsSL "$src_url" -o "$tmp" || rc=$?
	elif command -v wget >/dev/null 2>&1; then
		wget -qO "$tmp" "$src_url" || rc=$?
	else
		rc=1
	fi
	[[ ${rc:-0} -eq 0 ]] || { rm -f "$tmp"; return "$rc"; }

	# shellcheck source=/dev/null
	source "$tmp" ""
	rc=$?
	rm -f "$tmp"
	[[ $rc -eq 0 ]] || return "$rc"
	rtd::bootstrap_library::ok && return 0

	echo "Loaded $library_name, but the requested version/functions are not available." >&2
	return 1
}

checkbox_state() {
	if [[ "$1" == "TRUE" ]]; then
		return 0
	fi

	return 1
}

gtk4_settings_file() {
	printf '%s\n' "${XDG_CONFIG_HOME:-${HOME}/.config}/gtk-4.0/settings.ini"
}

startup_sound_autostart_file() {
	printf '%s\n' "${XDG_CONFIG_HOME:-${HOME}/.config}/autostart/rtd-startup-sound.desktop"
}

gsettings_value_is() {
	local schema="$1"
	local key="$2"
	local expected="$3"
	local current

	current="$(gsettings get "${schema}" "${key}" 2>/dev/null)" || return 1
	[[ "${current}" == "${expected}" ]]
}

compact_gvariant() {
	printf '%s' "$1" | tr -d '[:space:]'
}

gsettings_compact_value_is() {
	local schema="$1"
	local key="$2"
	local expected="$3"
	local current

	current="$(gsettings get "${schema}" "${key}" 2>/dev/null)" || return 1
	[[ "$(compact_gvariant "${current}")" == "$(compact_gvariant "${expected}")" ]]
}

gsettings_value_contains() {
	local schema="$1"
	local key="$2"
	local needle="$3"
	local current

	current="$(gsettings get "${schema}" "${key}" 2>/dev/null)" || return 1
	[[ "${current}" == *"${needle}"* ]]
}

gtk4_setting_is() {
	local key="$1"
	local expected="$2"
	local gtk4_file current

	gtk4_file="$(gtk4_settings_file)"
	[[ -f "${gtk4_file}" ]] || return 1

	current="$(grep -E "^${key}=" "${gtk4_file}" 2>/dev/null | tail -n1 | cut -d= -f2-)"
	[[ "${current}" == "${expected}" ]]
}

gtk4_custom_theme_present() {
	local gtk4_file

	gtk4_file="$(gtk4_settings_file)"
	[[ -f "${gtk4_file}" ]] || return 1
	grep -q '^gtk-theme-name=' "${gtk4_file}" &&
		grep -q '^gtk-icon-theme-name=' "${gtk4_file}" &&
		grep -q '^gtk-application-prefer-dark-theme=' "${gtk4_file}"
}

dconf_key_unset() {
	local key_path="$1"

	command -v dconf >/dev/null 2>&1 || return 1
	[[ -z "$(dconf read "${key_path}" 2>/dev/null)" ]]
}

terminal_profiles() {
	gsettings get org.gnome.Terminal.ProfilesList list 2>/dev/null | tr -d "[]',"
}

default_terminal_profile() {
	local default_uuid profiles

	default_uuid="$(gsettings get org.gnome.Terminal.ProfilesList default 2>/dev/null | tr -d "'")"
	if [[ -n "${default_uuid}" && "${default_uuid}" != "''" ]]; then
		printf '%s\n' "${default_uuid}"
		return 0
	fi

	profiles="$(terminal_profiles)"
	printf '%s\n' "${profiles%% *}"
}

terminal_profile_schema() {
	local uuid="$1"

	printf 'org.gnome.Terminal.Legacy.Profile:/org/gnome/terminal/legacy/profiles:/:%s/\n' "${uuid}"
}

tilix_expected_terminal_font() {
	if command -v fc-list >/dev/null 2>&1 && fc-list | grep -qi "SauceCodePro"; then
		printf "'%s'\n" "SauceCodePro Nerd Font 12"
	else
		printf "'%s'\n" "Monospace 12"
	fi
}

terminal_profile_matches_defaults() {
	local schema="$1"

	gsettings_value_is "${schema}" font "'Monospace 10'" &&
		gsettings_value_is "${schema}" use-system-font "false" &&
		gsettings_value_is "${schema}" audible-bell "false" &&
		gsettings_value_is "${schema}" use-theme-colors "false" &&
		gsettings_value_is "${schema}" background-color "'#000000'" &&
		gsettings_value_is "${schema}" foreground-color "'#AFAFAF'" &&
		gsettings_value_is "${schema}" use-transparent-background "true" &&
		gsettings_value_is "${schema}" background-transparency-percent "20" &&
		gsettings_value_is "${schema}" bold-is-bright "true"
}

tilix_terminal_defaults_applied() {
	local default_uuid schema expected_font

	default_uuid="$(default_terminal_profile)"
	[[ -n "${default_uuid}" ]] || return 1
	schema="$(terminal_profile_schema "${default_uuid}")"
	expected_font="$(tilix_expected_terminal_font)"

	gsettings_value_is "${schema}" use-transparent-background "true" &&
		gsettings_value_is "${schema}" background-transparency-percent "20" &&
		gsettings_value_is "${schema}" default-size-columns "100" &&
		gsettings_value_is "${schema}" use-theme-transparency "false" &&
		gsettings_value_is "${schema}" scrollback-lines "10000" &&
		gsettings_value_is "${schema}" font "${expected_font}" &&
		gsettings_value_is "${schema}" use-system-font "false" &&
		gsettings_value_is "${schema}" bold-is-bright "true"
}

terminal_preferences_applied() {
	local profiles uuid schema

	profiles="$(terminal_profiles)"
	[[ -n "${profiles}" ]] || return 1

	for uuid in ${profiles}; do
		schema="$(terminal_profile_schema "${uuid}")"
		terminal_profile_matches_defaults "${schema}" || return 1
	done

	return 0
}

expected_extensions_list() {
	local distro_type
	local -a extensions_to_enable
	local gsettings_list_format

	distro_type="$(system::distribution_type 2>/dev/null || true)"
	extensions_to_enable=(
		'user-theme@gnome-shell-extensions.gcampax.github.com'
		'caffeine@patapon.info'
		'apps-menu@gnome-shell-extensions.gcampax.github.com'
	)

	case "${distro_type}" in
	ubuntu|pop|mint|zorin|elementary)
		extensions_to_enable+=(
			'tiling-assistant@ubuntu.com'
			'ubuntu-appindicators@ubuntu.com'
		)
		;;
	*)
		extensions_to_enable+=(
			'gTile@vibou'
			'TopIcons@phocean.net'
			'trayIconsReloaded@selfmade.pl'
			'desktop-icons@csoriano'
		)
		;;
	esac

	gsettings_list_format="$(printf "'%s', " "${extensions_to_enable[@]}")"
	printf '[%s]\n' "${gsettings_list_format%, }"
}

startup_sound_enabled() {
	local autostart_file

	autostart_file="$(startup_sound_autostart_file)"
	[[ -f "${autostart_file}" ]] || return 1
	gsettings_value_is org.gnome.desktop.sound event-sounds "true"
}

overlay_folder_matches() {
	local folder_schema="$1"
	local expected_name="$2"
	local expected_categories="$3"

	gsettings_value_is "${folder_schema}" name "'${expected_name}'" &&
		gsettings_compact_value_is "${folder_schema}" categories "${expected_categories}"
}

