initialize_menu_state() {
	local sync_state="${1:-0}"
	local key

	for key in "${MENU_KEYS[@]}"; do
		if tweak_is_applied "${key}"; then
			MENU_APPLIED["${key}"]="Applied"
			[[ "${sync_state}" == "1" ]] && MENU_STATE["${key}"]="TRUE"
		else
			MENU_APPLIED["${key}"]="Not applied"
			[[ "${sync_state}" == "1" ]] && MENU_STATE["${key}"]="FALSE"
		fi
		: "${MENU_STATE[${key}]:=FALSE}"
	done
}

capture_menu_selection() {
	local selection="$1"
	local -a selected_keys
	local key

	for key in "${MENU_KEYS[@]}"; do
		MENU_SELECTION["${key}"]="FALSE"
	done

	[[ -n "${selection}" ]] || return 0
	IFS='|' read -r -a selected_keys <<< "${selection}"

	for key in "${selected_keys[@]}"; do
		[[ -n "${key}" ]] || continue
		MENU_SELECTION["${key}"]="TRUE"
	done
}

sync_menu_state_from_selection() {
	initialize_menu_state 1
}

show_gtk_menu() {
	local -a cmd options
	local key

	cmd=(
		zenity
		--list
		--checklist
		--title "${PUBLICATION} v${VERSION}"
		--width 1160
		--height 700
		--separator "|"
		--print-column 2
		--ok-label "APPLY CHANGES"
		--cancel-label "EXIT"
		--extra-button "SAVE PROFILE"
		--extra-button "LOAD PROFILE"
		--extra-button "DELETE PROFILE"
		--text "Checked tweaks are enabled; unchecked applied tweaks are reset to their defaults.\n\nProfiles are stored in ${PROFILE_DIR}."
		--column "Enabled"
		--column "ID"
		--column "Status"
		--column "Category"
		--column "Tweak"
		--column "Description"
	)

	for key in "${MENU_KEYS[@]}"; do
		options+=(
			"${MENU_STATE[${key}]:-FALSE}"
			"${key}"
			"${MENU_APPLIED[${key}]:-Unknown}"
			"${MENU_CATEGORY[${key}]:-General}"
			"${MENU_TEXT[${key}]}"
			"${MENU_DESCRIPTION[${key}]:-}"
		)
	done

	"${cmd[@]}" "${options[@]}"
}

profile_safe_name() {
	local name="$1"

	name="${name//[^[:alnum:]_.-]/_}"
	printf '%s\n' "${name}"
}

profile_path() {
	local name

	name="$(profile_safe_name "$1")"
	printf '%s/%s.profile\n' "${PROFILE_DIR}" "${name}"
}

profile_exists() {
	[[ -f "$(profile_path "$1")" ]]
}

valid_tweak_key() {
	local wanted="$1"
	local key

	for key in "${MENU_KEYS[@]}"; do
		[[ "${key}" == "${wanted}" ]] && return 0
	done
	return 1
}

reset_menu_selection() {
	local key

	for key in "${MENU_KEYS[@]}"; do
		MENU_STATE["${key}"]="FALSE"
		MENU_SELECTION["${key}"]="FALSE"
	done
}

prompt_profile_name() {
	local name safe_name

	name="$(zenity --entry \
		--title "${PUBLICATION} - Save Profile" \
		--width 560 \
		--text "Enter a profile name. It will be stored in ${PROFILE_DIR}." \
		--entry-text "workstation-default")" || return 1
	safe_name="$(profile_safe_name "${name}")"
	[[ -n "${safe_name}" ]] || {
		zenity --error --title "${PUBLICATION}" --text "Profile name cannot be empty."
		return 1
	}
	printf '%s\n' "${safe_name}"
}

show_profile_builder() {
	local -a options
	local key

	for key in "${MENU_KEYS[@]}"; do
		options+=(
			"${MENU_STATE[${key}]:-FALSE}"
			"${key}"
			"${MENU_CATEGORY[${key}]:-General}"
			"${MENU_TEXT[${key}]}"
			"${MENU_DESCRIPTION[${key}]:-}"
		)
	done

	zenity \
		--list \
		--checklist \
		--title "${PUBLICATION} - Build Profile" \
		--width 1160 \
		--height 700 \
		--separator "|" \
		--print-column 2 \
		--ok-label "SAVE" \
		--cancel-label "CANCEL" \
		--text "Choose the tweaks that should belong to this profile." \
		--column "Include" \
		--column "ID" \
		--column "Category" \
		--column "Tweak" \
		--column "Description" \
		"${options[@]}"
}

save_profile() {
	local selection profile_name profile_file key
	local -a selected_keys

	selection="$(show_profile_builder 2>/dev/null)" || return 0
	[[ -n "${selection}" ]] || {
		zenity --info --title "${PUBLICATION}" --text "No tweaks selected. Profile was not saved."
		return 0
	}
	profile_name="$(prompt_profile_name)" || return 0
	profile_file="$(profile_path "${profile_name}")"

	if [[ -e "${profile_file}" ]]; then
		zenity --question \
			--title "${PUBLICATION}" \
			--width 520 \
			--text "Profile '${profile_name}' already exists. Replace it?" || return 0
	fi

	mkdir -p "${PROFILE_DIR}"
	{
		printf '# RTD OEM Tweaks profile\n'
		printf '# name=%s\n' "${profile_name}"
		printf '# saved_at=%s\n' "$(date --iso-8601=seconds 2>/dev/null || date '+%Y-%m-%dT%H:%M:%S%z')"
		IFS='|' read -r -a selected_keys <<< "${selection}"
		for key in "${selected_keys[@]}"; do
			valid_tweak_key "${key}" && printf '%s\n' "${key}"
		done
	} >"${profile_file}"

	zenity --info --title "${PUBLICATION}" --width 560 --text "Saved profile '${profile_name}' to:\n${profile_file}"
}

choose_profile() {
	local title="$1"
	local -a options
	local profile file

	mkdir -p "${PROFILE_DIR}"
	while IFS= read -r -d '' file; do
		profile="$(basename "${file}" .profile)"
		options+=("${profile}" "${file}")
	done < <(find "${PROFILE_DIR}" -maxdepth 1 -type f -name '*.profile' -print0 2>/dev/null | sort -z)

	if (( ${#options[@]} == 0 )); then
		zenity --info --title "${PUBLICATION}" --text "No tweak profiles found in ${PROFILE_DIR}."
		return 1
	fi

	zenity \
		--list \
		--title "${title}" \
		--width 760 \
		--height 420 \
		--print-column 1 \
		--column "Profile" \
		--column "File" \
		"${options[@]}"
}

load_profile() {
	local profile profile_file line loaded_count=0

	profile="$(choose_profile "${PUBLICATION} - Load Profile")" || return 0
	profile_file="$(profile_path "${profile}")"
	[[ -f "${profile_file}" ]] || {
		zenity --error --title "${PUBLICATION}" --text "Profile file not found: ${profile_file}"
		return 1
	}

	reset_menu_selection
	while IFS= read -r line; do
		[[ -n "${line}" && "${line}" != \#* ]] || continue
		if valid_tweak_key "${line}"; then
			MENU_STATE["${line}"]="TRUE"
			loaded_count=$((loaded_count + 1))
		fi
	done <"${profile_file}"

	zenity --info --title "${PUBLICATION}" --width 560 --text "Loaded profile '${profile}'.\n${loaded_count} tweak(s) selected for apply."
}

delete_profile() {
	local profile profile_file

	profile="$(choose_profile "${PUBLICATION} - Delete Profile")" || return 0
	profile_file="$(profile_path "${profile}")"
	[[ -f "${profile_file}" ]] || return 0
	zenity --question \
		--title "${PUBLICATION}" \
		--width 520 \
		--text "Delete profile '${profile}'?\n\n${profile_file}" || return 0
	rm -f "${profile_file}"
	zenity --info --title "${PUBLICATION}" --text "Deleted profile '${profile}'."
}

prompt_custom_gtk4_theme() {
	local input theme_name icon_name prefer_dark

	input="$(zenity --forms \
		--title "${PUBLICATION} - Custom GTK4 Theme" \
		--width 640 \
		--height 320 \
		--separator "|" \
		--text "Enter GTK4 settings.ini values to write." \
		--add-entry "GTK theme name" \
		--add-entry "Icon theme name" \
		--add-entry "Prefer dark (0 or 1)")" || return 1

	IFS='|' read -r theme_name icon_name prefer_dark <<< "${input}"

	if [[ -z "${theme_name}" || -z "${icon_name}" ]]; then
		zenity --error --title "${PUBLICATION}" --text "Theme and icon names are required."
		return 1
	fi

	if [[ ! "${prefer_dark}" =~ ^[01]$ ]]; then
		zenity --error --title "${PUBLICATION}" --text "Prefer dark must be 0 or 1."
		return 1
	fi

	echo "${theme_name}|${icon_name}|${prefer_dark}"
}

prompt_window_buttons_layout() {
	local layout

	layout="$(zenity --entry \
		--title "${PUBLICATION} - Window Buttons Layout" \
		--width 680 \
		--text "Set custom button layout (example: appmenu:minimize,maximize,close)." \
		--entry-text "appmenu:minimize,maximize,close")" || return 1

	[[ -n "${layout}" ]] || {
		zenity --error --title "${PUBLICATION}" --text "Layout cannot be empty."
		return 1
	}

	echo "${layout}"
}

prompt_startup_sound_file() {
	local sound_file

	sound_file="$(zenity --file-selection \
		--title "${PUBLICATION} - Select Startup Sound" \
		--file-filter "Audio files | *.ogg *.oga *.wav *.mp3 *.flac" \
		--file-filter "All files | *")" || return 1

	[[ -f "${sound_file}" ]] || {
		zenity --error --title "${PUBLICATION}" --text "Selected sound file is invalid."
		return 1
	}

	echo "${sound_file}"
}

run_function_checked() {
	local func="$1"
	shift || true

	if ! declare -F "${func}" >/dev/null 2>&1; then
		write_error "Function not found in loaded library: ${func}"
		return 1
	fi

	"${func}" "$@"
}

apply_gsetting() {
	local schema="$1"
	local key="$2"
	local value="$3"

	gsettings set "${schema}" "${key}" "${value}"
}

reset_gsetting() {
	local schema="$1"
	local key="$2"

	gsettings reset "${schema}" "${key}"
}

reset_terminal_profile() {
	local schema="$1"

	reset_gsetting "${schema}" font || true
	reset_gsetting "${schema}" use-system-font || true
	reset_gsetting "${schema}" audible-bell || true
	reset_gsetting "${schema}" use-theme-colors || true
	reset_gsetting "${schema}" background-color || true
	reset_gsetting "${schema}" foreground-color || true
	reset_gsetting "${schema}" use-transparent-background || true
	reset_gsetting "${schema}" background-transparency-percent || true
	reset_gsetting "${schema}" bold-is-bright || true
	reset_gsetting "${schema}" default-size-columns || true
	reset_gsetting "${schema}" use-theme-transparency || true
	reset_gsetting "${schema}" scrollback-lines || true
}

reset_tweak() {
	local key="$1"
	local profiles uuid schema folder setting_key
	local -a app_folders=(
		accessories chrome-apps games graphics internet office programming science
		sound---video system-tools universal-access wine OEM 3D-Printing Cloud
	)
	local -a dock_keys=(
		click-action dock-position apply-custom-theme custom-background-color
		custom-theme-customize-running-dots custom-theme-running-dots-color
		custom-theme-shrink dock-fixed extend-height force-straight-corner
		icon-size-fixed intellihide-mode isolate-workspaces show-apps-at-top
		unity-backlit-items transparency-mode running-indicator-style background-opacity
	)
	local -a panel_keys=(
		click-action dash-max-icon-size appicon-margin appicon-padding available-monitors
		dot-color-1 dot-color-2 dot-color-3 dot-color-4 dot-color-dominant
		dot-color-override dot-color-unfocused-1 dot-color-unfocused-2
		dot-color-unfocused-3 dot-color-unfocused-4 dot-color-unfocused-different
		dot-style-focused dot-style-unfocused focus-highlight-color
		focus-highlight-dominant force-check-update group-apps hotkeys-overlay-combo
		isolate-monitors isolate-workspaces panel-element-positions
		secondarymenu-contains-showdetails show-appmenu show-favorites
		show-favorites-all-monitors stockgs-keep-dash stockgs-keep-top-panel
		trans-use-custom-bg trans-use-custom-opacity tray-size
	)

	case "${key}" in
	mouse_accel)
		reset_gsetting org.gnome.desktop.peripherals.mouse accel-profile
		;;
	volume_limit)
		reset_gsetting org.gnome.desktop.sound allow-volume-above-100-percent
		;;
	calendar_weekdate)
		reset_gsetting org.gnome.desktop.calendar show-weekdate
		;;
	right_resize)
		reset_gsetting org.gnome.desktop.wm.preferences resize-with-right-button
		;;
	window_buttons|buttons_custom)
		reset_gsetting org.gnome.desktop.wm.preferences button-layout
		;;
	workspaces_all_monitors)
		reset_gsetting org.gnome.shell.overrides workspaces-only-on-primary
		;;
	nautilus_icon_zoom)
		reset_gsetting org.gnome.nautilus.icon-view default-zoom-level
		;;
	nautilus_executable_text)
		reset_gsetting org.gnome.nautilus.preferences executable-text-activation
		;;
	filechooser_dirs_first)
		reset_gsetting org.gtk.Settings.FileChooser sort-directories-first
		;;
	nautilus_tree_view)
		reset_gsetting org.gnome.nautilus.list-view use-tree-view
		;;
	nautilus_list_zoom)
		reset_gsetting org.gnome.nautilus.list-view default-zoom-level
		;;
	app_folders)
		reset_gsetting org.gnome.desktop.app-folders folder-children || true
		for folder in "${app_folders[@]}"; do
			schema="org.gnome.desktop.app-folders.folder:/org/gnome/desktop/app-folders/folders/${folder}/"
			reset_gsetting "${schema}" name || true
			reset_gsetting "${schema}" categories || true
		done
		;;
	extensions)
		reset_gsetting org.gnome.shell disable-user-extensions || true
		reset_gsetting org.gnome.shell enabled-extensions || true
		;;
	sleep_ac_off)
		reset_gsetting org.gnome.settings-daemon.plugins.power sleep-inactive-ac-timeout &&
			reset_gsetting org.gnome.settings-daemon.plugins.power sleep-inactive-ac-type
		;;
	sleep_battery_off)
		reset_gsetting org.gnome.settings-daemon.plugins.power sleep-inactive-battery-timeout &&
			reset_gsetting org.gnome.settings-daemon.plugins.power sleep-inactive-battery-type
		;;
	tracker_battery_saver)
		reset_gsetting org.freedesktop.Tracker.Miner.Files index-on-battery &&
			reset_gsetting org.freedesktop.Tracker.Miner.Files index-on-battery-first-time &&
			reset_gsetting org.freedesktop.Tracker.Miner.Files throttle
		;;
	battery_percent)
		reset_gsetting org.gnome.desktop.interface show-battery-percentage
		;;
	clock_details)
		reset_gsetting org.gnome.desktop.interface clock-show-date &&
			reset_gsetting org.gnome.desktop.interface clock-show-seconds
		;;
	hot_corners)
		reset_gsetting org.gnome.desktop.interface enable-hot-corners
		;;
	font_smoothing)
		reset_gsetting org.gnome.settings-daemon.plugins.xsettings hinting &&
			reset_gsetting org.gnome.settings-daemon.plugins.xsettings antialiasing &&
			reset_gsetting org.gnome.settings-daemon.plugins.xsettings rgba-order
		;;
	tilix)
		reset_gsetting com.gexperts.Tilix.Settings theme-variant || true
		reset_gsetting com.gexperts.Tilix.Settings font || true
		reset_gsetting com.gexperts.Tilix.Settings use-system-font || true
		reset_gsetting com.gexperts.Tilix.Settings bold-is-bright || true
		rm -f "${HOME}/.config/rtd/gconf-tilix-settings.ini"
		profiles="$(terminal_profiles)"
		for uuid in ${profiles}; do
			reset_terminal_profile "$(terminal_profile_schema "${uuid}")"
		done
		;;
	terminal)
		profiles="$(terminal_profiles)"
		for uuid in ${profiles}; do
			reset_terminal_profile "$(terminal_profile_schema "${uuid}")"
		done
		;;
	dock)
		for setting_key in "${dock_keys[@]}"; do
			reset_gsetting org.gnome.shell.extensions.dash-to-dock "${setting_key}" || true
		done
		;;
	panel)
		for setting_key in "${panel_keys[@]}"; do
			reset_gsetting org.gnome.shell.extensions.dash-to-panel "${setting_key}" || true
		done
		;;
	gtk4_custom|reset_theme)
		run_function_checked gnome::_reset_ui_theme_settings
		;;
	reload_shell)
		return 2
		;;
	startup_on|startup_off)
		run_function_checked gnome::set_startup_sound off /dev/null
		;;
	*)
		return 2
		;;
	esac
}

execute_tweak() {
	local key="$1"
	local force_apply="${2:-0}"
	local func=""
	local gtk4_values theme_name icon_name prefer_dark
	local layout
	local sound_file

	set_last_tweak_label "${key}"

	case "${key}" in
		mouse_accel)
			[[ "${force_apply}" != "1" ]] && tweak_is_applied "${key}" && return 2
			apply_gsetting org.gnome.desktop.peripherals.mouse accel-profile adaptive
			;;
		volume_limit)
			[[ "${force_apply}" != "1" ]] && tweak_is_applied "${key}" && return 2
			apply_gsetting org.gnome.desktop.sound allow-volume-above-100-percent false
			;;
		calendar_weekdate)
			[[ "${force_apply}" != "1" ]] && tweak_is_applied "${key}" && return 2
			apply_gsetting org.gnome.desktop.calendar show-weekdate true
			;;
		right_resize)
			[[ "${force_apply}" != "1" ]] && tweak_is_applied "${key}" && return 2
			apply_gsetting org.gnome.desktop.wm.preferences resize-with-right-button true
			;;
		window_buttons)
			[[ "${force_apply}" != "1" ]] && tweak_is_applied "${key}" && return 2
			apply_gsetting org.gnome.desktop.wm.preferences button-layout "${DEFAULT_BUTTON_LAYOUT}"
			;;
		workspaces_all_monitors)
			[[ "${force_apply}" != "1" ]] && tweak_is_applied "${key}" && return 2
			apply_gsetting org.gnome.shell.overrides workspaces-only-on-primary false
			;;
		nautilus_icon_zoom)
			[[ "${force_apply}" != "1" ]] && tweak_is_applied "${key}" && return 2
			apply_gsetting org.gnome.nautilus.icon-view default-zoom-level standard
			;;
		nautilus_executable_text)
			[[ "${force_apply}" != "1" ]] && tweak_is_applied "${key}" && return 2
			apply_gsetting org.gnome.nautilus.preferences executable-text-activation ask
			;;
		filechooser_dirs_first)
			[[ "${force_apply}" != "1" ]] && tweak_is_applied "${key}" && return 2
			apply_gsetting org.gtk.Settings.FileChooser sort-directories-first true
			;;
		nautilus_tree_view)
			[[ "${force_apply}" != "1" ]] && tweak_is_applied "${key}" && return 2
			apply_gsetting org.gnome.nautilus.list-view use-tree-view true
			;;
		nautilus_list_zoom)
			[[ "${force_apply}" != "1" ]] && tweak_is_applied "${key}" && return 2
			apply_gsetting org.gnome.nautilus.list-view default-zoom-level small
			;;
		app_folders)
			func="gnome::organize_overlay_menu"
			;;
		extensions)
			func="gnome::set_basic_extensions_enabled"
			;;
		sleep_ac_off)
			[[ "${force_apply}" != "1" ]] && tweak_is_applied "${key}" && return 2
			apply_gsetting org.gnome.settings-daemon.plugins.power sleep-inactive-ac-timeout 0 &&
				apply_gsetting org.gnome.settings-daemon.plugins.power sleep-inactive-ac-type nothing
			;;
		sleep_battery_off)
			[[ "${force_apply}" != "1" ]] && tweak_is_applied "${key}" && return 2
			apply_gsetting org.gnome.settings-daemon.plugins.power sleep-inactive-battery-timeout 0 &&
				apply_gsetting org.gnome.settings-daemon.plugins.power sleep-inactive-battery-type nothing
			;;
		tracker_battery_saver)
			[[ "${force_apply}" != "1" ]] && tweak_is_applied "${key}" && return 2
			apply_gsetting org.freedesktop.Tracker.Miner.Files index-on-battery false &&
				apply_gsetting org.freedesktop.Tracker.Miner.Files index-on-battery-first-time false &&
				apply_gsetting org.freedesktop.Tracker.Miner.Files throttle 15
			;;
		battery_percent)
			[[ "${force_apply}" != "1" ]] && tweak_is_applied "${key}" && return 2
			apply_gsetting org.gnome.desktop.interface show-battery-percentage true
			;;
		clock_details)
			[[ "${force_apply}" != "1" ]] && tweak_is_applied "${key}" && return 2
			apply_gsetting org.gnome.desktop.interface clock-show-date true &&
				apply_gsetting org.gnome.desktop.interface clock-show-seconds true
			;;
		hot_corners)
			[[ "${force_apply}" != "1" ]] && tweak_is_applied "${key}" && return 2
			apply_gsetting org.gnome.desktop.interface enable-hot-corners true
			;;
		font_smoothing)
			[[ "${force_apply}" != "1" ]] && tweak_is_applied "${key}" && return 2
			apply_gsetting org.gnome.settings-daemon.plugins.xsettings hinting slight &&
				apply_gsetting org.gnome.settings-daemon.plugins.xsettings antialiasing rgba &&
				apply_gsetting org.gnome.settings-daemon.plugins.xsettings rgba-order rgb
			;;
		tilix)
			func="gnome::set_tilix_ui_tweaks_for_user"
			;;
		terminal)
			func="gnome::_apply_terminal_preferences"
			;;
		dock)
			func="gnome::configure_dash_to_dock"
			;;
		panel)
			func="gnome::configure_dash_to_panel"
			;;
		buttons_custom)
			layout="$(prompt_window_buttons_layout)" || return 130
			func="gnome::ensure_window_buttons_visible"
			if [[ "${force_apply}" != "1" ]] && gsettings_value_is org.gnome.desktop.wm.preferences button-layout "'${layout}'"; then
				return 2
			fi
			if run_function_checked "${func}" "${layout}"; then
				return 0
			fi
			return 1
			;;
		gtk4_custom)
			gtk4_values="$(prompt_custom_gtk4_theme)" || return 130
			IFS='|' read -r theme_name icon_name prefer_dark <<< "${gtk4_values}"
			func="gnome::_apply_gtk4_theme"
			if [[ "${force_apply}" != "1" ]] &&
				gtk4_setting_is gtk-theme-name "${theme_name}" &&
				gtk4_setting_is gtk-icon-theme-name "${icon_name}" &&
				gtk4_setting_is gtk-application-prefer-dark-theme "${prefer_dark}"; then
				return 2
			fi
			if run_function_checked "${func}" "${theme_name}" "${icon_name}" "${prefer_dark}"; then
				return 0
			fi
			return 1
			;;
		reset_theme)
			func="gnome::_reset_ui_theme_settings"
			;;
		reload_shell)
			func="gnome::_reload_shell_theme"
			;;
		startup_on)
			func="gnome::set_startup_sound"
			if [[ "${force_apply}" != "1" ]] && startup_sound_enabled; then
				return 2
			fi
			sound_file="$(prompt_startup_sound_file)" || return 130
			if run_function_checked "${func}" on "${sound_file}"; then
				return 0
			fi
			return 1
			;;
		startup_off)
			func="gnome::set_startup_sound"
			if [[ "${force_apply}" != "1" ]] && tweak_is_applied startup_off; then
				return 2
			fi
			if run_function_checked "${func}" off /dev/null; then
				return 0
			fi
			return 1
			;;
		*)
			return 2
			;;
	esac
	local case_rc=$?
	[[ -z "${func}" ]] && return "${case_rc}"

	if [[ "${force_apply}" != "1" ]] && tweak_is_applied "${key}"; then
		return 2
	fi

	run_function_checked "${func}"
}

run_selected_tweaks() {
	local -a success_list failure_list skipped_list
	local key
	local rc=0
	local run_rc
	local force_apply
	local selected_count=0

	for key in "${MENU_KEYS[@]}"; do
		checkbox_state "${MENU_SELECTION[${key}]:-FALSE}" || continue
		selected_count=$((selected_count + 1))
		force_apply=0
		if ! checkbox_state "${MENU_STATE[${key}]:-FALSE}"; then
			force_apply=1
		fi

		execute_tweak "${key}" "${force_apply}"
		run_rc=$?

		case "${run_rc}" in
		0)
			success_list+=("${LAST_TWEAK_LABEL}")
			;;
		2)
			skipped_list+=("${LAST_TWEAK_LABEL}")
			;;
		*)
			failure_list+=("${LAST_TWEAK_LABEL}")
			rc=1
			;;
		esac
	done

	if (( selected_count == 0 )); then
		zenity --info --title "${PUBLICATION}" --text "No tweaks selected. Nothing changed."
		return 0
	fi

	local summary
	summary="GNOME tweaks execution completed."

	if (( ${#success_list[@]} > 0 )); then
		summary+=$'\n\nApplied successfully:'
		for key in "${success_list[@]}"; do
			summary+=$'\n'"- ${key}"
		done
	fi

	if (( ${#skipped_list[@]} > 0 )); then
		summary+=$'\n\nSkipped:'
		for key in "${skipped_list[@]}"; do
			summary+=$'\n'"- ${key}"
		done
	fi

	if (( ${#failure_list[@]} > 0 )); then
		summary+=$'\n\nFailed:'
		for key in "${failure_list[@]}"; do
			summary+=$'\n'"- ${key}"
		done
		zenity --warning --title "${PUBLICATION}" --width 860 --height 620 --text "${summary}"
	else
		zenity --info --title "${PUBLICATION}" --width 860 --height 620 --text "${summary}"
	fi

	return "${rc}"
}

print_status() {
	local key status

	initialize_menu_state
	for key in "${MENU_KEYS[@]}"; do
		status="${MENU_APPLIED[${key}]:-Unknown}"
		printf '%-26s %-12s %s\n' "${key}" "${status}" "${MENU_TEXT[${key}]}"
	done
}

print_tweak_catalog() {
	local key status

	initialize_menu_state
	for key in "${MENU_KEYS[@]}"; do
		status="${MENU_APPLIED[${key}]:-Unknown}"
		printf '%s\t%s\t%s\t%s\t%s\n' \
			"${key}" \
			"${MENU_CATEGORY[${key}]:-General}" \
			"${status}" \
			"${MENU_TEXT[${key}]}" \
			"${MENU_DESCRIPTION[${key}]:-}"
	done
}

print_profile_list() {
	local file

	mkdir -p "${PROFILE_DIR}"
	find "${PROFILE_DIR}" -maxdepth 1 -type f -name '*.profile' -print0 2>/dev/null |
		sort -z |
		while IFS= read -r -d '' file; do
			printf '%s\t%s\n' "$(basename "${file}" .profile)" "${file}"
		done
}

apply_tweaks_cli() {
	local key rc=0 run_rc

	[[ $# -gt 0 ]] || {
		write_error "No tweak IDs were provided."
		return 64
	}

	for key in "$@"; do
		if ! valid_tweak_key "${key}"; then
			write_error "Unknown tweak ID: ${key}"
			rc=1
			continue
		fi
		execute_tweak "${key}" 1
		run_rc=$?
		case "${run_rc}" in
		0|2) ;;
		130) return 130 ;;
		*) rc=1 ;;
		esac
	done
	return "${rc}"
}

set_tweak_state_cli() {
	local key="$1"
	local state="$2"

	[[ -n "${key}" && -n "${state}" ]] || {
		write_error "Usage: $(basename "$0") --set <tweak-id> <on|off>"
		return 64
	}

	if ! valid_tweak_key "${key}"; then
		write_error "Unknown tweak ID: ${key}"
		return 64
	fi

	case "${state}" in
	on|true|1|yes)
		execute_tweak "${key}" 1
		;;
	off|false|0|no)
		reset_tweak "${key}"
		;;
	*)
		write_error "Invalid state '${state}'. Use on or off."
		return 64
		;;
	esac
}

apply_profile_cli() {
	local profile="$1"
	local profile_file line
	local -a keys=()

	[[ -n "${profile}" ]] || {
		write_error "No profile name was provided."
		return 64
	}
	profile_file="$(profile_path "${profile}")"
	[[ -f "${profile_file}" ]] || {
		write_error "Profile file not found: ${profile_file}"
		return 1
	}

	while IFS= read -r line; do
		[[ -n "${line}" && "${line}" != \#* ]] || continue
		valid_tweak_key "${line}" && keys+=("${line}")
	done <"${profile_file}"

	apply_tweaks_cli "${keys[@]}"
}

gtk_frontend_ready() {
	command -v python3 >/dev/null 2>&1 &&
		python3 -c 'import gi; gi.require_version("Gtk", "3.0"); from gi.repository import Gtk' >/dev/null 2>&1
}

launch_gtk_frontend() {
	[[ -r "${GTK_FRONTEND}" ]] || return 1
	gtk_frontend_ready || return 1
	exec python3 "${GTK_FRONTEND}" "$@"
}


